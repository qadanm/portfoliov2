---
import Admin from '@/layouts/Admin.astro';
import { angles } from '@/data/angles';
import { JOB_STATUSES } from '@/lib/storage';
---

<Admin
  title="Add job"
  intro="Paste one job to review carefully, or switch to bulk mode to drop in 10–30 links and queue them all at once. Bulk-added jobs land directly in /today as Saved."
>
  <div class="mode-tabs no-print" role="tablist" aria-label="intake mode">
    <button class="mode-tab is-active" role="tab" aria-selected="true" data-mode="single" type="button">Single (review &amp; edit)</button>
    <button class="mode-tab" role="tab" aria-selected="false" data-mode="bulk" type="button">Bulk (paste &amp; queue)</button>
  </div>

  <!-- Step 1: single input ─────────────────────────────────────── -->
  <section class="card" id="step-input">
    <label class="lbl">Job URL <span class="hint">optional</span></label>
    <input id="jd-url" type="url" placeholder="https://… (LinkedIn, Greenhouse, Lever, Workday, company career site)" />

    <label class="lbl" style="margin-top:14px;">Job description <span class="hint">paste the full posting for the best results</span></label>
    <textarea id="jd-text" rows="14" placeholder="Most boards block browser fetching, so paste the description here. The longer the better."></textarea>

    <div class="actions-row">
      <button class="btn btn--primary" id="analyze-btn">Analyze</button>
      <button class="btn" id="try-fetch-btn">Try to fetch from URL</button>
      <button class="btn" id="reset-btn">Reset</button>
    </div>
    <p id="input-error" class="err" style="display:none;"></p>
    <p id="fetch-status" class="hint" style="margin-top:6px;display:none;"></p>
  </section>

  <!-- Step 1B: bulk input ──────────────────────────────────────── -->
  <section class="card" id="step-bulk" style="display:none;">
    <label class="lbl">Job URLs <span class="hint">one per line · 10–30 at a time</span></label>
    <textarea id="bulk-urls" rows="12" placeholder="https://www.linkedin.com/jobs/view/1234567
https://boards.greenhouse.io/acme/jobs/12345
https://jobs.lever.co/example/abc-123
…"></textarea>

    <details style="margin-top:10px;">
      <summary class="lbl" style="cursor:pointer; display:inline;">Or paste full JDs <span class="hint">separate each with <code>---</code> on its own line</span></summary>
      <textarea id="bulk-jds" rows="10" style="margin-top:8px;" placeholder="Full job description text…
---
Another full job description…
---
Another…"></textarea>
    </details>

    <div class="actions-row">
      <button class="btn btn--primary" id="bulk-analyze-btn">Analyze all &amp; queue</button>
      <button class="btn" id="bulk-clear-btn">Clear</button>
    </div>
    <p id="bulk-status" class="hint" style="margin-top:8px; display:none;"></p>
    <div id="bulk-results" style="margin-top:12px; display:none;"></div>
  </section>

  <!-- Step 2: results + editable preview ────────────────────────── -->
  <section id="step-preview" style="display:none; margin-top:16px;">
    <div class="grid">
      <!-- Score panel -->
      <article class="card score-card">
        <div class="score">
          <div class="score__value" id="score-value">—</div>
          <div>
            <div class="score__label">Opportunity score</div>
            <div id="score-meta" class="score__meta">—</div>
          </div>
        </div>

        <div class="score-row">
          <span class="lbl">Recommended angle</span>
          <span id="rec-angle" class="rec">—</span>
        </div>
        <div class="score-row">
          <span class="lbl">Confidence</span>
          <span id="confidence" class="rec">—</span>
        </div>
        <div class="score-row">
          <span class="lbl">Priority</span>
          <span id="priority" class="rec">—</span>
        </div>
        <div class="score-row">
          <span class="lbl">Application effort</span>
          <span id="effort" class="rec">—</span>
        </div>

        <div class="section">
          <h3>Recommended action</h3>
          <p id="action" class="muted"></p>
        </div>

        <div class="section">
          <h3>Score breakdown</h3>
          <ul id="breakdown" class="bd"></ul>
        </div>

        <div class="section" id="strengths-section">
          <h3>Strengths matched</h3>
          <div id="strengths" class="pill-list"></div>
        </div>

        <div class="section" id="gaps-section" style="display:none;">
          <h3>Stack gaps</h3>
          <div id="gaps" class="pill-list"></div>
        </div>

        <div class="section" id="risks-section" style="display:none;">
          <h3>Risk flags</h3>
          <ul id="risks" class="muted bullet-list"></ul>
        </div>
      </article>

      <!-- Editable job draft -->
      <article class="card">
        <h2 class="h2">Editable draft</h2>
        <p class="hint" style="margin-bottom:10px;">Auto-filled from the analysis. Change anything before saving.</p>

        <div class="row">
          <label>Company<input id="f-company" /></label>
          <label>Role<input id="f-role" /></label>
        </div>
        <div class="row">
          <label>URL<input id="f-url" type="url" /></label>
          <label>Source<input id="f-source" /></label>
        </div>
        <div class="row">
          <label>Location<input id="f-location" /></label>
          <label>Status
            <select id="f-status">
              {JOB_STATUSES.map(s => <option value={s}>{s}</option>)}
            </select>
          </label>
        </div>
        <div class="row">
          <label>Salary min ($)<input id="f-salaryMin" type="number" min="0" step="1000" /></label>
          <label>Salary max ($)<input id="f-salaryMax" type="number" min="0" step="1000" /></label>
        </div>
        <div class="row">
          <label>Resume angle
            <select id="f-angle">
              {angles.map(a => <option value={a.id}>{a.label}</option>)}
            </select>
          </label>
          <label>Priority
            <select id="f-priority">
              <option value="">—</option>
              <option value="1">P1 (highest)</option>
              <option value="2">P2</option>
              <option value="3">P3</option>
            </select>
          </label>
        </div>
        <label>Next step<input id="f-nextStep" /></label>

        <div class="actions-row" style="margin-top:14px;">
          <button class="btn btn--primary" id="save-btn">Save job</button>
          <button class="btn" id="discard-btn">Discard</button>
        </div>
        <p id="save-error" class="err" style="display:none;"></p>
      </article>
    </div>
  </section>

  <!-- Step 3: saved + quick actions ──────────────────────────────── -->
  <section id="step-saved" class="card" style="display:none; margin-top:16px;">
    <h2 class="h2">Saved <span class="hint">to /jobs</span></h2>
    <p id="saved-summary" class="muted" style="margin-bottom:12px;"></p>
    <h3 style="font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--c-text-subtle); margin-bottom:8px;">Quick actions</h3>
    <div id="quick-actions" class="row" style="flex-wrap:wrap;"></div>
    <div class="row" style="margin-top:14px;">
      <a class="btn" href="/jobs">All jobs →</a>
      <a class="btn" href="/jobs/new">Add another</a>
    </div>
  </section>
</Admin>

<style>
  .lbl { font-size: 12px; color: var(--c-text-subtle); display: block; margin-bottom: 4px; }
  .hint { color: var(--c-text-subtle); font-size: 12px; }
  .err { color: #F87171; font-size: 12px; margin-top: 8px; line-height: 1.5; }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .row > label { display: flex; flex-direction: column; gap: 4px; font-size: 12px; color: var(--c-text-subtle); }
  .row .btn { font-size: 13px; }
  .actions-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 12px; }
  .actions-row #reset-btn, .actions-row #discard-btn { margin-left: auto; }
  textarea { font-family: var(--font-mono); font-size: 12.5px; line-height: 1.55; resize: vertical; min-height: 220px; }

  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 1000px) { .grid { grid-template-columns: 1fr; } }

  .h2 { font-family: var(--font-display); font-size: 22px; font-weight: 400; letter-spacing: -0.01em; margin-bottom: 12px; }

  .score-card { display: flex; flex-direction: column; gap: 12px; }
  .score { display: flex; align-items: baseline; gap: 14px; padding: 16px; background: var(--c-bg); border: 1px solid var(--c-border); border-radius: var(--r-md); }
  .score__value { font-family: var(--font-display); font-size: 56px; line-height: 1; }
  .score__label { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-text-subtle); }
  .score__meta { font-size: 12px; color: var(--c-text-muted); margin-top: 2px; }
  .score-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--c-border-subtle); font-size: 13px; }
  .score-row:last-of-type { border-bottom: none; }
  .rec { color: var(--c-text); font-weight: 500; }

  .section { margin-top: 8px; padding-top: 12px; border-top: 1px solid var(--c-border-subtle); }
  .section h3 { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-text-subtle); margin-bottom: 8px; }
  .muted { color: var(--c-text-muted); font-size: 13px; line-height: 1.6; }

  .bd { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .bd :global(li) { display: grid; grid-template-columns: minmax(140px, max-content) 1fr 32px 32px; gap: 12px; align-items: center; font-size: 12px; color: var(--c-text-muted); }
  .bd :global(.bd-label) { white-space: nowrap; }
  .bd :global(.bar) { background: var(--c-bg-muted); height: 6px; border-radius: 3px; overflow: hidden; min-width: 60px; }
  .bd :global(.bar) > :global(span) { display: block; height: 100%; background: var(--c-accent); }
  .bd :global(.num) { font-family: var(--font-mono); text-align: right; font-size: 12px; color: var(--c-text); }
  .bd :global(.bd-weight) { font-family: var(--font-mono); text-align: right; font-size: 10px; color: var(--c-text-subtle); }

  .pill-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .pill-list :global(.pill), :global(.score-row) :global(.pill) { padding: 3px 9px; border-radius: var(--r-full); font-family: var(--font-mono); font-size: 11px;
    background: var(--c-bg-muted); border: 1px solid var(--c-border-subtle); color: var(--c-text-muted); }
  .pill-list :global(.pill--good) { color: var(--c-success); border-color: rgba(16,185,129,0.4); background: rgba(16,185,129,0.08); }
  .pill-list :global(.pill--gap) { color: #F87171; border-color: rgba(239, 68, 68, 0.4); background: rgba(239, 68, 68, 0.08); }
  :global(.score-row) :global(.pill--p1) { color: var(--c-accent); border-color: var(--c-accent); }

  .bullet-list { padding-left: 18px; }
  .bullet-list :global(li) { margin-bottom: 4px; }

  /* Bulk mode tabs and results */
  .mode-tabs { display: inline-flex; gap: 0; margin-bottom: 14px; border: 1px solid var(--c-border); border-radius: var(--r-md); overflow: hidden; background: var(--c-bg-elev); }
  .mode-tab { background: transparent; border: none; color: var(--c-text-muted); padding: 8px 14px; font-size: 13px; font-family: inherit; cursor: pointer; border-right: 1px solid var(--c-border); }
  .mode-tab:last-child { border-right: none; }
  .mode-tab.is-active { background: var(--c-bg-muted); color: var(--c-text); }
  .mode-tab:hover:not(.is-active) { color: var(--c-text); }

  #bulk-results :global(.bulk-result) { padding: 10px 12px; border: 1px solid var(--c-border-subtle); border-radius: var(--r-md); margin-bottom: 6px; display: grid; grid-template-columns: 90px 1fr auto auto auto; gap: 12px; align-items: center; font-size: 12px; }
  #bulk-results :global(.bulk-result--err) { border-color: rgba(239,68,68,0.25); background: rgba(239,68,68,0.04); grid-template-columns: 90px 1fr auto auto; }
  #bulk-results :global(.bulk-result--dup) { opacity: 0.78; }
  #bulk-results :global(.bulk-result__board) { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--c-text-subtle); padding: 2px 7px; border: 1px solid var(--c-border-subtle); border-radius: var(--r-full); white-space: nowrap; text-align: center; }
  #bulk-results :global(.bulk-result__main) { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  #bulk-results :global(.bulk-result__co) { color: var(--c-text); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  #bulk-results :global(.bulk-result__role) { color: var(--c-text-muted); font-family: var(--font-mono); font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  #bulk-results :global(.bulk-result__url) { color: var(--c-text-subtle); font-family: var(--font-mono); font-size: 10.5px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-decoration: none; }
  #bulk-results :global(.bulk-result__url:hover) { color: var(--c-accent); text-decoration: underline; }
  #bulk-results :global(.bulk-result__reason) { color: #F87171; font-size: 11.5px; line-height: 1.4; }
  #bulk-results :global(.bulk-result__hint) { color: var(--c-text-muted); font-size: 11px; line-height: 1.4; }
  #bulk-results :global(.bulk-result__score) { font-family: var(--font-display); font-size: 18px; min-width: 32px; text-align: right; }
  #bulk-results :global(.bulk-result__status) { font-family: var(--font-mono); font-size: 10px; padding: 2px 7px; border-radius: var(--r-full); text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; }
  #bulk-results :global(.bulk-result__status--added) { color: var(--c-success); border: 1px solid rgba(16,185,129,0.4); background: rgba(16,185,129,0.08); }
  #bulk-results :global(.bulk-result__status--dup) { color: var(--c-text-subtle); border: 1px solid var(--c-border-subtle); background: transparent; }
  #bulk-results :global(.bulk-result__status--err) { color: #F87171; border: 1px solid rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); }
  #bulk-results :global(.bulk-result__actions) { display: flex; gap: 6px; align-items: center; }
  #bulk-results :global(.bulk-result__action) { font-family: var(--font-mono); font-size: 10.5px; padding: 4px 9px; border-radius: var(--r-md); border: 1px solid var(--c-border); background: var(--c-bg-elev); color: var(--c-text); cursor: pointer; text-decoration: none; white-space: nowrap; line-height: 1; }
  #bulk-results :global(.bulk-result__action:hover) { border-color: var(--c-accent); color: var(--c-accent); }
  #bulk-results :global(.bulk-result__action--primary) { background: var(--c-accent); color: var(--c-bg); border-color: var(--c-accent); }
  #bulk-results :global(.bulk-result__action--primary:hover) { color: var(--c-bg); opacity: 0.85; }
  #bulk-results :global(.bulk-fix) { grid-column: 1 / -1; padding: 12px; margin-top: 8px; background: var(--c-bg); border: 1px solid var(--c-border); border-radius: var(--r-md); display: flex; flex-direction: column; gap: 8px; }
  #bulk-results :global(.bulk-fix .row) { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  #bulk-results :global(.bulk-fix label) { display: flex; flex-direction: column; gap: 4px; font-size: 11px; color: var(--c-text-subtle); }
  #bulk-results :global(.bulk-fix input), #bulk-results :global(.bulk-fix textarea) { font-family: inherit; font-size: 12.5px; }
  #bulk-results :global(.bulk-fix textarea) { font-family: var(--font-mono); font-size: 11.5px; min-height: 100px; }
  #bulk-results :global(.bulk-fix .actions) { display: flex; gap: 8px; justify-content: flex-end; margin-top: 4px; }
  #bulk-results :global(.bulk-summary) { display: flex; gap: 14px; padding: 10px 14px; background: var(--c-bg-muted); border: 1px solid var(--c-border); border-radius: var(--r-md); margin-bottom: 12px; font-size: 13px; align-items: center; flex-wrap: wrap; }
  #bulk-results :global(.bulk-summary strong) { color: var(--c-text); font-family: var(--font-display); font-size: 18px; line-height: 1; margin-right: 4px; }
  #bulk-results :global(.bulk-summary .label) { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-text-subtle); }
  @media (max-width: 720px) {
    #bulk-results :global(.bulk-result) { grid-template-columns: 1fr auto; }
    #bulk-results :global(.bulk-result__board), #bulk-results :global(.bulk-result__score), #bulk-results :global(.bulk-result__actions) { grid-column: 1 / -1; justify-self: start; }
  }
</style>

<script>
  import { runIntake, runIntakeAsync, tryFetchJD, fetchJobViaProxy, type IntakeResult, type IntakeAsyncOutcome } from '@/lib/job-intake';
  import { parseJobUrl } from '@/lib/job-url-parser';
  import { jobsStore, ensureSchema, type Job, type JobStatus } from '@/lib/storage';

  ensureSchema();

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

  let lastResult: IntakeResult | null = null;

  function escape(s: string): string {
    return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  function showStep(step: 'input' | 'preview' | 'saved') {
    ($('step-input') as HTMLElement).style.display = step === 'input' ? 'block' : 'none';
    ($('step-preview') as HTMLElement).style.display = step === 'preview' ? 'block' : 'none';
    ($('step-saved') as HTMLElement).style.display = step === 'saved' ? 'block' : 'none';
  }

  function fillDraft(r: IntakeResult) {
    const d = r.draft;
    ($<HTMLInputElement>('f-company')).value = d.company ?? '';
    ($<HTMLInputElement>('f-role')).value = d.role ?? '';
    ($<HTMLInputElement>('f-url')).value = d.url ?? '';
    ($<HTMLInputElement>('f-source')).value = d.source ?? '';
    ($<HTMLInputElement>('f-location')).value = d.location ?? '';
    ($<HTMLInputElement>('f-salaryMin')).value = d.salaryMin ? String(d.salaryMin) : '';
    ($<HTMLInputElement>('f-salaryMax')).value = d.salaryMax ? String(d.salaryMax) : '';
    ($<HTMLSelectElement>('f-status')).value = (d.status as JobStatus) ?? 'Saved';
    ($<HTMLSelectElement>('f-angle')).value = d.resumeAngle ?? '';
    ($<HTMLSelectElement>('f-priority')).value = d.priority ? String(d.priority) : '';
    ($<HTMLInputElement>('f-nextStep')).value = d.nextStep ?? '';
  }

  function fillScore(r: IntakeResult) {
    if (!r.score) return;
    const s = r.score;
    $('score-value').textContent = String(s.total);
    $('score-meta').textContent = `${s.confidence} confidence · priority P${s.priority}`;
    $('rec-angle').textContent = s.suggestedAngleLabel;
    $('confidence').textContent = s.confidence;
    $('priority').innerHTML = `<span class="pill ${s.priority === 1 ? 'pill--p1' : ''}">P${s.priority}</span>`;
    $('effort').textContent = s.applicationEffort;
    $('action').textContent = s.recommendedAction;

    $('breakdown').innerHTML = s.breakdown.map(b => {
      const rounded = Math.round(b.score);
      const pct = Math.max(0, Math.min(100, rounded));
      const color = b.score < 0 ? '#F87171' : 'var(--c-accent)';
      const bar = b.weight > 0
        ? `<span class="bar"><span style="width:${pct}%; background:${color};"></span></span>`
        : `<span class="hint" style="font-size:11px;">${escape(b.note ?? '')}</span>`;
      const weight = b.weight ? `<span class="bd-weight">${b.weight}%</span>` : '';
      return `<li><span class="bd-label">${escape(b.label)}</span>${bar}<span class="num">${rounded}</span>${weight}</li>`;
    }).join('');

    $('strengths').innerHTML = s.topStrengths.length
      ? s.topStrengths.map(x => `<span class="pill pill--good">${escape(x)}</span>`).join('')
      : '<span class="hint">No strong matches yet — pick a different angle or add more JD text.</span>';

    if (s.gaps.length) {
      $('gaps-section').style.display = '';
      $('gaps').innerHTML = s.gaps.map(x => `<span class="pill pill--gap">${escape(x)}</span>`).join('');
    } else {
      $('gaps-section').style.display = 'none';
    }

    if (r.analyzer?.riskFlags.length) {
      $('risks-section').style.display = '';
      $('risks').innerHTML = r.analyzer.riskFlags.map(f => `<li>${escape(f)}</li>`).join('');
    } else {
      $('risks-section').style.display = 'none';
    }
  }

  function showInputError(msg: string) {
    const el = $('input-error');
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }
  function showSaveError(msg: string) {
    const el = $('save-error');
    el.textContent = msg;
    el.style.display = msg ? 'block' : 'none';
  }

  function runAnalysis() {
    const urlText = ($<HTMLInputElement>('jd-url')).value.trim();
    const jdText = ($<HTMLTextAreaElement>('jd-text')).value.trim();
    if (!urlText && jdText.length < 50) {
      showInputError('Paste a URL or at least a paragraph of job description.');
      return;
    }
    showInputError('');
    lastResult = runIntake({ urlText: urlText || undefined, jdText: jdText || undefined });
    fillDraft(lastResult);
    fillScore(lastResult);
    showStep('preview');
  }

  $('analyze-btn').addEventListener('click', runAnalysis);

  $('try-fetch-btn').addEventListener('click', async () => {
    const urlText = ($<HTMLInputElement>('jd-url')).value.trim();
    const status = $('fetch-status');
    if (!urlText) {
      showInputError('Paste a URL first.');
      return;
    }
    showInputError('');
    status.style.display = 'block';
    status.textContent = 'Fetching via the edge proxy…';

    // 1. Try the server-side proxy (works for LinkedIn + most boards).
    const proxy = await fetchJobViaProxy(urlText);
    if (proxy.kind === 'ok') {
      const d = proxy.data;
      const merged: string[] = [];
      if (d.title) merged.push(`Title: ${d.title}`);
      if (d.company) merged.push(`Company: ${d.company}`);
      if (d.location) merged.push(`Location: ${d.location}`);
      if (d.description) merged.push('', d.description);
      ($<HTMLTextAreaElement>('jd-text')).value = merged.join('\n').trim();
      status.textContent = `Fetched from ${d.source} (${d.via}). Review the text above and hit Analyze.`;
      return;
    }

    // 2. Proxy unavailable (dev mode without wrangler) — try client-side fetch.
    if (proxy.kind === 'unavailable') {
      status.textContent = 'Proxy not running, trying client-side fetch…';
      const text = await tryFetchJD(urlText);
      if (text) {
        ($<HTMLTextAreaElement>('jd-text')).value = text;
        status.textContent = 'Fetched directly. Review the text above and hit Analyze.';
        return;
      }
      status.textContent = `${proxy.message} Open the URL in a tab and paste the JD into the box.`;
      return;
    }

    // 3. Proxy ran but the upstream failed — give a specific reason.
    status.textContent = `${proxy.message}${proxy.hint ? ' ' + proxy.hint : ''}`;
  });

  $('reset-btn').addEventListener('click', () => {
    ($<HTMLInputElement>('jd-url')).value = '';
    ($<HTMLTextAreaElement>('jd-text')).value = '';
    $('fetch-status').style.display = 'none';
    lastResult = null;
    showStep('input');
  });

  $('discard-btn').addEventListener('click', () => {
    lastResult = null;
    showStep('input');
  });

  $('save-btn').addEventListener('click', () => {
    const company = ($<HTMLInputElement>('f-company')).value.trim();
    const role = ($<HTMLInputElement>('f-role')).value.trim();
    if (!company || !role) {
      showSaveError('Company and role are required.');
      return;
    }
    showSaveError('');
    const job: Job = {
      id: crypto.randomUUID(),
      company,
      role,
      url: ($<HTMLInputElement>('f-url')).value.trim() || undefined,
      source: ($<HTMLInputElement>('f-source')).value.trim() || undefined,
      location: ($<HTMLInputElement>('f-location')).value.trim() || undefined,
      salaryMin: Number(($<HTMLInputElement>('f-salaryMin')).value) || undefined,
      salaryMax: Number(($<HTMLInputElement>('f-salaryMax')).value) || undefined,
      status: (($<HTMLSelectElement>('f-status')).value as JobStatus) || 'Saved',
      resumeAngle: ($<HTMLSelectElement>('f-angle')).value || undefined,
      priority: (Number(($<HTMLSelectElement>('f-priority')).value) as 1|2|3) || undefined,
      fitScore: lastResult?.score?.total,
      jdText: lastResult?.draft.jdText,
      nextStep: ($<HTMLInputElement>('f-nextStep')).value.trim() || undefined,
      dateFound: lastResult?.draft.dateFound ?? Date.now(),
      createdAt: Date.now(),
      updatedAt: Date.now(),
    };
    jobsStore.upsert(job);

    // Saved view
    $('saved-summary').textContent = `${company} — ${role}${lastResult?.score ? ` · score ${lastResult.score.total} · ${lastResult.score.suggestedAngleLabel}` : ''}`;
    const links = (lastResult?.nextSteps ?? []).map(a => `<a class="btn" href="${a.href}">${escape(a.label)}</a>`).join('');
    $('quick-actions').innerHTML = links;

    showStep('saved');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ── Mode tabs (single vs bulk) ───────────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>('.mode-tab');
  function setMode(mode: 'single' | 'bulk') {
    tabs.forEach(t => {
      const active = t.dataset.mode === mode;
      t.classList.toggle('is-active', active);
      t.setAttribute('aria-selected', String(active));
    });
    ($('step-input') as HTMLElement).style.display = mode === 'single' ? 'block' : 'none';
    ($('step-bulk') as HTMLElement).style.display = mode === 'bulk' ? 'block' : 'none';
    if (mode === 'bulk') {
      ($('step-preview') as HTMLElement).style.display = 'none';
      ($('step-saved') as HTMLElement).style.display = 'none';
    }
  }
  tabs.forEach(t => t.addEventListener('click', () => setMode(t.dataset.mode as 'single' | 'bulk')));

  // ── Bulk intake ──────────────────────────────────────────────────────
  type BulkItem = { id: string; source: string; kind: 'url' | 'jd' };
  type BulkOutcome =
    | { id: string; status: 'added'; job: Job; score?: number; source: string; board?: string }
    | { id: string; status: 'duplicate'; matched: Job; source: string; board?: string }
    | { id: string; status: 'error'; reason: string; hint?: string; source: string; board?: string; statusCode?: number };

  function looksLikeUrl(line: string): boolean {
    return /^https?:\/\//i.test(line.trim());
  }

  function parseBulkInputs(): BulkItem[] {
    const urlBlock = ($<HTMLTextAreaElement>('bulk-urls')).value.trim();
    const jdBlock = ($<HTMLTextAreaElement>('bulk-jds')).value.trim();
    const items: BulkItem[] = [];
    if (urlBlock) {
      for (const raw of urlBlock.split(/\r?\n/)) {
        const line = raw.trim();
        if (!line) continue;
        if (looksLikeUrl(line)) items.push({ id: crypto.randomUUID(), source: line, kind: 'url' });
      }
    }
    if (jdBlock) {
      const chunks = jdBlock.split(/^\s*-{3,}\s*$/m).map(c => c.trim()).filter(c => c.length > 50);
      for (const chunk of chunks) items.push({ id: crypto.randomUUID(), source: chunk, kind: 'jd' });
    }
    return items;
  }

  function findDuplicate(existingJobs: Job[], item: BulkItem, intake: IntakeResult): Job | null {
    if (item.kind === 'url') {
      const a = item.source.replace(/[?#].*$/, '').replace(/\/$/, '').toLowerCase();
      for (const ex of existingJobs) {
        if (!ex.url) continue;
        const b = ex.url.replace(/[?#].*$/, '').replace(/\/$/, '').toLowerCase();
        if (a === b) return ex;
      }
    }
    // Fallback: company + role match (case-insensitive)
    const co = (intake.draft.company ?? '').trim().toLowerCase();
    const role = (intake.draft.role ?? '').trim().toLowerCase();
    if (co && role) {
      for (const ex of existingJobs) {
        if ((ex.company ?? '').trim().toLowerCase() === co
            && (ex.role ?? '').trim().toLowerCase() === role) return ex;
      }
    }
    return null;
  }

  function boardLabelForItem(item: BulkItem): string | undefined {
    if (item.kind !== 'url') return 'JD paste';
    try { return parseJobUrl(item.source).boardLabel; } catch { return undefined; }
  }

  function buildJobFromIntake(intake: IntakeResult, fallbackUrl: string | undefined): Job {
    const d = intake.draft;
    return {
      id: crypto.randomUUID(),
      company: d.company || '(unknown)',
      role: d.role || '(unknown)',
      url: d.url ?? fallbackUrl,
      source: d.source,
      location: d.location,
      salaryMin: d.salaryMin,
      salaryMax: d.salaryMax,
      status: 'Saved',
      resumeAngle: d.resumeAngle,
      priority: d.priority,
      fitScore: intake.score?.total,
      jdText: d.jdText,
      nextStep: d.nextStep,
      dateFound: d.dateFound ?? Date.now(),
      createdAt: Date.now(),
      updatedAt: Date.now(),
    };
  }

  async function processBulkItem(item: BulkItem, existingJobs: Job[]): Promise<BulkOutcome> {
    const board = boardLabelForItem(item);
    let outcome: IntakeAsyncOutcome;
    try {
      outcome = await runIntakeAsync({
        urlText: item.kind === 'url' ? item.source : undefined,
        jdText: item.kind === 'jd' ? item.source : undefined,
      });
    } catch (e: any) {
      return { id: item.id, status: 'error', reason: e?.message ?? 'analyze failed', source: item.source, board };
    }

    const intake = outcome.result;
    const dup = findDuplicate(existingJobs, item, intake);
    if (dup) return { id: item.id, status: 'duplicate', matched: dup, source: item.source, board };

    const d = intake.draft;
    if (!d.company && !d.role) {
      // Build a specific reason + hint so the user knows what to do next.
      const p = outcome.proxy;
      let reason = 'Could not extract company or role.';
      let hint = 'Open the URL and paste the JD below.';
      let statusCode: number | undefined;
      if (p?.kind === 'fail') {
        reason = p.message;
        if (p.hint) hint = p.hint;
        statusCode = p.statusCode;
      } else if (p?.kind === 'unavailable') {
        reason = 'Edge proxy is not reachable from this environment.';
        hint = `${p.message} Open the URL and paste the JD below.`;
      }
      return { id: item.id, status: 'error', reason, hint, source: item.source, board, statusCode };
    }

    const job = buildJobFromIntake(intake, item.kind === 'url' ? item.source : undefined);
    jobsStore.upsert(job);
    return { id: item.id, status: 'added', job, score: intake.score?.total, source: item.source, board };
  }

  // Track the most recent set of outcomes so per-row inline-fix can mutate it.
  let lastOutcomes: BulkOutcome[] = [];

  function shortenUrl(url: string, max = 70): string {
    try {
      const u = new URL(url);
      const tail = (u.pathname + (u.search || '')).slice(0, max - u.hostname.length - 3);
      return `${u.hostname}${tail}${(u.pathname + (u.search || '')).length > tail.length ? '…' : ''}`;
    } catch {
      return url.length > max ? url.slice(0, max - 1) + '…' : url;
    }
  }

  function renderBulkResults() {
    const outcomes = lastOutcomes;
    const added = outcomes.filter(o => o.status === 'added').length;
    const dup = outcomes.filter(o => o.status === 'duplicate').length;
    const err = outcomes.filter(o => o.status === 'error').length;
    const p1 = outcomes.filter(o => o.status === 'added' && (o as any).job.priority === 1).length;
    const p2 = outcomes.filter(o => o.status === 'added' && (o as any).job.priority === 2).length;

    const summary = `
      <div class="bulk-summary">
        <span><strong>${added}</strong><span class="label">added</span></span>
        <span><strong>${p1}</strong><span class="label">P1</span></span>
        <span><strong>${p2}</strong><span class="label">P2</span></span>
        <span><strong>${dup}</strong><span class="label">duplicates</span></span>
        <span><strong>${err}</strong><span class="label">need attention</span></span>
        <span style="margin-left:auto;"><a class="btn" href="/today">→ Open /today</a></span>
      </div>
    `;

    const rows = outcomes.map(o => {
      const board = escape(o.board ?? '—');
      const sourceUrl = o.source && /^https?:\/\//i.test(o.source) ? o.source : null;

      if (o.status === 'added') {
        const j = o.job;
        const co = escape(j.company ?? '');
        const role = escape(j.role ?? '');
        const score = j.fitScore != null ? Math.round(j.fitScore) : '—';
        const urlLine = sourceUrl
          ? `<a class="bulk-result__url" href="${escape(sourceUrl)}" target="_blank" rel="noopener noreferrer">${escape(shortenUrl(sourceUrl))}</a>`
          : '';
        const openSource = sourceUrl
          ? `<a class="bulk-result__action" href="${escape(sourceUrl)}" target="_blank" rel="noopener noreferrer">Open ↗</a>`
          : '';
        return `<div class="bulk-result" data-row-id="${escape(o.id)}">
          <span class="bulk-result__board">${board}</span>
          <div class="bulk-result__main">
            <span class="bulk-result__co">${co}</span>
            <span class="bulk-result__role">${role}</span>
            ${urlLine}
          </div>
          <span class="bulk-result__score">${score}</span>
          <span class="bulk-result__status bulk-result__status--added">added · P${j.priority ?? '–'}</span>
          <div class="bulk-result__actions">${openSource}</div>
        </div>`;
      }

      if (o.status === 'duplicate') {
        const j = o.matched;
        const urlLine = sourceUrl
          ? `<a class="bulk-result__url" href="${escape(sourceUrl)}" target="_blank" rel="noopener noreferrer">${escape(shortenUrl(sourceUrl))}</a>`
          : '';
        const openTracker = `<a class="bulk-result__action" href="/jobs">In tracker →</a>`;
        return `<div class="bulk-result bulk-result--dup" data-row-id="${escape(o.id)}">
          <span class="bulk-result__board">${board}</span>
          <div class="bulk-result__main">
            <span class="bulk-result__co">${escape(j.company ?? '')}</span>
            <span class="bulk-result__role">${escape(j.role ?? '')}</span>
            ${urlLine}
          </div>
          <span class="bulk-result__score">—</span>
          <span class="bulk-result__status bulk-result__status--dup">duplicate</span>
          <div class="bulk-result__actions">${openTracker}</div>
        </div>`;
      }

      // Error row — make it actionable.
      const urlLine = sourceUrl
        ? `<a class="bulk-result__url" href="${escape(sourceUrl)}" target="_blank" rel="noopener noreferrer" title="${escape(sourceUrl)}">${escape(shortenUrl(sourceUrl))}</a>`
        : `<span class="bulk-result__url">${escape((o.source ?? '').slice(0, 100))}${(o.source ?? '').length > 100 ? '…' : ''}</span>`;
      const reasonLine = `<span class="bulk-result__reason">${escape(o.reason ?? 'error')}</span>`;
      const hintLine = o.hint ? `<span class="bulk-result__hint">${escape(o.hint)}</span>` : '';
      const openBtn = sourceUrl
        ? `<a class="bulk-result__action" href="${escape(sourceUrl)}" target="_blank" rel="noopener noreferrer">Open ↗</a>`
        : '';
      const fixBtn = `<button class="bulk-result__action bulk-result__action--primary" data-action="fix" data-row-id="${escape(o.id)}">Add manually</button>`;
      const skipBtn = `<button class="bulk-result__action" data-action="skip" data-row-id="${escape(o.id)}">Skip</button>`;
      return `<div class="bulk-result bulk-result--err" data-row-id="${escape(o.id)}">
        <span class="bulk-result__board">${board}</span>
        <div class="bulk-result__main">
          ${urlLine}
          ${reasonLine}
          ${hintLine}
        </div>
        <span class="bulk-result__status bulk-result__status--err">needs review</span>
        <div class="bulk-result__actions">${openBtn}${fixBtn}${skipBtn}</div>
      </div>`;
    }).join('');

    const wrap = $('bulk-results');
    wrap.style.display = 'block';
    wrap.innerHTML = summary + rows;
    wireBulkResultActions(wrap);
  }

  function wireBulkResultActions(wrap: HTMLElement) {
    wrap.querySelectorAll<HTMLButtonElement>('button[data-action="fix"]').forEach(btn => {
      btn.addEventListener('click', () => openInlineFix(btn.dataset.rowId!));
    });
    wrap.querySelectorAll<HTMLButtonElement>('button[data-action="skip"]').forEach(btn => {
      btn.addEventListener('click', () => skipOutcome(btn.dataset.rowId!));
    });
  }

  function findOutcomeById(id: string): BulkOutcome | undefined {
    return lastOutcomes.find(o => o.id === id);
  }

  function skipOutcome(id: string) {
    lastOutcomes = lastOutcomes.filter(o => o.id !== id);
    renderBulkResults();
  }

  function openInlineFix(id: string) {
    const o = findOutcomeById(id);
    if (!o || o.status !== 'error') return;
    const row = document.querySelector<HTMLElement>(`[data-row-id="${CSS.escape(id)}"]`);
    if (!row) return;
    // If already open, close it.
    if (row.querySelector('.bulk-fix')) {
      row.querySelector('.bulk-fix')?.remove();
      return;
    }
    const sourceUrl = /^https?:\/\//i.test(o.source) ? o.source : '';
    const fix = document.createElement('div');
    fix.className = 'bulk-fix';
    fix.innerHTML = `
      <div class="row">
        <label>Company<input type="text" data-fix-field="company" placeholder="Acme" /></label>
        <label>Role<input type="text" data-fix-field="role" placeholder="Senior Product Designer" /></label>
      </div>
      <label>JD <span style="color:var(--c-text-subtle);">(optional · improves scoring)</span>
        <textarea data-fix-field="jd" placeholder="Paste the job description for accurate scoring…"></textarea>
      </label>
      <div class="actions">
        <button class="btn" data-fix-action="cancel">Cancel</button>
        <button class="btn btn--primary" data-fix-action="save">Save with these fields</button>
      </div>
    `;
    row.appendChild(fix);

    const coInput = fix.querySelector<HTMLInputElement>('[data-fix-field="company"]')!;
    const roleInput = fix.querySelector<HTMLInputElement>('[data-fix-field="role"]')!;
    const jdInput = fix.querySelector<HTMLTextAreaElement>('[data-fix-field="jd"]')!;
    coInput.focus();

    fix.querySelector<HTMLButtonElement>('[data-fix-action="cancel"]')!.addEventListener('click', () => {
      fix.remove();
    });
    fix.querySelector<HTMLButtonElement>('[data-fix-action="save"]')!.addEventListener('click', () => {
      const company = coInput.value.trim();
      const role = roleInput.value.trim();
      const jd = jdInput.value.trim();
      if (!company || !role) {
        coInput.style.borderColor = company ? '' : '#F87171';
        roleInput.style.borderColor = role ? '' : '#F87171';
        return;
      }
      // Re-run intake with the typed JD if present (so scoring works), then
      // overlay the manual company/role on top so they win.
      const intake = runIntake({
        urlText: sourceUrl || undefined,
        jdText: jd || undefined,
      });
      intake.draft.company = company;
      intake.draft.role = role;
      const job = buildJobFromIntake(intake, sourceUrl || undefined);
      jobsStore.upsert(job);

      // Replace the error row with a success row in lastOutcomes.
      const idx = lastOutcomes.findIndex(x => x.id === id);
      if (idx >= 0) {
        lastOutcomes[idx] = {
          id,
          status: 'added',
          job,
          score: intake.score?.total,
          source: o.source,
          board: o.board,
        };
      }
      renderBulkResults();
    });
  }

  $('bulk-analyze-btn').addEventListener('click', async () => {
    const items = parseBulkInputs();
    const status = $<HTMLElement>('bulk-status');
    if (items.length === 0) {
      status.style.display = 'block';
      status.textContent = 'Paste at least one URL or JD chunk.';
      return;
    }
    status.style.display = 'block';
    status.textContent = `Analyzing 0 / ${items.length}…`;

    lastOutcomes = [];
    for (let i = 0; i < items.length; i++) {
      const existing = jobsStore.list(); // re-read each iteration so duplicates within batch are caught
      const out = await processBulkItem(items[i], existing);
      lastOutcomes.push(out);
      const addedSoFar = lastOutcomes.filter(o => o.status === 'added').length;
      status.textContent = `Analyzing ${i + 1} / ${items.length} · ${addedSoFar} added so far…`;
      // Render incrementally so the user sees progress, not a frozen block.
      renderBulkResults();
      await new Promise(r => setTimeout(r, 0));
    }
    const addedFinal = lastOutcomes.filter(o => o.status === 'added').length;
    const errFinal = lastOutcomes.filter(o => o.status === 'error').length;
    status.textContent = `Done. ${addedFinal} added${errFinal ? ` · ${errFinal} need attention` : ''}.`;
  });

  $('bulk-clear-btn').addEventListener('click', () => {
    ($<HTMLTextAreaElement>('bulk-urls')).value = '';
    ($<HTMLTextAreaElement>('bulk-jds')).value = '';
    $('bulk-status').style.display = 'none';
    $('bulk-results').style.display = 'none';
    $('bulk-results').innerHTML = '';
    lastOutcomes = [];
  });
</script>
