---
import Admin from '@/layouts/Admin.astro';
---

<Admin title="Today">
  <div class="today">
    <header class="today__bar" id="today-bar">
      <div class="today__count">
        <strong id="today-applied">0</strong>
        <span class="today__count-label">applied today</span>
      </div>
      <div class="today__queue-stat">
        <strong id="today-queue-count">0</strong>
        <span class="today__count-label">in queue</span>
      </div>
      <div class="today__hints" aria-label="keyboard shortcuts">
        <kbd>j</kbd><kbd>k</kbd> navigate
        <span class="today__hint-sep">·</span>
        <kbd>r</kbd> resume PDF
        <span class="today__hint-sep">·</span>
        <kbd>l</kbd> letter PDF
        <span class="today__hint-sep">·</span>
        <kbd>b</kbd> both PDFs
        <span class="today__hint-sep">·</span>
        <kbd>space</kbd> open
        <span class="today__hint-sep">·</span>
        <kbd>a</kbd> apply
        <span class="today__hint-sep">·</span>
        <kbd>e</kbd> edit
        <span class="today__hint-sep">·</span>
        <kbd>d</kbd> defer
      </div>
    </header>

    <div class="today__split">
      <ol class="today__queue" id="today-queue" aria-label="application queue"></ol>
      <aside class="today__detail" id="today-detail" aria-live="polite">
        <p class="today__empty">Select a job. Press <kbd>j</kbd>/<kbd>k</kbd> to navigate.</p>
      </aside>
    </div>

    <div class="today__toast" id="today-toast" aria-live="polite"></div>
  </div>
</Admin>

<style>
  .today {
    display: flex;
    flex-direction: column;
    gap: 12px;
    /* fill the viewport minus the admin chrome */
    height: calc(100vh - 180px);
    min-height: 480px;
  }

  .today__bar {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 10px 14px;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    background: var(--c-bg-elev);
    flex-wrap: wrap;
  }
  .today__count, .today__queue-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }
  .today__count strong, .today__queue-stat strong {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1;
    color: var(--c-text);
  }
  .today__count-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-subtle);
  }
  .today__hints {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--c-text-subtle);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .today__hint-sep { opacity: 0.5; }
  .today__bar kbd, .today__detail kbd, .today__empty kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 1px 5px;
    border-radius: 3px;
    border: 1px solid var(--c-border);
    background: var(--c-bg-muted);
    color: var(--c-text);
    line-height: 1.4;
  }

  .today__split {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 12px;
    flex: 1 1 auto;
    min-height: 0;
  }
  @media (max-width: 900px) {
    .today__split { grid-template-columns: 1fr; height: auto; }
    .today { height: auto; }
  }

  .today__queue {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    background: var(--c-bg-elev);
  }
  .today__queue:empty::after {
    content: 'No saved jobs in the queue. Add some via /jobs/new.';
    display: block;
    padding: 24px;
    color: var(--c-text-subtle);
    font-size: 13px;
  }
  .today__queue :global(li.today__row) {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr) auto auto;
    gap: 10px;
    align-items: center;
    padding: 9px 12px;
    border-bottom: 1px solid var(--c-border-subtle);
    cursor: pointer;
    user-select: none;
  }
  .today__queue :global(li.today__row:last-child) { border-bottom: none; }
  .today__queue :global(li.today__row:hover) { background: var(--c-bg-muted); }
  .today__queue :global(li.today__row.is-selected) {
    background: var(--c-accent-dim);
    border-left: 2px solid var(--c-accent);
    padding-left: 10px;
  }
  .today__queue :global(li.today__row.is-deferred) { opacity: 0.45; }

  .today__queue :global(.today__rank) {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--c-text-subtle);
    text-align: right;
  }
  .today__queue :global(.today__row-main) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .today__queue :global(.today__row-co) {
    font-size: 14px;
    color: var(--c-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .today__queue :global(.today__row-role) {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--c-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .today__queue :global(.today__pill) {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 6px;
    border-radius: var(--r-full);
    background: var(--c-bg-muted);
    border: 1px solid var(--c-border-subtle);
    color: var(--c-text-muted);
    white-space: nowrap;
  }
  .today__queue :global(.today__pill--p1) { color: var(--c-accent); border-color: var(--c-accent); }
  .today__queue :global(.today__score) {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--c-text);
    line-height: 1;
    min-width: 28px;
    text-align: right;
  }

  .today__detail {
    overflow-y: auto;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    background: var(--c-bg-elev);
    padding: 18px;
    display: flex;
    flex-direction: column;
  }
  .today__empty {
    color: var(--c-text-subtle);
    font-size: 13px;
    margin: auto;
    text-align: center;
  }

  .today__detail :global(.detail__head) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--c-border-subtle);
    margin-bottom: 14px;
  }
  .today__detail :global(.detail__co) {
    font-family: var(--font-display);
    font-size: 22px;
    line-height: 1.15;
    color: var(--c-text);
  }
  .today__detail :global(.detail__role) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--c-text-muted);
    margin-top: 4px;
  }
  .today__detail :global(.detail__score-block) {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
    text-align: right;
  }
  .today__detail :global(.detail__score) {
    font-family: var(--font-display);
    font-size: 36px;
    line-height: 1;
    color: var(--c-text);
  }
  .today__detail :global(.detail__score-meta) {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-subtle);
  }

  .today__detail :global(.detail__angle) {
    font-size: 12px;
    color: var(--c-text-muted);
    margin-bottom: 14px;
  }
  .today__detail :global(.detail__angle strong) { color: var(--c-text); font-weight: 500; }
  .today__detail :global(.detail__angle a) { color: var(--c-accent); text-decoration: underline; text-decoration-color: var(--c-border); text-underline-offset: 2px; }
  .today__detail :global(.detail__angle a:hover) { text-decoration-color: var(--c-accent); }

  .today__detail :global(.detail__facts) {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 8px 14px;
    padding: 10px 12px;
    margin-bottom: 14px;
    background: var(--c-bg);
    border: 1px solid var(--c-border-subtle);
    border-radius: var(--r-md);
    font-size: 12px;
  }
  .today__detail :global(.detail__fact) { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .today__detail :global(.detail__fact-label) {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-subtle);
  }
  .today__detail :global(.detail__fact-value) {
    color: var(--c-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .today__detail :global(.detail__fact-value a) { color: var(--c-accent); text-decoration: none; }
  .today__detail :global(.detail__fact-value a:hover) { text-decoration: underline; }

  .today__detail :global(.detail__actions) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 14px;
  }
  .today__detail :global(.detail__action) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 12px;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    background: var(--c-bg-muted);
    color: var(--c-text);
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    text-decoration: none;
  }
  .today__detail :global(.detail__action:hover) { border-color: var(--c-accent); color: var(--c-accent); }
  .today__detail :global(.detail__action[disabled]) { opacity: 0.5; cursor: not-allowed; }
  .today__detail :global(.detail__action--primary) {
    background: var(--c-accent);
    color: var(--c-bg);
    border-color: var(--c-accent);
    grid-column: 1 / -1;
    justify-content: center;
    font-weight: 500;
  }
  .today__detail :global(.detail__action--wide) { grid-column: 1 / -1; }
  .today__detail :global(.detail__action--primary:hover) { color: var(--c-bg); filter: brightness(1.1); }
  .today__detail :global(.detail__action kbd) {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 1px 5px;
    border-radius: 3px;
    border: 1px solid var(--c-border-subtle);
    background: rgba(0,0,0,0.25);
    color: inherit;
    opacity: 0.7;
  }
  .today__detail :global(.detail__action--primary kbd) { background: rgba(0,0,0,0.3); border-color: rgba(0,0,0,0.4); color: var(--c-bg); }
  .today__detail :global(.detail__action .hint) { color: var(--c-text-subtle); font-size: 11px; }

  .today__detail :global(.detail__section-h) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-text-subtle);
    margin: 16px 0 8px;
  }

  /* Status transitions row */
  .today__detail :global(.detail__transitions) {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 8px;
  }
  .today__detail :global(.detail__transition) {
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 5px 10px;
    border: 1px solid var(--c-border);
    border-radius: var(--r-full);
    background: var(--c-bg);
    color: var(--c-text-muted);
    cursor: pointer;
    line-height: 1;
  }
  .today__detail :global(.detail__transition:hover) { border-color: var(--c-accent); color: var(--c-accent); }
  .today__detail :global(.detail__transition--danger:hover) { border-color: #F87171; color: #F87171; }

  /* Inline edit form for company/role */
  .today__detail :global(.detail__edit) {
    display: grid;
    gap: 8px;
    padding: 12px;
    margin-bottom: 14px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
  }
  .today__detail :global(.detail__edit .row) { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .today__detail :global(.detail__edit label) { display: flex; flex-direction: column; gap: 4px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--c-text-subtle); }
  .today__detail :global(.detail__edit input) { font-family: inherit; font-size: 13px; padding: 7px 10px; border: 1px solid var(--c-border); border-radius: 6px; background: var(--c-bg-elev); color: var(--c-text); }
  .today__detail :global(.detail__edit input:focus) { outline: none; border-color: var(--c-accent); }
  .today__detail :global(.detail__edit-actions) { display: flex; gap: 8px; justify-content: flex-end; }

  .today__detail :global(.detail__jd) {
    margin-top: 4px;
    padding: 10px 12px;
    background: var(--c-bg);
    border: 1px solid var(--c-border-subtle);
    border-radius: var(--r-md);
    font-size: 11.5px;
    line-height: 1.55;
    color: var(--c-text-muted);
    max-height: 220px;
    overflow: auto;
    white-space: pre-wrap;
    font-family: var(--font-mono);
  }
  .today__detail :global(.detail__jd-toggle) { cursor: pointer; color: var(--c-text-muted); font-size: 12px; }
  .today__detail :global(.detail__jd-toggle:hover) { color: var(--c-accent); }

  .today__toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translate(-50%, 12px);
    background: var(--c-text);
    color: var(--c-bg);
    padding: 9px 14px;
    border-radius: var(--r-md);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.02em;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 1000;
  }
  .today__toast.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  /* Hide intro chrome on this page if present */
  :global(main:has(.today)) :global(header.admin__page-head) { display: none; }
</style>

<script>
  import { jobsStore, type Job, type JobStatus } from '@/lib/storage';
  import { angleById } from '@/data/angles';
  import { openForPrint, openBothForPrint } from '@/lib/pdf-download';

  // ── State ────────────────────────────────────────────────────────────
  type State = {
    queue: Job[];
    selectedIdx: number;
  };

  const state: State = {
    queue: [],
    selectedIdx: -1,
  };

  // Defer state lives on the Job itself (job.deferredAt) so it persists
  // across refreshes and syncs across devices through the standard sync
  // pipeline. This helper is just a sugar read so the rest of the code
  // doesn't repeat the boolean check everywhere.
  const isDeferred = (job: Job): boolean => job.deferredAt != null;

  // ── DOM ──────────────────────────────────────────────────────────────
  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
  const queueEl = $('today-queue');
  const detailEl = $('today-detail');
  const toastEl = $('today-toast');
  const appliedEl = $<HTMLElement>('today-applied');
  const queueCountEl = $<HTMLElement>('today-queue-count');

  // ── Sorting ──────────────────────────────────────────────────────────
  // Priority asc (1 = highest), then fitScore desc, then updatedAt desc.
  function sortQueue(jobs: Job[]): Job[] {
    return jobs.slice().sort((a, b) => {
      const pa = a.priority ?? 9, pb = b.priority ?? 9;
      if (pa !== pb) return pa - pb;
      const sa = a.fitScore ?? 0, sb = b.fitScore ?? 0;
      if (sa !== sb) return sb - sa;
      return (b.updatedAt ?? 0) - (a.updatedAt ?? 0);
    });
  }

  function loadQueue() {
    const all = jobsStore.list();
    const saved = all.filter(j => j.status === 'Saved');
    const sorted = sortQueue(saved);
    // Deferred jobs go to the bottom but stay visible (subtle)
    const undef = sorted.filter(j => !isDeferred(j));
    const def = sorted.filter(j => isDeferred(j));
    state.queue = [...undef, ...def];
    if (state.queue.length === 0) state.selectedIdx = -1;
    else if (state.selectedIdx < 0 || state.selectedIdx >= state.queue.length) state.selectedIdx = 0;
  }

  function appliedToday(): number {
    const start = new Date();
    start.setHours(0, 0, 0, 0);
    const startMs = start.getTime();
    return jobsStore.list().filter(j =>
      j.status === 'Applied' && j.dateApplied != null && j.dateApplied >= startMs
    ).length;
  }

  // ── Render ───────────────────────────────────────────────────────────
  function renderHeader() {
    appliedEl.textContent = String(appliedToday());
    queueCountEl.textContent = String(state.queue.length);
  }

  function escape(s: string): string {
    return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  function renderQueue() {
    if (state.queue.length === 0) {
      queueEl.innerHTML = '';
      return;
    }
    queueEl.innerHTML = state.queue.map((j, i) => {
      const sel = i === state.selectedIdx ? 'is-selected' : '';
      const def = isDeferred(j) ? 'is-deferred' : '';
      const score = j.fitScore != null ? Math.round(j.fitScore) : '—';
      const pri = j.priority ? `<span class="today__pill ${j.priority === 1 ? 'today__pill--p1' : ''}">P${j.priority}</span>` : '';
      const role = j.role ?? '';
      const co = j.company ?? '(no company)';
      return `
        <li class="today__row ${sel} ${def}" data-idx="${i}">
          <span class="today__rank">${i + 1}</span>
          <div class="today__row-main">
            <span class="today__row-co">${escape(co)}</span>
            <span class="today__row-role">${escape(role)}</span>
          </div>
          ${pri}
          <span class="today__score">${score}</span>
        </li>
      `;
    }).join('');
    // Click to select
    queueEl.querySelectorAll<HTMLElement>('.today__row').forEach(row => {
      row.addEventListener('click', () => {
        const idx = Number(row.dataset.idx);
        select(idx);
      });
    });
    // Scroll selected into view
    const sel = queueEl.querySelector<HTMLElement>('.today__row.is-selected');
    if (sel) sel.scrollIntoView({ block: 'nearest' });
  }

  // Track which jobs the user has expanded the JD on or is currently editing.
  const expandedJDIds = new Set<string>();
  const editingIds = new Set<string>();

  function formatSalary(min?: number, max?: number): string | undefined {
    const fmt = (n: number) => n >= 1000 ? `$${Math.round(n / 1000)}k` : `$${n}`;
    if (min && max && min !== max) return `${fmt(min)}–${fmt(max)}`;
    if (min) return fmt(min);
    if (max) return fmt(max);
    return undefined;
  }

  function shortHost(url: string): string {
    try { return new URL(url).hostname.replace(/^www\./, ''); }
    catch { return url; }
  }

  function renderDetail() {
    if (state.selectedIdx < 0 || !state.queue[state.selectedIdx]) {
      detailEl.innerHTML = `<p class="today__empty">No job selected.</p>`;
      return;
    }
    const job = state.queue[state.selectedIdx];
    const angleId = job.resumeAngle ?? 'product-designer';
    const angle = angleById(angleId);
    const angleLabel = angle?.label ?? angleId;

    const co = escape(job.company ?? '(no company)');
    const role = escape(job.role ?? '');
    const score = job.fitScore != null ? Math.round(job.fitScore) : 'n/a';
    const conf = job.priority === 1 ? 'high confidence' : job.priority === 2 ? 'medium' : 'low';
    const url = job.url ?? '';
    const pri = job.priority ? `P${job.priority}` : 'no priority';

    // ── Facts row ────────────────────────────────────────────────────
    const salary = formatSalary(job.salaryMin, job.salaryMax);
    const facts: string[] = [];
    if (job.location) facts.push(factCell('Location', escape(job.location)));
    if (salary) facts.push(factCell('Salary', escape(salary)));
    if (job.source) facts.push(factCell('Source', escape(job.source)));
    if (url) facts.push(factCell('Link', `<a href="${escape(url)}" target="_blank" rel="noopener noreferrer">${escape(shortHost(url))} ↗</a>`));
    if (job.dateFound) {
      const days = Math.floor((Date.now() - job.dateFound) / 86_400_000);
      facts.push(factCell('Found', days === 0 ? 'today' : days === 1 ? 'yesterday' : `${days}d ago`));
    }
    const factsHtml = facts.length
      ? `<div class="detail__facts">${facts.join('')}</div>`
      : '';

    // ── Inline edit form (toggled by 'e' / button) ─────────────────
    const isEditing = editingIds.has(job.id);
    const editHtml = isEditing
      ? `<div class="detail__edit">
          <div class="row">
            <label>Company<input data-edit="company" value="${escape(job.company ?? '')}" /></label>
            <label>Role<input data-edit="role" value="${escape(job.role ?? '')}" /></label>
          </div>
          <div class="row">
            <label>Location<input data-edit="location" value="${escape(job.location ?? '')}" /></label>
            <label>URL<input data-edit="url" type="url" value="${escape(job.url ?? '')}" /></label>
          </div>
          <div class="detail__edit-actions">
            <button class="detail__transition" data-act="edit-cancel" type="button">Cancel</button>
            <button class="detail__transition" data-act="edit-save" type="button" style="background:var(--c-accent); color:var(--c-bg); border-color:var(--c-accent);">Save</button>
          </div>
        </div>`
      : '';

    // ── Action buttons ──────────────────────────────────────────────
    const urlBtn = url
      ? `<button class="detail__action" data-act="open" type="button"><span>Open posting <span class="hint">↗</span></span><kbd>space</kbd></button>`
      : `<button class="detail__action" type="button" disabled><span>Open posting <span class="hint">no URL</span></span></button>`;

    const editBtn = isEditing
      ? ''
      : `<button class="detail__action" data-act="edit" type="button"><span>Edit details</span><kbd>e</kbd></button>`;

    // ── JD excerpt ──────────────────────────────────────────────────
    const jdHtml = renderJDExcerpt(job);

    detailEl.innerHTML = `
      <div class="detail__head">
        <div>
          <div class="detail__co">${co}</div>
          <div class="detail__role">${role}</div>
        </div>
        <div class="detail__score-block">
          <span class="detail__score">${score}</span>
          <span class="detail__score-meta">${escape(pri)}<br>${escape(conf)}</span>
        </div>
      </div>

      ${factsHtml}

      <p class="detail__angle">Resume angle: <a href="/resume/${escape(angleId)}" target="_blank" rel="noopener"><strong>${escape(angleLabel)}</strong> ↗</a></p>

      ${editHtml}

      <div class="detail__actions">
        <button class="detail__action" data-act="resume-pdf" type="button"><span>Resume PDF <span class="hint">↓</span></span><kbd>r</kbd></button>
        <button class="detail__action" data-act="letter-pdf" type="button"><span>Cover letter PDF <span class="hint">↓</span></span><kbd>l</kbd></button>
        <button class="detail__action detail__action--wide" data-act="both-pdf" type="button"><span>Download both PDFs <span class="hint">↓↓</span></span><kbd>b</kbd></button>
        ${urlBtn}
        ${editBtn}
        <button class="detail__action" data-act="defer" type="button"><span>${isDeferred(job) ? 'Undefer' : 'Defer'}</span><kbd>d</kbd></button>
        <button class="detail__action detail__action--primary" data-act="apply" type="button"><span>Mark applied</span><kbd>a</kbd></button>
      </div>

      <h3 class="detail__section-h">Move to status</h3>
      <div class="detail__transitions">
        <button class="detail__transition" data-status="Applying" type="button">Applying</button>
        <button class="detail__transition" data-status="Recruiter Screen" type="button">Recruiter screen</button>
        <button class="detail__transition" data-status="Hiring Manager" type="button">Hiring manager</button>
        <button class="detail__transition" data-status="Interview Loop" type="button">Interview loop</button>
        <button class="detail__transition" data-status="Take-home" type="button">Take-home</button>
        <button class="detail__transition detail__transition--danger" data-status="Rejected" type="button">Rejected</button>
        <button class="detail__transition detail__transition--danger" data-status="Archived" type="button">Archive</button>
      </div>

      ${jdHtml}
    `;

    // Wire up dynamic actions
    detailEl.querySelectorAll<HTMLButtonElement>('[data-act]').forEach(btn => {
      btn.addEventListener('click', () => {
        const act = btn.dataset.act!;
        runAction(act);
      });
    });
    detailEl.querySelectorAll<HTMLButtonElement>('[data-status]').forEach(btn => {
      btn.addEventListener('click', () => {
        const status = btn.dataset.status as JobStatus;
        moveToStatus(status);
      });
    });
    const jdToggle = detailEl.querySelector<HTMLElement>('.detail__jd-toggle');
    if (jdToggle) {
      jdToggle.addEventListener('click', () => {
        if (expandedJDIds.has(job.id)) expandedJDIds.delete(job.id);
        else expandedJDIds.add(job.id);
        renderDetail();
      });
    }
  }

  function factCell(label: string, value: string): string {
    return `<div class="detail__fact"><span class="detail__fact-label">${escape(label)}</span><span class="detail__fact-value" title="${value.replace(/"/g, '&quot;')}">${value}</span></div>`;
  }

  function renderJDExcerpt(job: Job): string {
    if (!job.jdText) return '';
    const expanded = expandedJDIds.has(job.id);
    const text = job.jdText.trim();
    const preview = text.length > 320 ? text.slice(0, 320).trim() + '…' : text;
    if (expanded) {
      return `<h3 class="detail__section-h">Job description <span class="detail__jd-toggle" style="float:right; font-weight:normal; text-transform:none; letter-spacing:0;">collapse</span></h3>
        <pre class="detail__jd">${escape(text.slice(0, 6000))}</pre>`;
    }
    return `<h3 class="detail__section-h">Job description <span class="detail__jd-toggle" style="float:right; font-weight:normal; text-transform:none; letter-spacing:0;">expand</span></h3>
      <p style="font-size:12px; color:var(--c-text-muted); line-height:1.55; margin:0;">${escape(preview)}</p>`;
  }

  // ── Actions ──────────────────────────────────────────────────────────
  function select(idx: number) {
    if (idx < 0 || idx >= state.queue.length) return;
    state.selectedIdx = idx;
    renderQueue();
    renderDetail();
  }

  function move(delta: number) {
    if (state.queue.length === 0) return;
    let next = state.selectedIdx + delta;
    if (next < 0) next = 0;
    if (next >= state.queue.length) next = state.queue.length - 1;
    select(next);
  }

  // Build a sensible PDF filename for a job. Browsers append .pdf
  // automatically when the user picks "Save as PDF" in the print dialog
  // (the filename here becomes the dialog default), so don't include the
  // extension.
  function fileSlug(s: string): string {
    return s.replace(/[^a-zA-Z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 60);
  }
  function resumeFilename(job: Job): string {
    const co = fileSlug(job.company || 'job');
    return `Moe-Qadan-Resume-${co}`;
  }
  function letterFilename(job: Job): string {
    const co = fileSlug(job.company || 'job');
    return `Moe-Qadan-Cover-Letter-${co}`;
  }

  function downloadResumePdf() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    const angleId = job.resumeAngle ?? 'product-designer';
    try {
      openForPrint({
        url: `/resume/${encodeURIComponent(angleId)}`,
        filename: resumeFilename(job),
      });
      toast('Resume opened — Save in the print dialog.');
    } catch (e) {
      toast(e instanceof Error ? e.message : 'Open failed.');
    }
  }

  function downloadLetterPdf() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    try {
      openForPrint({
        url: `/letter/?id=${encodeURIComponent(job.id)}`,
        filename: letterFilename(job),
      });
      toast('Cover letter opened — Save in the print dialog.');
    } catch (e) {
      toast(e instanceof Error ? e.message : 'Open failed.');
    }
  }

  function downloadBothPdfs() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    const angleId = job.resumeAngle ?? 'product-designer';
    try {
      openBothForPrint([
        { url: `/resume/${encodeURIComponent(angleId)}`, filename: resumeFilename(job) },
        { url: `/letter/?id=${encodeURIComponent(job.id)}`, filename: letterFilename(job) },
      ]);
      toast('Two tabs opened — Save in each print dialog.');
    } catch (e) {
      toast(e instanceof Error ? e.message : 'Open failed.');
    }
  }

  function openJob() {
    const job = state.queue[state.selectedIdx];
    if (!job?.url) { toast('No URL on this job.'); return; }
    window.open(job.url, '_blank', 'noopener');
  }

  function markApplied() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    moveToStatus('Applied' as JobStatus);
  }

  function moveToStatus(status: JobStatus) {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    const updated: Job = {
      ...job,
      status,
      ...(status === 'Applied' ? { dateApplied: Date.now() } : {}),
      updatedAt: Date.now(),
    };
    jobsStore.upsert(updated);
    const prevIdx = state.selectedIdx;
    loadQueue();
    state.selectedIdx = Math.min(prevIdx, state.queue.length - 1);
    renderHeader();
    renderQueue();
    renderDetail();
    toast(`Moved to ${status}: ${job.company ?? job.role ?? 'job'}`);
  }

  function toggleDefer() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    const updated: Job = {
      ...job,
      deferredAt: isDeferred(job) ? undefined : Date.now(),
      updatedAt: Date.now(),
    };
    jobsStore.upsert(updated);
    const prevIdx = state.selectedIdx;
    loadQueue();
    state.selectedIdx = Math.min(prevIdx, state.queue.length - 1);
    renderQueue();
    renderDetail();
  }

  function startEdit() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    editingIds.add(job.id);
    renderDetail();
    // Focus the company input
    requestAnimationFrame(() => {
      const input = detailEl.querySelector<HTMLInputElement>('input[data-edit="company"]');
      input?.focus();
      input?.select();
    });
  }

  function cancelEdit() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    editingIds.delete(job.id);
    renderDetail();
  }

  function saveEdit() {
    const job = state.queue[state.selectedIdx];
    if (!job) return;
    const get = (field: string): string =>
      (detailEl.querySelector<HTMLInputElement>(`input[data-edit="${field}"]`)?.value ?? '').trim();
    const updated: Job = {
      ...job,
      company: get('company') || job.company,
      role: get('role') || job.role,
      location: get('location') || undefined,
      url: get('url') || undefined,
      updatedAt: Date.now(),
    };
    jobsStore.upsert(updated);
    editingIds.delete(job.id);
    loadQueue();
    renderQueue();
    renderDetail();
    toast('Saved');
  }

  function runAction(act: string) {
    switch (act) {
      case 'resume-pdf': void downloadResumePdf(); break;
      case 'letter-pdf': void downloadLetterPdf(); break;
      case 'both-pdf': void downloadBothPdfs(); break;
      case 'open': openJob(); break;
      case 'apply': markApplied(); break;
      case 'defer': toggleDefer(); break;
      case 'edit': startEdit(); break;
      case 'edit-cancel': cancelEdit(); break;
      case 'edit-save': saveEdit(); break;
    }
  }

  // ── Toast ────────────────────────────────────────────────────────────
  let toastTimeout: number | null = null;
  function toast(msg: string) {
    toastEl.textContent = msg;
    toastEl.classList.add('is-visible');
    if (toastTimeout) window.clearTimeout(toastTimeout);
    toastTimeout = window.setTimeout(() => {
      toastEl.classList.remove('is-visible');
    }, 1500);
  }

  // ── Keyboard ─────────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    // Ignore when typing in inputs/textareas (shouldn't happen on this page,
    // but be safe in case future fields get added).
    const tgt = e.target as HTMLElement;
    if (tgt && (tgt.tagName === 'INPUT' || tgt.tagName === 'TEXTAREA' || tgt.isContentEditable)) return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;

    switch (e.key) {
      case 'j':
      case 'ArrowDown':
        e.preventDefault(); move(1); break;
      case 'k':
      case 'ArrowUp':
        e.preventDefault(); move(-1); break;
      case ' ':
        e.preventDefault(); openJob(); break;
      case 'r':
        e.preventDefault(); void downloadResumePdf(); break;
      case 'l':
        e.preventDefault(); void downloadLetterPdf(); break;
      case 'b':
        e.preventDefault(); void downloadBothPdfs(); break;
      case 'a':
        e.preventDefault(); markApplied(); break;
      case 'd':
        e.preventDefault(); toggleDefer(); break;
      case 'e':
        e.preventDefault(); startEdit(); break;
    }
  });

  // ── Init ─────────────────────────────────────────────────────────────
  loadQueue();
  if (state.queue.length > 0) state.selectedIdx = 0;
  renderHeader();
  renderQueue();
  renderDetail();
</script>
