---
import '@/styles/global.css';
import { angles } from '@/data/angles';

interface Props {
  title?: string;
  intro?: string;
  activePath?: string;
}
const { title, intro, activePath = Astro.url.pathname } = Astro.props;

function isActive(href: string) {
  if (href === '/') return activePath === '/';
  return activePath === href || activePath.startsWith(href + '/');
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title ? `${title} · Qadan Admin` : 'Qadan Admin'}</title>
</head>
<body>
  <div class="admin">
    <aside class="admin__sidebar no-print" data-sidebar>
      <div class="admin__brand-row">
        <a href="/" class="admin__brand">Qadan<span>.</span> admin</a>
        <button type="button" class="admin__menu-toggle" data-menu-toggle aria-expanded="false" aria-controls="admin-nav" aria-label="Open menu">
          <span aria-hidden="true">☰</span>
          <span class="admin__menu-label">Menu</span>
        </button>
      </div>
      <nav id="admin-nav" class="admin__nav" aria-label="Admin navigation" data-nav>
        <a href="/" class:list={{ 'is-active': isActive('/') }}>Dashboard</a>
        <a href="/today" class:list={['admin__nav-primary', { 'is-active': isActive('/today') }]}>→ Today</a>

        <h4>Workflow</h4>
        <a href="/discovery" class:list={{ 'is-active': isActive('/discovery') }}>⌕ Discovery</a>
        <a href="/jobs/new" class:list={{ 'is-active': activePath === '/jobs/new' }}>+ Add job (smart intake)</a>
        <a href="/jobs" class:list={{ 'is-active': activePath === '/jobs' || activePath.startsWith('/jobs?') }}>Job tracker</a>
        <a href="/analyzer" class:list={{ 'is-active': isActive('/analyzer') }}>JD analyzer</a>
        <a href="/letters" class:list={{ 'is-active': isActive('/letters') }}>Letters &amp; messages</a>
        <a href="/outreach" class:list={{ 'is-active': isActive('/outreach') }}>Outreach emails</a>
        <a href="/recruiters" class:list={{ 'is-active': isActive('/recruiters') }}>Recruiter CRM</a>
        <a href="/interview" class:list={{ 'is-active': isActive('/interview') }}>Interview prep</a>
        <a href="/export" class:list={{ 'is-active': isActive('/export') }}>Export &amp; backup</a>

        <details class="admin__angles" open>
          <summary><h4>Resume by angle</h4></summary>
          {angles.map(a => (
            <a href={`/resume/${a.id}`} class:list={{ 'is-active': isActive(`/resume/${a.id}`) }}>
              {a.shortLabel}
            </a>
          ))}
        </details>

        <details class="admin__angles" open>
          <summary><h4>Recruiter pack by angle</h4></summary>
          {angles.map(a => (
            <a href={`/recruiter/${a.id}`} class:list={{ 'is-active': isActive(`/recruiter/${a.id}`) }}>
              {a.shortLabel}
            </a>
          ))}
        </details>
      </nav>

      <div class="admin__sync no-print" id="admin-sync" hidden>
        <div class="admin__sync-row">
          <span class="admin__sync-dot" data-sync-dot></span>
          <span class="admin__sync-label" data-sync-label>Sync</span>
          <button type="button" class="admin__sync-btn" data-sync-action="pull" title="Force re-sync now">↻</button>
        </div>
        <details class="admin__sync-help" id="admin-sync-help" hidden>
          <summary>How to fix</summary>
          <p data-sync-help-msg></p>
          <ol class="admin__sync-steps">
            <li>Open the <a href="https://dash.cloudflare.com" target="_blank" rel="noopener">Cloudflare dashboard</a> → <em>Workers &amp; Pages → KV → Create namespace</em>. Name it anything (e.g. <code>qadan-admin-data</code>).</li>
            <li>Go to your Pages project (<code>qadan-admin</code> or similar) → <em>Settings → Functions → KV namespace bindings → Add binding</em>.</li>
            <li>Set <strong>Variable name</strong> to <code>KV</code> (exact, case-sensitive) and pick the namespace from step 1.</li>
            <li>Save, then redeploy the project (or push a new commit to trigger a deploy).</li>
            <li>Hard-refresh this page. Status should turn green.</li>
          </ol>
          <p class="admin__sync-help-note">Cross-device sync needs the KV binding on every device's deploy — the binding is server-side, not per-browser.</p>
        </details>
      </div>
    </aside>

    <script is:inline>
      // Mobile menu: collapsed by default at <=800px, click Menu to open,
      // click any link or the toggle to close. Desktop ignores this entirely.
      (() => {
        const toggle = document.querySelector('[data-menu-toggle]');
        const nav = document.querySelector('[data-nav]');
        const sidebar = document.querySelector('[data-sidebar]');
        if (!toggle || !nav || !sidebar) return;

        const isMobile = () => window.matchMedia('(max-width: 800px)').matches;

        function close() {
          sidebar.classList.remove('admin__sidebar--open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open menu');
        }
        function open() {
          sidebar.classList.add('admin__sidebar--open');
          toggle.setAttribute('aria-expanded', 'true');
          toggle.setAttribute('aria-label', 'Close menu');
        }

        toggle.addEventListener('click', () => {
          if (sidebar.classList.contains('admin__sidebar--open')) close(); else open();
        });

        nav.querySelectorAll('a').forEach((a) => {
          a.addEventListener('click', () => { if (isMobile()) close(); });
        });

        // Reset state on resize past breakpoint so going from mobile → desktop doesn't leave the menu visually stuck.
        const mq = window.matchMedia('(max-width: 800px)');
        const onChange = () => { if (!mq.matches) close(); };
        if (typeof mq.addEventListener === 'function') mq.addEventListener('change', onChange);
        else mq.addListener(onChange);
      })();
    </script>
    <main class="admin__main">
      {(title || intro) && (
        <header class="admin__head no-print">
          {title && <h1>{title}</h1>}
          {intro && <p>{intro}</p>}
        </header>
      )}
      <slot />
    </main>
  </div>

  <script>
    // Boot the cross-device sync layer. Pulls from /api/sync on load,
    // pushes on every local write (debounced), polls every 60s while the
    // tab is visible. The status indicator in the sidebar reflects state.
    import sync, { type SyncStatusEvent } from '@/lib/sync';

    const wrap = document.getElementById('admin-sync');
    const dot = wrap?.querySelector<HTMLElement>('[data-sync-dot]');
    const label = wrap?.querySelector<HTMLElement>('[data-sync-label]');
    const btn = wrap?.querySelector<HTMLButtonElement>('[data-sync-action="pull"]');
    const help = document.getElementById('admin-sync-help') as HTMLDetailsElement | null;
    const helpMsg = help?.querySelector<HTMLElement>('[data-sync-help-msg]') ?? null;

    function fmtRelative(ms: number): string {
      if (!ms) return 'never';
      const dt = Date.now() - ms;
      if (dt < 5_000) return 'just now';
      if (dt < 60_000) return `${Math.round(dt / 1000)}s ago`;
      if (dt < 3_600_000) return `${Math.round(dt / 60_000)}m ago`;
      if (dt < 86_400_000) return `${Math.round(dt / 3_600_000)}h ago`;
      return `${Math.round(dt / 86_400_000)}d ago`;
    }

    function render(e: SyncStatusEvent) {
      if (!wrap || !dot || !label) return;
      wrap.hidden = false;
      dot.dataset.state = e.status;
      const last = e.lastSyncedAt ?? sync.lastSyncedAt();
      switch (e.status) {
        case 'idle': label.textContent = 'Sync ready'; break;
        case 'pulling': label.textContent = 'Pulling…'; break;
        case 'pushing': label.textContent = 'Pushing…'; break;
        case 'synced':
          label.textContent = `Synced ${fmtRelative(last)}`;
          break;
        case 'offline':
          label.textContent = `Offline · ${fmtRelative(last)}`;
          break;
        case 'unconfigured':
          label.textContent = 'Sync not set up';
          break;
        case 'error':
          label.textContent = `Sync error · ${fmtRelative(last)}`;
          break;
      }
      if (e.message) wrap.title = e.message;
      else wrap.title = '';

      // Reveal the inline setup steps when the cloud function reports the
      // KV binding is missing or any other configuration error. The user
      // sees the fix without hovering the dot for a tooltip.
      if (help) {
        const showHelp = e.status === 'unconfigured' || e.status === 'error';
        help.hidden = !showHelp;
        if (showHelp && helpMsg) helpMsg.textContent = e.message ?? '';
      }
    }

    sync.subscribe(render);
    btn?.addEventListener('click', () => { sync.forcePull(); });

    // Refresh the relative timestamp every 30 seconds even if status doesn't change.
    setInterval(() => render(sync.status()), 30_000);

    // Skip sync init when this page is loaded inside the print iframe
    // (lib/pdf-download.ts adds ?embed=1). Otherwise every PDF print
    // would trigger an extra sync round-trip from the headless render.
    const isEmbedded = new URLSearchParams(window.location.search).get('embed') === '1';
    if (!isEmbedded) {
      // Kick off the sync. Errors are surfaced via render(); never throw out.
      sync.init().catch(() => { /* surfaced via status */ });
    }
  </script>
</body>
</html>
