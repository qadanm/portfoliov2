---
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout
  title="404, Not Found"
  description="Page not found."
  noindex={true}
>
  <div class="nf">
    <div class="nf__atmos" aria-hidden="true">
      <span class="nf__atmos-glow"></span>
    </div>

    <div class="container-site nf__inner">
      <div class="nf__sxn">
        <span class="nf__sxn-num">404</span>
        <span class="nf__sxn-label">Off the path</span>
        <span class="nf__sxn-rule" aria-hidden="true"></span>
        <span class="nf__sxn-meta">Page not found</span>
      </div>

      <h1 class="nf__title">
        This page <em>doesn't exist</em>.<br />
        Or it moved.
      </h1>

      <p class="nf__lede">
        Either way, pick a thread below.
      </p>

      <div class="nf__links">
        <a href="/" class="nf__link">
          <span class="nf__link-num">01</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Home</span>
            <span class="nf__link-sub">Start at the beginning.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/work" class="nf__link">
          <span class="nf__link-num">02</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Work</span>
            <span class="nf__link-sub">Selected projects and case studies.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/approach" class="nf__link">
          <span class="nf__link-num">03</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Approach</span>
            <span class="nf__link-sub">How I design, build, and use AI in production.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/about" class="nf__link">
          <span class="nf__link-num">04</span>
          <span class="nf__link-body">
            <span class="nf__link-title">About</span>
            <span class="nf__link-sub">Background and how I think.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/contact" class="nf__link">
          <span class="nf__link-num">05</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Contact</span>
            <span class="nf__link-sub">Send a message.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .nf {
    position: relative;
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-16);
    min-height: 80vh;
  }

  @media (min-width: 768px) {
    .nf {
      padding-top: calc(64px + var(--space-20));
      padding-bottom: var(--space-24);
    }
  }

  /* Page atmosphere */
  .nf__atmos {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 600px;
    pointer-events: none;
    overflow: hidden;
  }

  .nf__atmos-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 540px;
    background: radial-gradient(ellipse 50% 50% at 50% 50%, var(--color-accent-muted), transparent 70%);
    filter: blur(28px);
    opacity: 0.6;
  }

  .nf__inner {
    position: relative;
    max-width: 720px;
  }

  /* Numbered head */
  .nf__sxn {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .nf__sxn-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 8px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .nf__sxn-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .nf__sxn-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
    min-width: 32px;
  }

  .nf__sxn-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .nf__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 9vw, 72px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  .nf__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .nf__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin-bottom: var(--space-10);
  }

  .nf__links {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border-subtle);
  }

  .nf__link {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-4) 0;
    min-height: 64px;
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
    color: var(--color-text);
    transition: padding-left var(--duration-base) var(--ease-out);
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 600px) {
    .nf__link {
      grid-template-columns: 36px 1fr auto;
      gap: var(--space-4);
      padding: var(--space-5) 0;
    }
  }

  .nf__link:hover {
    padding-left: 8px;
  }

  .nf__link-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
  }

  .nf__link:hover .nf__link-num {
    color: var(--color-accent);
  }

  .nf__link-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nf__link-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  @media (min-width: 600px) {
    .nf__link-title {
      font-size: 22px;
    }
  }

  .nf__link-sub {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .nf__link-arrow {
    font-size: 18px;
    color: var(--color-text-subtle);
    transition: color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }

  .nf__link:hover .nf__link-arrow {
    color: var(--color-accent);
    transform: translateX(6px);
  }
</style>
