---
import BaseLayout from '@/components/layout/BaseLayout.astro';
---

<BaseLayout
  title="404 — Not Found"
  description="Page not found."
  noindex={true}
>
  <div class="nf">
    <div class="container-site nf__inner">
      <span class="nf__eyebrow">
        <span class="eyebrow__index">404</span>
        Off the path
      </span>

      <h1 class="nf__title">
        This page <em>doesn't exist</em>.<br />
        Or it moved.
      </h1>

      <p class="nf__lede">
        Either way, the system kept running. Pick a thread below.
      </p>

      <div class="nf__links">
        <a href="/" class="nf__link">
          <span class="nf__link-num">01</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Home</span>
            <span class="nf__link-sub">Start at the beginning.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/work" class="nf__link">
          <span class="nf__link-num">02</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Work</span>
            <span class="nf__link-sub">A flagship product, a platform, and earlier work.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/about" class="nf__link">
          <span class="nf__link-num">03</span>
          <span class="nf__link-body">
            <span class="nf__link-title">About</span>
            <span class="nf__link-sub">How I think about the work.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/contact" class="nf__link">
          <span class="nf__link-num">04</span>
          <span class="nf__link-body">
            <span class="nf__link-title">Contact</span>
            <span class="nf__link-sub">If you're building something interesting.</span>
          </span>
          <span class="nf__link-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .nf {
    padding-top: calc(64px + var(--space-20));
    padding-bottom: var(--space-24);
    min-height: 80vh;
  }

  .nf__inner {
    max-width: 720px;
  }

  .nf__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-5);
  }

  .nf__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  .nf__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .nf__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin-bottom: var(--space-10);
  }

  .nf__links {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border-subtle);
  }

  .nf__link {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
    color: var(--color-text);
    transition: padding-left var(--duration-base) var(--ease-out);
  }

  .nf__link:hover {
    padding-left: 8px;
  }

  .nf__link-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
  }

  .nf__link:hover .nf__link-num {
    color: var(--color-accent);
  }

  .nf__link-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nf__link-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .nf__link-sub {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .nf__link-arrow {
    font-size: 18px;
    color: var(--color-text-subtle);
    transition: color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }

  .nf__link:hover .nf__link-arrow {
    color: var(--color-accent);
    transform: translateX(6px);
  }
</style>
