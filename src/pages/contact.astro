---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.astro';

const channels = [
  {
    label: 'Email',
    value: 'moe@qadan.co',
    href: 'mailto:moe@qadan.co',
    primary: true,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/mqadan',
    href: 'https://linkedin.com/in/mqadan',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/qadanm',
    href: 'https://github.com/qadanm',
    external: true,
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Moe Qadan. Project questions, design and engineering conversations, speaking and writing inquiries. Replies within a day."
  keywords={[
    'contact Moe Qadan',
    'UX engineer Los Angeles',
    'frontend engineer Los Angeles',
    'design engineer',
    'creative technologist',
  ]}
>
  <div class="contact">
    {/* Page atmosphere */}
    <div class="contact__atmos" aria-hidden="true">
      <span class="contact__atmos-glow"></span>
    </div>

    <div class="container-site contact__inner">
      <header class="contact__head">
        <div class="contact__sxn">
          <span class="contact__sxn-num">01</span>
          <span class="contact__sxn-label">Contact</span>
          <span class="contact__sxn-rule" aria-hidden="true"></span>
          <span class="contact__sxn-meta">Replies within a day</span>
        </div>

        <h1 class="contact__title">
          Tell me what you're working on.
        </h1>

        <p class="contact__lede">
          For project questions, design or engineering conversations,
          or anything related to the work below. The form works, or
          email me directly. Either way you'll hear back.
        </p>
      </header>

      <div class="contact__grid">
        {/* Form card */}
        <section class="contact__form-card" aria-labelledby="contact-form-heading">
          <span class="contact__form-corner contact__form-corner--tl" aria-hidden="true"></span>
          <span class="contact__form-corner contact__form-corner--tr" aria-hidden="true"></span>
          <span class="contact__form-corner contact__form-corner--bl" aria-hidden="true"></span>
          <span class="contact__form-corner contact__form-corner--br" aria-hidden="true"></span>
          <span class="contact__form-glow" aria-hidden="true"></span>

          <header class="contact__form-head">
            <span class="contact__form-num">02</span>
            <h2 id="contact-form-heading" class="contact__form-title">Send a message</h2>
            <span class="contact__form-rule" aria-hidden="true"></span>
          </header>

          <div class="contact__form-wrap">
            <ContactForm variant="full" formId="contact-form-full" />
          </div>
        </section>

        {/* Direct channels */}
        <aside class="contact__channels-wrap" aria-labelledby="contact-channels-heading">
          <header class="contact__channels-head">
            <span class="contact__channels-num">03</span>
            <h2 id="contact-channels-heading" class="contact__channels-title">Or reach me directly</h2>
            <span class="contact__channels-rule" aria-hidden="true"></span>
          </header>

          <ul class="contact__channels">
            {channels.map(c => (
              <li>
                <a
                  href={c.href}
                  class:list={['contact__channel', { 'contact__channel--primary': c.primary }]}
                  target={c.external ? '_blank' : undefined}
                  rel={c.external ? 'noopener noreferrer' : undefined}
                  data-track="contact_click"
                  data-track-channel={c.label.toLowerCase()}
                  data-track-loc="contact-page"
                >
                  <span class="contact__channel-corner contact__channel-corner--tl" aria-hidden="true"></span>
                  <span class="contact__channel-corner contact__channel-corner--br" aria-hidden="true"></span>

                  <span class="contact__channel-label">{c.label}</span>
                  <span class="contact__channel-value">{c.value}</span>
                  <span class="contact__channel-icon" aria-hidden="true">
                    {c.external ? (
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <path d="M5 2h7v7M12 2 2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    ) : (
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </span>
                </a>
              </li>
            ))}
          </ul>

          <footer class="contact__foot">
            <span class="contact__foot-line" aria-hidden="true"></span>
            <p class="contact__foot-text">
              Based in Los Angeles. Working PT/CST/EST hours, but flexible.
            </p>
          </footer>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact {
    position: relative;
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-16);
    min-height: 80vh;
  }

  @media (min-width: 768px) {
    .contact {
      padding-top: calc(64px + var(--space-16));
      padding-bottom: var(--space-24);
    }
  }

  /* Page atmosphere */
  .contact__atmos {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 600px;
    pointer-events: none;
    overflow: hidden;
  }

  .contact__atmos-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 540px;
    background: radial-gradient(ellipse 50% 50% at 50% 50%, var(--color-accent-muted), transparent 70%);
    filter: blur(28px);
    opacity: 0.7;
  }

  .contact__inner {
    position: relative;
  }

  /* Numbered head */
  .contact__head {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .contact__head {
      margin-bottom: var(--space-12);
    }
  }

  .contact__sxn {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .contact__sxn-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 7px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .contact__sxn-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .contact__sxn-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
    min-width: 32px;
  }

  .contact__sxn-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 7vw, 60px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  @media (min-width: 768px) {
    .contact__title { margin-bottom: var(--space-6); }
  }

  .contact__lede {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  /* Two-column body */
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-10);
      align-items: start;
    }
  }

  /* ─── Form card ───────────────────────────────────────────────────── */
  .contact__form-card {
    position: relative;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background:
      linear-gradient(180deg, var(--color-bg-elevated), var(--color-bg-muted));
    box-shadow:
      var(--shadow-card),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }

  @media (min-width: 600px) {
    .contact__form-card {
      padding: var(--space-7) var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .contact__form-card {
      padding: var(--space-8) var(--space-9);
    }
  }

  .contact__form-glow {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, var(--color-accent-muted), transparent 65%);
    filter: blur(40px);
    pointer-events: none;
  }

  .contact__form-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-text-subtle);
    pointer-events: none;
    opacity: 0.5;
    z-index: 2;
  }

  .contact__form-corner--tl { top: 12px; left: 12px; border-right: none; border-bottom: none; }
  .contact__form-corner--tr { top: 12px; right: 12px; border-left: none; border-bottom: none; }
  .contact__form-corner--bl { bottom: 12px; left: 12px; border-right: none; border-top: none; }
  .contact__form-corner--br { bottom: 12px; right: 12px; border-left: none; border-top: none; }

  .contact__form-head {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
    z-index: 1;
  }

  .contact__form-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 7px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .contact__form-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
  }

  .contact__form-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
  }

  .contact__form-wrap {
    position: relative;
    z-index: 1;
  }

  /* Style overrides on the form for the new submit treatment */
  .contact__form-wrap :global(.cf__submit) {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 1px 2px rgba(0, 0, 0, 0.2),
      0 6px 18px rgba(0, 0, 0, 0.18);
  }

  :global([data-theme="dark"]) .contact__form-wrap :global(.cf__submit) {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 1px 2px rgba(0, 0, 0, 0.4),
      0 8px 22px rgba(0, 0, 0, 0.35);
  }

  .contact__form-wrap :global(.cf__submit:hover:not(:disabled)) {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.5) inset,
      0 12px 28px rgba(0, 0, 0, 0.18),
      0 0 0 4px var(--color-accent-dim);
  }

  /* ─── Channels ────────────────────────────────────────────────────── */
  .contact__channels-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (min-width: 1024px) {
    .contact__channels-wrap {
      position: sticky;
      top: 84px;
    }
  }

  .contact__channels-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-1);
  }

  .contact__channels-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 7px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .contact__channels-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
  }

  .contact__channels-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
  }

  .contact__channels {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Per-channel accent: primary uses warm amber, others use steel */
  .contact__channel {
    --pc-accent: var(--color-text);
    --pc-accent-rgb: 113, 113, 122;
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    min-height: 64px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(180deg, var(--color-bg-elevated), var(--color-bg-muted));
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      border-color 280ms,
      transform 280ms var(--ease-out),
      box-shadow 280ms;
    -webkit-tap-highlight-color: transparent;
  }

  .contact__channel--primary {
    --pc-accent: var(--color-accent);
    --pc-accent-rgb: var(--project-flagship-rgb);
    border-color: var(--color-accent-muted);
    background:
      linear-gradient(180deg,
        color-mix(in srgb, var(--color-accent) 6%, var(--color-bg-elevated)),
        var(--color-bg-muted)
      );
  }

  .contact__channel:hover {
    border-color: var(--pc-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .contact__channel-corner {
    position: absolute;
    width: 8px;
    height: 8px;
    border: 1px solid var(--color-text-subtle);
    opacity: 0.4;
    pointer-events: none;
    transition: opacity 240ms, border-color 240ms;
  }

  .contact__channel-corner--tl { top: 8px; left: 8px; border-right: none; border-bottom: none; }
  .contact__channel-corner--br { bottom: 8px; right: 8px; border-left: none; border-top: none; }

  .contact__channel:hover .contact__channel-corner {
    opacity: 1;
    border-color: var(--pc-accent);
  }

  .contact__channel-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    width: 80px;
    flex-shrink: 0;
  }

  .contact__channel--primary .contact__channel-label {
    color: var(--color-accent);
  }

  .contact__channel-value {
    flex: 1;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.005em;
    word-break: break-all;
  }

  .contact__channel-icon {
    color: var(--color-text-subtle);
    transition: color 200ms, transform 200ms;
    flex-shrink: 0;
    display: inline-flex;
  }

  .contact__channel:hover .contact__channel-icon {
    color: var(--pc-accent);
    transform: translate(2px, -2px);
  }

  @media (max-width: 560px) {
    .contact__channel {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "label icon"
        "value icon";
      align-items: center;
      column-gap: var(--space-3);
      row-gap: 4px;
    }

    .contact__channel-label {
      grid-area: label;
      width: auto;
    }

    .contact__channel-value {
      grid-area: value;
      font-size: 16px;
    }

    .contact__channel-icon {
      grid-area: icon;
    }
  }

  /* Footer line */
  .contact__foot {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding-top: var(--space-3);
  }

  .contact__foot-line {
    flex-shrink: 0;
    width: 18px;
    height: 1px;
    margin-top: 9px;
    background-color: var(--color-text-subtle);
  }

  .contact__foot-text {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-subtle);
    line-height: 1.55;
    letter-spacing: 0.02em;
    margin: 0;
  }
</style>
