---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.astro';

const channels = [
  {
    label: 'Email',
    value: 'moe@qadan.co',
    href: 'mailto:moe@qadan.co',
    primary: true,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/mqadan',
    href: 'https://linkedin.com/in/mqadan',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/qadanm',
    href: 'https://github.com/qadanm',
    external: true,
  },
];
---

<BaseLayout
  title="Contact Moe Qadan"
  description="Open to hearing about projects. Contracts, advisory, or a half-hour conversation. Reply within a day."
  keywords={[
    'contact Moe Qadan',
    'product designer',
    'UX engineer',
    'design engineer',
    'AI product design',
  ]}
>
  <div class="contact">
    <div class="container-site contact__inner">
      <div class="contact__content">
        <div class="contact__status">
          <span class="contact__status-dot" aria-hidden="true"></span>
          <span class="contact__status-text">Open to projects</span>
        </div>

        <h1 class="contact__title">
          Tell me what you're building.
        </h1>

        <p class="contact__lede">
          Contracts, advisory, or a half-hour conversation about
          something on your roadmap. Reply within a day. Form below
          works fine, or email me directly.
        </p>

        <div class="contact__form-wrap">
          <ContactForm variant="full" formId="contact-form-full" />
        </div>

        <div class="contact__divider" aria-hidden="true">
          <span>Or reach out directly</span>
        </div>

        <ul class="contact__channels">
          {channels.map(c => (
            <li>
              <a
                href={c.href}
                class:list={['contact__channel', { 'contact__channel--primary': c.primary }]}
                target={c.external ? '_blank' : undefined}
                rel={c.external ? 'noopener noreferrer' : undefined}
                data-track="contact_click"
                data-track-channel={c.label.toLowerCase()}
                data-track-loc="contact-page"
              >
                <span class="contact__channel-label">{c.label}</span>
                <span class="contact__channel-value">{c.value}</span>
                <span class="contact__channel-icon" aria-hidden="true">
                  {c.external ? (
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <path d="M5 2h7v7M12 2 2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  ) : (
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact {
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-16);
    min-height: 80vh;
  }

  @media (min-width: 768px) {
    .contact {
      padding-top: calc(64px + var(--space-16));
      padding-bottom: var(--space-24);
    }
  }

  .contact__content {
    max-width: 720px;
  }

  .contact__status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px 5px 10px;
    margin-bottom: var(--space-5);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-success);
    background-color: color-mix(in srgb, var(--color-success) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-success) 28%, transparent);
  }

  .contact__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-success);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-success) 65%, transparent);
    animation: contact-status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes contact-status-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact__status-dot { animation: none; }
  }

  .contact__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 7vw, 60px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  @media (min-width: 768px) {
    .contact__title {
      margin-bottom: var(--space-6);
    }
  }

  .contact__lede {
    font-size: clamp(16px, 1.6vw, 18px);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: var(--space-10);
  }

  .contact__form-wrap {
    margin-bottom: var(--space-10);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-elevated);
    max-width: 640px;
  }

  @media (min-width: 600px) {
    .contact__form-wrap {
      padding: var(--space-6);
      border-radius: var(--radius-xl);
    }
  }

  @media (min-width: 720px) {
    .contact__form-wrap {
      padding: var(--space-8) var(--space-9);
    }
  }

  .contact__divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    max-width: 560px;
  }

  .contact__divider::before,
  .contact__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: var(--color-border-subtle);
  }

  .contact__divider span {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .contact__channels {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 560px;
  }

  .contact__channel {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    min-height: 64px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-elevated);
    text-decoration: none;
    color: var(--color-text);
    transition:
      border-color 200ms,
      transform 200ms var(--ease-out),
      box-shadow 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .contact__channel:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 0 0 1px var(--color-accent-muted);
  }

  .contact__channel--primary {
    border-color: var(--color-accent-muted);
    background-color: var(--color-accent-dim);
  }

  .contact__channel-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    width: 80px;
    flex-shrink: 0;
  }

  .contact__channel--primary .contact__channel-label {
    color: var(--color-accent);
  }

  .contact__channel-value {
    flex: 1;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.005em;
    word-break: break-all;
  }

  .contact__channel-icon {
    color: var(--color-text-subtle);
    transition: color 200ms, transform 200ms;
    flex-shrink: 0;
    display: inline-flex;
  }

  .contact__channel:hover .contact__channel-icon {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }

  @media (max-width: 560px) {
    .contact__channel {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "label icon"
        "value icon";
      align-items: center;
      column-gap: var(--space-3);
      row-gap: 4px;
      padding: var(--space-4);
    }

    .contact__channel-label {
      grid-area: label;
      width: auto;
    }

    .contact__channel-value {
      grid-area: value;
      font-size: 16px;
    }

    .contact__channel-icon {
      grid-area: icon;
    }
  }
</style>
