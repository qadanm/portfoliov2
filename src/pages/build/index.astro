---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProjectGrid from '@/components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Build — Selected Work by Moe Qadan"
  description="Selected projects and experience across product design, UX engineering, frontend systems, platform-scale work, and AI-native products — including ChatOBD2, MagTek Platform, the Sawa marketing site, and advisor platforms."
  keywords={[
    'Moe Qadan',
    'portfolio',
    'product design portfolio',
    'UX engineering portfolio',
    'case studies',
    'ChatOBD2',
    'MagTek',
    'Sawa',
    'advisor platforms',
  ]}
>
  <div class="work-index">
    <header class="work-index__hero">
      <div class="container-site">
        <span class="work-index__eyebrow">
          <span class="eyebrow__index">B</span>
          Build
        </span>
        <h1 class="work-index__title">
          A flagship product, a platform,<br />and the systems <em>around them</em>.
        </h1>
        <p class="work-index__lede">
          AI-native products on one side, multi-site platform UX and
          financial advisor systems on the other. All of it approached
          as work that has to keep running.
        </p>
      </div>
    </header>

    <div class="container-site work-index__body">
      <ProjectGrid projects={projects} />
    </div>
  </div>
</BaseLayout>

<style>
  .work-index__hero {
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border-subtle);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .work-index__hero {
      padding-top: calc(64px + var(--space-16));
      padding-bottom: var(--space-12);
      margin-bottom: var(--space-12);
    }
  }

  .work-index__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .work-index__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 9vw, 80px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  .work-index__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .work-index__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .work-index__body {
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .work-index__body {
      padding-bottom: var(--space-24);
    }
  }
</style>
