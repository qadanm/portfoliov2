---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const experiments = await getCollection('lab');
const sorted = experiments.sort((a, b) => a.data.order - b.data.order);

const statusColors: Record<string, string> = {
  Active: 'status-active',
  Shipped: 'status-shipped',
  Archived: 'status-archived',
  Concept: 'status-concept',
};
---

<BaseLayout
  title="Lab — Muhammed Qadan"
  description="Active experiments in AI-native workflows, agentic UX concepts, and frontier interface patterns."
>
  <div class="page-hero">
    <div class="container-site">
      <span class="badge badge-accent animate-fade-up">Lab</span>
      <h1 class="page-title animate-fade-up animate-delay-100">
        Active experiments
      </h1>
      <p class="page-desc animate-fade-up animate-delay-200">
        A working bench of AI-native workflow experiments, interface concepts,
        and frontier thinking. Not polished case studies — living work.
        Some of it will ship. Some of it will inform something that ships.
      </p>
    </div>
  </div>

  <div class="container-site" style="padding-bottom: var(--space-24)">
    <div class="lab-grid">
      {sorted.map((exp, i) => (
        <div class="lab-card" style={`animation-delay: ${i * 80}ms`}>
          <div class="lc-header">
            <div class={`lab-status ${statusColors[exp.data.status]}`}>
              <span class="status-dot-small"></span>
              {exp.data.status}
            </div>
            <time datetime={exp.data.date.toISOString()} class="lc-date">
              {exp.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
            </time>
          </div>
          <h2 class="lc-title">{exp.data.title}</h2>
          <p class="lc-desc">{exp.data.description}</p>
          <div class="lc-tags">
            {exp.data.tags.map(tag => (
              <span class="lc-tag">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Lab note -->
    <div class="lab-note">
      <div class="lab-note-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <p>
        This is a living section. Experiments get added, updated, and sometimes retired
        as priorities shift. For more developed thinking on any of these areas, see
        <a href="/writing">Writing</a> or <a href="/work">Work</a>.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(64px + var(--space-16));
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .page-title {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text);
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .page-desc {
    font-size: 17px;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 560px;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 640px) {
    .lab-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .lab-card {
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    animation: fadeUp 400ms var(--ease-out) both;
    transition: border-color 200ms, transform 200ms;
  }

  .lab-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .lc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .lab-status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 9999px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .status-dot-small {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: currentColor;
  }

  .status-active {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--color-success);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .status-active .status-dot-small {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  .status-shipped {
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-muted);
  }

  .status-archived {
    background-color: var(--color-bg-muted);
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
  }

  .status-concept {
    background-color: rgba(139, 92, 246, 0.08);
    color: rgb(139, 92, 246);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .lc-date {
    font-size: 12px;
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .lc-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.25;
  }

  .lc-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .lc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .lc-tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
  }

  .lab-note {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-muted);
  }

  .lab-note-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    color: var(--color-text-subtle);
    margin-top: 1px;
  }

  .lab-note p {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .lab-note a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-muted);
    text-underline-offset: 2px;
    font-weight: 500;
  }

  .lab-note a:hover {
    text-decoration-color: var(--color-accent);
  }
</style>
