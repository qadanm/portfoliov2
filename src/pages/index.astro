---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Hero from '@/components/home/Hero.astro';
import ProjectGrid from '@/components/ProjectGrid.astro';
import VerdictCardMock from '@/components/diagrams/VerdictCardMock.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Moe Qadan — Product Designer & UX Engineer"
  description="Moe Qadan designs and ships products end to end — interface, frontend, and the system the model lives inside. Work spans enterprise platforms (MagTek), advisor portals deployed across 50+ wealth and banking institutions at InvestCloud, and ChatOBD2."
  keywords={[
    'Moe Qadan',
    'Muhammed Qadan',
    'product designer',
    'UX engineer',
    'design engineer',
    'AI product design',
    'frontend architecture',
    'design systems',
    'platform UX',
    'portfolio',
  ]}
>
  <Hero />

  {/* Section 01 — Selected work, BEFORE methodology.
      The audit's #1 structural fix: lead with evidence, not process. */}
  <section class="home-work" id="work">
    <div class="container-site">
      <div class="home-work__head" data-reveal>
        <span class="home-work__eyebrow">
          <span class="section-index" aria-hidden="true">01</span>
          Selected work
        </span>
        <h2 class="home-work__title">
          Recent work — products,<br />platforms, AI systems.
        </h2>
        <p class="home-work__lede">
          A flagship AI product, a multi-site enterprise platform, and
          advisor tools deployed across major wealth institutions. All
          shipped, all live, all built end to end.
        </p>
      </div>

      <div data-reveal data-reveal-delay="2">
        <ProjectGrid projects={projects} />
      </div>
    </div>
  </section>

  {/* Section 02 — Approach.
      One concise section combining "How I work" + design workflow,
      anchored by a real product surface (the verdict card) instead of
      an abstract workflow diagram. Concrete proof beats methodology. */}
  <section class="home-approach" id="approach">
    <div class="container-site">
      <div class="home-approach__head" data-reveal>
        <span class="home-approach__eyebrow">
          <span class="section-index" aria-hidden="true">02</span>
          Approach
        </span>
        <h2 class="home-approach__title">
          The model is one stage.<br />The <em>system</em> is the product.
        </h2>
      </div>

      <div class="home-approach__grid">
        <div class="home-approach__col" data-reveal data-reveal-delay="1">
          <p class="home-approach__lead">
            ChatOBD2 puts six deterministic reasoning layers in front of
            every model call, with a system prompt assembled per scan
            from a 38,000-token budget. The model gets a structured spec,
            not a chat. That's how it stays repeatable, inspectable, and
            cheaper to evolve.
          </p>
          <ul class="home-approach__principles">
            <li>
              <span class="home-approach__principle-num">01</span>
              <div>
                <strong>Systems before surfaces.</strong>
                A page is a render of something deeper. Get the structure
                right and the surface gets cheaper to change.
              </div>
            </li>
            <li>
              <span class="home-approach__principle-num">02</span>
              <div>
                <strong>Constraints are the brief.</strong>
                Long-running stacks, real users, code that can't be torn
                down. That's the actual design problem.
              </div>
            </li>
            <li>
              <span class="home-approach__principle-num">03</span>
              <div>
                <strong>AI is infrastructure, not a feature.</strong>
                Prompts live in the system, scoped and budgeted. Same
                inputs, consistent outputs. Repeatability over novelty.
              </div>
            </li>
          </ul>
          <a
            href="/approach"
            class="home-approach__link"
            data-track="cta_click"
            data-track-cta="more-approach"
            data-track-loc="home-approach"
          >
            More on the approach
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        {/* Real product artifact, not an abstract diagram —
            audit fix: replace workflow strip with shipped pixels. */}
        <div class="home-approach__art" data-reveal data-reveal-delay="3">
          <VerdictCardMock />
        </div>
      </div>
    </div>
  </section>

  {/* Section 03 — Single CTA.
      No inline form (the form is on /contact, no need to duplicate it). */}
  <section class="home-contact" id="contact-cta">
    <div class="container-site">
      <div class="home-contact__card" data-reveal>
        <div class="home-contact__card-text">
          <span class="home-contact__eyebrow">
            <span class="section-index" aria-hidden="true">03</span>
            Get in touch
          </span>
          <h2 class="home-contact__title">
            Open to hearing about projects<br />
            and AI-native product work.
          </h2>
          <p class="home-contact__sub">
            Tell me what you're building. Replies usually within a day.
          </p>
        </div>
        <div class="home-contact__card-actions">
          <a
            href="/contact"
            class="home-contact__cta home-contact__cta--primary"
            data-track="cta_click"
            data-track-cta="contact-page"
            data-track-loc="home-contact"
          >
            Send a message
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="mailto:moe@qadan.co"
            class="home-contact__cta home-contact__cta--ghost"
            data-track="contact_click"
            data-track-channel="email"
            data-track-loc="home-contact"
          >
            moe@qadan.co
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Selected work — comes first now */
  .home-work {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .home-work {
      padding-top: var(--space-24);
      padding-bottom: var(--space-24);
    }
  }

  .home-work__head {
    margin-bottom: var(--space-8);
    max-width: 720px;
  }

  @media (min-width: 768px) {
    .home-work__head {
      margin-bottom: var(--space-12);
    }
  }

  .home-work__eyebrow,
  .home-approach__eyebrow,
  .home-contact__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .section-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 22px;
    padding: 0 7px;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .home-work__title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 400;
    letter-spacing: -0.028em;
    line-height: 1.0;
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .home-work__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 56ch;
    opacity: 0.92;
  }

  /* Approach — single combined section (was: How I Work + Design Workflow) */
  .home-approach {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .home-approach {
      padding-top: var(--space-32);
      padding-bottom: var(--space-24);
    }
  }

  .home-approach__head {
    margin-bottom: var(--space-8);
    max-width: 720px;
  }

  @media (min-width: 768px) {
    .home-approach__head {
      margin-bottom: var(--space-12);
    }
  }

  .home-approach__title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    text-wrap: balance;
  }

  .home-approach__title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .home-approach__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .home-approach__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      gap: var(--space-16);
    }
  }

  .home-approach__lead {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: var(--space-6);
    max-width: 56ch;
  }

  .home-approach__principles {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 56ch;
  }

  .home-approach__principles li {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: var(--space-3);
    align-items: baseline;
    font-size: clamp(14px, 1.4vw, 16px);
    line-height: 1.65;
    color: var(--color-text-muted);
  }

  .home-approach__principle-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    padding-top: 2px;
  }

  .home-approach__principles strong {
    color: var(--color-text);
    font-weight: 600;
    display: block;
    margin-bottom: 2px;
  }

  .home-approach__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 6px;
    transition: color 150ms, border-color 150ms;
  }

  .home-approach__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .home-approach__art {
    /* The verdict card mock has its own internal layout */
  }

  .home-approach__art :global(.verdict-mock) {
    margin: 0;
  }

  .home-approach__art :global(.verdict-mock__head) {
    display: none;
  }

  .home-approach__art :global(.verdict-mock__frame) {
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .home-approach__art :global(.verdict-mock__frame) {
      grid-template-columns: 1fr;
    }
  }

  /* Contact CTA card — single, focused, no inline form */
  .home-contact {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .home-contact {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }
  }

  .home-contact__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding: var(--space-7) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background-color: var(--color-bg-elevated);
    background-image: radial-gradient(ellipse 60% 70% at 100% 0%, var(--color-accent-dim), transparent 70%);
  }

  @media (min-width: 720px) {
    .home-contact__card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-10);
      padding: var(--space-9) var(--space-10);
    }
  }

  .home-contact__card-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .home-contact__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
    max-width: 28ch;
  }

  .home-contact__sub {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 38ch;
  }

  .home-contact__card-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  @media (min-width: 380px) and (max-width: 720px) {
    .home-contact__card-actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  .home-contact__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: transform 200ms var(--ease-out), background-color 200ms, border-color 200ms, color 200ms, box-shadow 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .home-contact__cta--primary {
    background-color: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }

  .home-contact__cta--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
  }

  .home-contact__cta--ghost {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
  }

  .home-contact__cta--ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }
</style>
