---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Hero from '@/components/home/Hero.astro';
import ProjectGrid from '@/components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Moe Qadan, Senior UX & Front-end"
  description="Moe Qadan is a senior UX and frontend practitioner in Los Angeles. UX, design systems, content architecture, SEO, performance, accessibility, and AI-assisted prototyping. Currently leading web experience at MagTek; shipping ChatOBD2 solo; previously deployed advisor portals at InvestCloud across 50+ wealth and banking institutions."
  keywords={[
    'Moe Qadan',
    'Muhammed Qadan',
    'UX engineer',
    'senior UX engineer',
    'frontend engineer',
    'web experience',
    'design systems',
    'Razor partials',
    'ASP.NET MVC',
    'AI-assisted prototyping',
    'portfolio',
  ]}
>
  <Hero />

  {/* Selected work. No section number, no manifesto lede.
      The cards do the work. */}
  <section class="home-work" id="work">
    <div class="container-site">
      <div class="home-work__head" data-reveal>
        <span class="home-work__eyebrow">Work</span>
        <h2 class="home-work__title">
          Recent projects.
        </h2>
      </div>

      <div data-reveal data-reveal-delay="2">
        <ProjectGrid projects={projects} />
      </div>
    </div>
  </section>

  {/* Approach teaser. Three lines, links into the dedicated page.
      The /approach page carries the depth so the homepage stays
      a fast read. */}
  <section class="home-approach" id="approach-teaser">
    <div class="container-site">
      <div class="home-approach__inner" data-reveal>
        <div class="home-approach__col-l">
          <span class="home-approach__eyebrow">How I work</span>
          <p class="home-approach__lead">
            A lot of the work I take on looks like repair. A platform
            that grew without a system. A site that ranks well and
            converts badly. A frontend that ships fine on Chrome and
            falls apart on iOS. Existing AI tooling that needs a real
            home in the codebase.
          </p>
        </div>
        <div class="home-approach__col-r">
          <p class="home-approach__body">
            The way I approach it is the same in each case. Read the
            constraints first. Pick the structure carefully. Use AI
            where it earns its place.
          </p>
          <a
            href="/approach"
            class="home-approach__link"
            data-track="cta_click"
            data-track-cta="more-approach"
            data-track-loc="home-approach"
          >
            Read more on how I work
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Single, plain CTA. No section number. */}
  <section class="home-contact" id="contact-cta">
    <div class="container-site">
      <div class="home-contact__card" data-reveal>
        <div class="home-contact__card-text">
          <span class="home-contact__eyebrow">Contact</span>
          <h2 class="home-contact__title">
            If you're putting something on the web,<br />
            I'd like to hear about it.
          </h2>
          <p class="home-contact__sub">
            Contracts, advisory, or a half-hour conversation. Reply
            within a day.
          </p>
        </div>
        <div class="home-contact__card-actions">
          <a
            href="/contact"
            class="home-contact__cta home-contact__cta--primary"
            data-track="cta_click"
            data-track-cta="contact-page"
            data-track-loc="home-contact"
          >
            Send a message
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="mailto:moe@qadan.co"
            class="home-contact__cta home-contact__cta--ghost"
            data-track="contact_click"
            data-track-channel="email"
            data-track-loc="home-contact"
          >
            moe@qadan.co
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-work {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .home-work {
      padding-top: var(--space-24);
      padding-bottom: var(--space-24);
    }
  }

  .home-work__head {
    margin-bottom: var(--space-8);
    max-width: 720px;
  }

  @media (min-width: 768px) {
    .home-work__head {
      margin-bottom: var(--space-12);
    }
  }

  .home-work__eyebrow,
  .home-approach__eyebrow,
  .home-contact__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .home-work__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }

  .home-work__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  /* Approach teaser */
  .home-approach {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .home-approach {
      padding-top: var(--space-24);
      padding-bottom: var(--space-24);
    }
  }

  .home-approach__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 900px) {
    .home-approach__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      align-items: start;
    }
  }

  .home-approach__lead {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 28px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.35;
    color: var(--color-text);
    max-width: 32ch;
  }

  .home-approach__body {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-5);
  }

  .home-approach__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 6px;
    transition: color 150ms, border-color 150ms;
  }

  .home-approach__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Contact CTA card */
  .home-contact {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .home-contact {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }
  }

  .home-contact__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    padding: var(--space-7) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background-color: var(--color-bg-elevated);
  }

  @media (min-width: 720px) {
    .home-contact__card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-10);
      padding: var(--space-9) var(--space-10);
    }
  }

  .home-contact__card-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .home-contact__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.8vw, 32px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
    max-width: 30ch;
  }

  .home-contact__sub {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 38ch;
  }

  .home-contact__card-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  @media (min-width: 380px) and (max-width: 720px) {
    .home-contact__card-actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  .home-contact__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: transform 200ms var(--ease-out), background-color 200ms, border-color 200ms, color 200ms, box-shadow 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .home-contact__cta--primary {
    background-color: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }

  .home-contact__cta--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
  }

  .home-contact__cta--ghost {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.02em;
  }

  .home-contact__cta--ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }
</style>
