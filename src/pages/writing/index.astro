---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('writing', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Writing — Muhammed Qadan"
  description="Notes on AI-native product design, agentic workflows, design systems, and how the designer's role is evolving."
>
  <div class="page-hero">
    <div class="container-site">
      <span class="badge badge-muted animate-fade-up">Writing</span>
      <h1 class="page-title animate-fade-up animate-delay-100">
        Thinking in public
      </h1>
      <p class="page-desc animate-fade-up animate-delay-200">
        Notes on AI-native design, agentic workflows, design-to-code convergence,
        and what it means to build products in an era of intelligent systems.
        Infrequent but substantial.
      </p>
    </div>
  </div>

  <div class="container-site" style="padding-bottom: var(--space-24)">
    <div class="writing-list">
      {posts.map((post, i) => (
        <a
          href={`/writing/${post.slug}`}
          class="writing-item"
          style={`animation-delay: ${i * 60}ms`}
        >
          <div class="wi-meta">
            <time datetime={post.data.date.toISOString()} class="wi-date">
              {formatDate(post.data.date)}
            </time>
            <div class="wi-tags">
              {post.data.tags.slice(0, 2).map(tag => (
                <span class="wi-tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="wi-body">
            <h2 class="wi-title">{post.data.title}</h2>
            <p class="wi-desc">{post.data.description}</p>
            {post.data.readingTime && (
              <span class="wi-reading-time">{post.data.readingTime} min read</span>
            )}
          </div>
          <div class="wi-arrow" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero {
    padding-top: calc(64px + var(--space-16));
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .page-title {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text);
    margin-top: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .page-desc {
    font-size: 17px;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 560px;
  }

  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background-color: var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .writing-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-7);
    background-color: var(--color-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition: background-color 150ms;
    animation: fadeUp 400ms var(--ease-out) both;
  }

  @media (min-width: 768px) {
    .writing-item {
      grid-template-columns: 220px 1fr auto;
      gap: var(--space-8);
      align-items: center;
    }
  }

  .writing-item:hover {
    background-color: var(--color-bg-muted);
  }

  .writing-item:hover .wi-title {
    color: var(--color-accent);
  }

  .wi-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .wi-date {
    font-size: 13px;
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .wi-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .wi-tag {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 9999px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-muted);
  }

  .wi-body {
    flex: 1;
  }

  .wi-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 6px;
    line-height: 1.3;
    transition: color 150ms;
  }

  .wi-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .wi-reading-time {
    display: inline-block;
    margin-top: var(--space-2);
    font-size: 12px;
    color: var(--color-text-subtle);
  }

  .wi-arrow {
    color: var(--color-text-subtle);
    transition: color 200ms, transform 200ms;
    flex-shrink: 0;
  }

  .writing-item:hover .wi-arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }
</style>
