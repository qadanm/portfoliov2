---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProjectGrid from '@/components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Selected Work"
  description="Selected case studies by Moe Qadan. ChatOBD2 AI-native diagnostics, MagTek's multi-site platform, the Sawa marketing site, and advisor portals deployed across more than 50 wealth and banking institutions at InvestCloud."
  keywords={[
    'Moe Qadan',
    'portfolio',
    'UX engineering portfolio',
    'frontend portfolio',
    'design systems portfolio',
    'case studies',
    'ChatOBD2',
    'MagTek',
    'Sawa',
    'InvestCloud',
  ]}
>
  <div class="work-index">
    {/* Page atmosphere */}
    <div class="work-index__atmos" aria-hidden="true">
      <span class="work-index__atmos-glow"></span>
    </div>

    <header class="work-index__hero">
      <div class="container-site">
        <div class="work-index__sxn">
          <span class="work-index__sxn-num">01</span>
          <span class="work-index__sxn-label">Work</span>
          <span class="work-index__sxn-rule" aria-hidden="true"></span>
          <span class="work-index__sxn-meta">Case studies &amp; project notes</span>
        </div>
        <h1 class="work-index__title">
          Selected work, in two passes.
        </h1>
        <p class="work-index__lede">
          Independent projects below, then the companies where I've
          shipped work inside their team. Each one is a different
          surface, a different platform, a different posture.
        </p>
      </div>
    </header>

    <div class="container-site work-index__body">
      <ProjectGrid projects={projects} />
    </div>
  </div>
</BaseLayout>

<style>
  .work-index {
    position: relative;
  }

  /* Page atmosphere */
  .work-index__atmos {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 600px;
    pointer-events: none;
    overflow: hidden;
  }

  .work-index__atmos-glow {
    position: absolute;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 540px;
    background: radial-gradient(ellipse 50% 50% at 50% 50%, var(--color-accent-muted), transparent 70%);
    filter: blur(28px);
    opacity: 0.7;
  }

  .work-index__hero {
    position: relative;
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border-subtle);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .work-index__hero {
      padding-top: calc(64px + var(--space-16));
      padding-bottom: var(--space-12);
      margin-bottom: var(--space-12);
    }
  }

  .work-index__sxn {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .work-index__sxn-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 7px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .work-index__sxn-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .work-index__sxn-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
    min-width: 32px;
  }

  .work-index__sxn-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .work-index__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 9vw, 80px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  .work-index__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 62ch;
  }

  .work-index__body {
    position: relative;
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .work-index__body {
      padding-bottom: var(--space-24);
    }
  }
</style>
