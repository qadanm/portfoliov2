---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ProjectGrid from '@/components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Work, Moe Qadan"
  description="Selected work. ChatOBD2, MagTek's multi-site platform, the Sawa marketing site, and advisor portals deployed across 50+ wealth and banking institutions at InvestCloud."
  keywords={[
    'Moe Qadan',
    'portfolio',
    'product design portfolio',
    'UX engineering portfolio',
    'case studies',
    'ChatOBD2',
    'MagTek',
    'Sawa',
    'advisor platforms',
  ]}
>
  <div class="work-index">
    <header class="work-index__hero">
      <div class="container-site">
        <span class="work-index__eyebrow">Work</span>
        <h1 class="work-index__title">
          Four shipped projects.
        </h1>
        <p class="work-index__lede">
          ChatOBD2, MagTek's multi-site platform, the Sawa marketing
          site, and the InvestCloud portal work. All in production. All
          have traffic. The case studies below cover the constraint, the
          decision, the tradeoff, and what landed.
        </p>
      </div>
    </header>

    <div class="container-site work-index__body">
      <ProjectGrid projects={projects} />
    </div>
  </div>
</BaseLayout>

<style>
  .work-index__hero {
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--color-border-subtle);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 768px) {
    .work-index__hero {
      padding-top: calc(64px + var(--space-16));
      padding-bottom: var(--space-12);
      margin-bottom: var(--space-12);
    }
  }

  .work-index__eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
  }

  .work-index__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 9vw, 80px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 18ch;
  }

  .work-index__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 62ch;
  }

  .work-index__body {
    padding-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .work-index__body {
      padding-bottom: var(--space-24);
    }
  }
</style>
