<style>
  /* ─── The project's own colour ────────────────────────────────────────
     Keyed on the SLUG, not the category — category is a filing label, it
     was never a design fact. Every value below is lifted from the artifact
     component for that project (src/components/artifacts/), which was drawn
     against the shipped product. Nothing here is invented, and nothing is
     sampled: --plane is the product's colour and --ink is the pairing the
     product itself uses (CarSpotter sets black on lime on its own button;
     VINly's ink is its own placeholder.from).

     It is spent as a PLANE and nowhere else. A plane carries its own field,
     so it reads identically in both themes and needs no light/dark fork —
     which is exactly what an accent used as text could not do: #C8FF00 is
     16.9:1 on the dark page and 1.13:1 on the light one. */
  .cs {
    --plane: var(--color-accent);
    --ink: #1F1408;
    position: relative;
  }

  .cs--car-spotter         { --plane: #C8FF00; --ink: #0B0C0E; }  /* CarSpotterArtifact */
  .cs--vinly               { --plane: #EA580C; --ink: #1A120B; }  /* VinlyArtifact */
  .cs--chatobd2            { --plane: #F59E0B; --ink: #1F1408; }  /* VerdictArtifact — check-engine amber */
  .cs--elmulator           { --plane: #0969DA; --ink: #FFFFFF; }  /* ElmulatorArtifact — GitHub blue; it ships on the Marketplace */
  .cs--magtek-platform     { --plane: #1E40AF; --ink: #FFFFFF; }  /* PlatformArtifact */
  .cs--financial-platforms { --plane: #0E1A33; --ink: #FFFFFF; }  /* AdvisorArtifact */

  /* Page-level accent atmosphere — sits behind the header. */
  .cs__header {
    position: relative;
    padding-top: calc(60px + var(--space-8));
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs__header {
      padding-top: calc(64px + var(--space-12));
      padding-bottom: var(--space-10);
    }
  }

  .cs__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
    padding: 6px 0;
    transition: color 150ms, transform 200ms var(--ease-out);
    -webkit-tap-highlight-color: transparent;
  }

  .cs__back:hover {
    color: var(--color-accent);
    transform: translateX(-2px);
  }

  /* Numbered case-study head */
  .cs__sxn {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .cs__sxn-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 22px;
    padding: 0 8px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .cs__sxn-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 4px 10px;
    border-radius: 9999px;
    background-color: var(--color-bg-deep);
    border: 1px solid var(--color-border);
    line-height: 1;
  }


  .cs__sxn-tag--flagship {
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
    border-color: var(--color-accent-muted);
  }

  .cs__sxn-company {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-subtle);
    padding: 4px 10px;
    border-radius: 9999px;
    border: 1px dashed var(--color-border);
    line-height: 1;
  }

  .cs__sxn-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
    min-width: 40px;
  }

  .cs__sxn-meta {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-subtle);
  }

  .cs__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 9vw, 88px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 16ch;
  }

  /* Accent rule under the headline — picks up the project color */

  @media (min-width: 768px) {
    .cs__title {
      line-height: 1.02;
      margin-bottom: var(--space-5);
    }
  }

  .cs__short {
    font-size: clamp(16px, 1.8vw, 21px);
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs__short {
      margin-bottom: var(--space-10);
    }
  }

  .cs__meta {
    margin: 0;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .cs__meta {
      gap: var(--space-12);
      padding-top: var(--space-8);
    }
  }

  .cs__meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs__meta dt {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-subtle);
  }

  .cs__meta dd { margin: 0; }

  .cs__meta ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
  }

  .cs__meta li {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .cs__meta li + li::before {
    content: '·';
    margin-right: 14px;
    color: var(--color-border);
  }

  .cs__meta-text {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .cs__meta-text--status {
    color: var(--color-success);
    font-family: var(--font-body);
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .cs__status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-success);
    box-shadow: 0 0 6px color-mix(in srgb, var(--color-success) 65%, transparent);
    animation: cs-status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes cs-status-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  /* Coming-soon status — muted, not the live green, and no pulse. */
  .cs__meta-text--coming {
    color: var(--color-text-muted);
  }

  .cs__status-dot--coming {
    background-color: var(--color-text-subtle);
    box-shadow: none;
    animation: none;
  }

  /* ── Live-product links: header badge row + closing download band ──── */
  .cs__get {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .cs__get-site {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-muted);
    transition: color 200ms var(--ease-out);
  }
  .cs__get-site:hover { color: var(--color-text); }
  .cs__get-site svg { transition: transform 200ms var(--ease-out); }
  .cs__get-site:hover svg { transform: translate(2px, -2px); }

  .cs__download {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-top: var(--space-12);
    padding: var(--space-7) var(--space-7);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, var(--color-bg-elevated), var(--color-bg-muted));
  }
  .cs__download-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 6px;
  }
  .cs__download-sub {
    font-size: 14px;
    color: var(--color-text-muted);
  }
  .cs__download-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .cs__status-dot { animation: none; }
  }

  /* Outcomes panel */
  .cs__outcomes-wrap {
    padding-top: var(--space-6);
    padding-bottom: var(--space-2);
  }

  @media (min-width: 768px) {
    .cs__outcomes-wrap {
      padding-top: var(--space-8);
    }
  }

  /* The one place the project's colour is spent, and it is spent as a field.
     These are the measurements the work actually produced — they were being
     served as the same elevated stats card every SaaS site ships. The card
     is gone: no border, no radius, no shadow, no gradient, no glow. */
  .cs__outcomes {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--plane);
    color: var(--ink);
    position: relative;
  }

  @media (min-width: 720px) {
    .cs__outcomes {
      padding: var(--space-8);
    }
  }

  .cs__outcomes-head {
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
    z-index: 1;
  }


  .cs__outcomes-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--ink);
  }

  .cs__outcomes-rule {
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.25;
  }

  .cs__outcomes-meta {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--ink);
  }

  .cs__outcomes-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: var(--space-5) var(--space-6);
    position: relative;
    z-index: 1;
  }

  .cs__outcome {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-right: var(--space-2);
  }

  .cs__outcome-value {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.8vw, 32px);
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.1;
    color: var(--ink);
  }

  .cs__outcome-label {
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink);
  }

  .cs__meta .cs__stack {
    gap: 6px;
  }

  .cs__meta .cs__stack li {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    padding: 3px 9px;
    border-radius: 9999px;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    line-height: 1.4;
  }

  .cs__meta .cs__stack li + li::before { content: none; }

  /* Cover frame — wraps the cover image or artifact in a card-style
     container with corner crosshairs matching the project cards. */
  .cs__cover-wrap {
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs__cover-wrap {
      padding-top: var(--space-10);
      padding-bottom: var(--space-12);
    }
  }

  .cs__cover {
    position: relative;
    border-radius: var(--radius-2xl);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: border-color 320ms var(--ease-out), box-shadow 320ms var(--ease-out);
  }

  .cs__cover:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card-hover);
  }

  .cs__cover-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-text-subtle);
    pointer-events: none;
    opacity: 0.4;
    z-index: 4;
    transition: opacity 240ms, border-color 240ms;
  }

  .cs__cover:hover .cs__cover-corner {
    opacity: 1;
    border-color: var(--color-accent);
  }

  .cs__cover-corner--tl { top: 10px; left: 10px; border-right: none; border-bottom: none; }
  .cs__cover-corner--tr { top: 10px; right: 10px; border-left: none; border-bottom: none; }
  .cs__cover-corner--bl { bottom: 10px; left: 10px; border-right: none; border-top: none; }
  .cs__cover-corner--br { bottom: 10px; right: 10px; border-left: none; border-top: none; }

  .cs__cover :global(.placeholder) {
    border-radius: 0;
  }

  .cs__cover-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .cs__cover-artifact {
    position: relative;
    aspect-ratio: 16 / 9;
  }

  .cs__cover-artifact :global(.vart),
  .cs__cover-artifact :global(.vinart),
  .cs__cover-artifact :global(.part),
  .cs__cover-artifact :global(.csart),
  .cs__cover-artifact :global(.aart),
  .cs__cover-artifact :global(.elart) {
    position: absolute;
    inset: 0;
  }

  /* Notes head + content */
  .cs__content {
    padding-bottom: var(--space-12);
  }

  .cs__content-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-6);
  }


  .cs__content-label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
  }

  .cs__content-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
  }

  .cs__visuals {
    padding-bottom: var(--space-16);
  }

  .cs__visuals--feature {
    padding-bottom: var(--space-20);
  }

  /* Inline pull-quote */
  .cs__pull {
    display: grid;
    grid-template-columns: 1px 1fr;
    gap: var(--space-5);
    align-items: start;
    margin: var(--space-12) auto var(--space-12);
    max-width: 720px;
  }

  @media (min-width: 768px) {
    .cs__pull {
      margin: var(--space-16) auto var(--space-12);
    }
  }

  .cs__pull::before {
    content: '';
    width: 1px;
    min-height: 64px;
    background: linear-gradient(to bottom, var(--color-border-strong), transparent 80%);
  }

  .cs__pull-text {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--color-text);
    margin: 0;
    max-width: 28ch;
  }

  .cs__pull-caption {
    grid-column: 2;
    margin-top: var(--space-3);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-subtle);
  }

  /* Numbered post sections */
  .cs__post {
    padding-block: var(--space-12) var(--space-10);
    border-top: 1px solid var(--color-border-subtle);
  }

  @media (min-width: 768px) {
    .cs__post {
      padding-block: var(--space-20) var(--space-16);
    }
  }

  .cs__post--alt {
    background-color: var(--color-bg-muted);
  }

  .cs__post-head {
    max-width: 64ch;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs__post-head {
      margin-bottom: var(--space-10);
    }
  }

  .cs__post-sxn {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-4);
  }


  .cs__post-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
  }

  .cs__post-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
    max-width: 200px;
  }

  .cs__post-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 22ch;
  }

  .cs__post-sub {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .cs__post-closing {
    margin-top: var(--space-10);
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .cs__shot-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 900px) {
    .cs__shot-grid--2 {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (min-width: 720px) {
    .cs__shot-grid--3 {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .cs__shot-grid--3 {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }

  /* Portrait phone screenshots — App Store-style row. Used for VINly. */
  .cs__shot-grid--phones {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
    max-width: 880px;
    margin-inline: auto;
  }

  @media (min-width: 900px) {
    .cs__shot-grid--phones {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
      max-width: none;
    }
  }

  .cs__shot {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cs__shot img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    transition: border-color 320ms var(--ease-out), transform 320ms var(--ease-out), box-shadow 320ms var(--ease-out);
  }

  .cs__shot:hover img {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .cs__shot figcaption {
    font-size: 13px;
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .cs__shot--full {
    max-width: 1100px;
    margin-inline: auto;
  }

  /* Prose */
  .cs__prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .cs__prose :global(h2:first-child) { margin-top: 0; }

  .cs__prose :global(h3) {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .cs__prose :global(p) {
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .cs__prose :global(ul), .cs__prose :global(ol) {
    padding-left: var(--space-6);
    color: var(--color-text-muted);
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.75;
    margin-bottom: var(--space-5);
  }

  .cs__prose :global(li) { margin-bottom: var(--space-2); }

  .cs__prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .cs__prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-10) 0;
  }

  /* Closing footer */
  .cs__footer {
    border-top: 1px solid var(--color-border-subtle);
    padding-block: var(--space-12);
  }

  @media (min-width: 768px) {
    .cs__footer {
      padding-block: var(--space-16);
    }
  }

  /* On mobile, the sticky bottom bar sits over the page. Push the
     closing footer up so its actions remain comfortable to reach
     without overlap. ~80px = bar height (60) + padding (16) + safe-area. */
  @media (max-width: 760px) {
    .cs__footer {
      padding-bottom: calc(var(--space-12) + 80px);
    }
  }

  .cs__next-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-5);
  }


  .cs__next-eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
  }

  .cs__next-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
  }

  /* Per-category accent for the next-project card */
  .cs__next {
  }

  .cs__next {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background:
      linear-gradient(180deg, var(--color-bg-elevated), var(--color-bg-muted));
    text-decoration: none;
    color: var(--color-text);
    margin-bottom: var(--space-8);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    transition:
      border-color 280ms var(--ease-out),
      transform 280ms var(--ease-out),
      box-shadow 280ms var(--ease-out);
    -webkit-tap-highlight-color: transparent;
  }


  @media (min-width: 600px) {
    .cs__next {
      padding: var(--space-7) var(--space-8);
    }
  }

  .cs__next:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .cs__next:hover::before {
    opacity: 1;
  }

  .cs__next-corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-text-subtle);
    pointer-events: none;
    opacity: 0.35;
    transition: opacity 240ms, border-color 240ms;
  }

  .cs__next:hover .cs__next-corner {
    opacity: 1;
    border-color: var(--color-accent);
  }

  .cs__next-corner--tl { top: 8px; left: 8px; border-right: none; border-bottom: none; }
  .cs__next-corner--tr { top: 8px; right: 8px; border-left: none; border-bottom: none; }
  .cs__next-corner--bl { bottom: 8px; left: 8px; border-right: none; border-top: none; }
  .cs__next-corner--br { bottom: 8px; right: 8px; border-left: none; border-top: none; }

  .cs__next-meta {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 1;
  }

  .cs__next-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 4px 10px;
    border-radius: 9999px;
    background-color: var(--color-bg-deep);
    border: 1px solid var(--color-border);
    line-height: 1;
    width: fit-content;
  }


  .cs__next-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .cs__next-short {
    font-size: 14px;
    color: var(--color-text-muted);
    margin-top: 2px;
    max-width: 56ch;
  }

  .cs__next-arrow {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    transition: color 200ms, transform 200ms var(--ease-out);
    z-index: 1;
  }

  .cs__next:hover .cs__next-arrow {
    color: var(--color-accent);
    transform: translateX(6px);
  }

  .cs__footer-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .cs__footer-actions {
      flex-direction: column-reverse;
      align-items: stretch;
    }
  }

  .cs__btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 24px;
    min-height: 48px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: all 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .cs__btn-secondary:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
    background-color: var(--color-bg-muted);
  }

  .cs__btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    min-height: 48px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--color-text);
    text-decoration: none;
    transition: all 200ms var(--ease-out);
    letter-spacing: -0.01em;
    -webkit-tap-highlight-color: transparent;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.5) inset,
      0 6px 16px rgba(0,0,0,0.15);
  }

  .cs__btn-primary svg {
    transition: transform 200ms var(--ease-out);
  }

  .cs__btn-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.5) inset,
      0 12px 28px rgba(0,0,0,0.18),
      0 0 0 4px var(--color-accent-dim);
  }

