---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Placeholder from '@/components/Placeholder.astro';
import ChatOBDFlow from '@/components/diagrams/ChatOBDFlow.astro';
import VerdictCardMock from '@/components/diagrams/VerdictCardMock.astro';
import AdvisorVisual from '@/components/diagrams/AdvisorVisual.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import SchemaArticle from '@/components/seo/SchemaArticle.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('build', ({ data }) => !data.draft);
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data } = project;

const allProjects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const currentIndex = allProjects.findIndex(p => p.slug === project.slug);
const next = allProjects[(currentIndex + 1) % allProjects.length];

const pageUrl = new URL(Astro.url.pathname, Astro.site);
const ogImage = data.coverImage ? new URL(data.coverImage, Astro.site).toString() : undefined;
const ogAlt = data.coverAlt ?? `${data.title} case study by Moe Qadan.`;
---

<BaseLayout
  title={`${data.title}, Case Study by Moe Qadan`}
  description={data.short}
  article={true}
  image={data.coverImage ?? '/og.png'}
  imageAlt={ogAlt}
  keywords={[data.title, data.category, ...data.keyFocus, 'case study', 'product design', 'UX engineering']}
>
  <Fragment slot="head">
    <SchemaArticle
      title={data.title}
      description={data.short}
      url={pageUrl}
      image={ogImage}
      imageAlt={ogAlt}
      category={data.category}
      keywords={data.keyFocus}
    />
    <SchemaBreadcrumb
      items={[
        { name: 'Home', url: new URL('/', Astro.site) },
        { name: 'Work', url: new URL('/work', Astro.site) },
        { name: data.title, url: pageUrl },
      ]}
    />
  </Fragment>

  <ReadingProgress />

  <article class="cs">
    <header class="cs__header">
      <div class="container-site">
        <a href="/work" class="cs__back">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13 8H3M7 12l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          All projects
        </a>

        <div class="cs__category">
          {data.category === 'Flagship'
            ? <span class="cs__flagship">Flagship</span>
            : <span class="cs__category-label">{data.category}</span>}
        </div>

        <h1 class="cs__title">{data.title}</h1>
        <p class="cs__short">{data.short}</p>

        <dl class="cs__meta">
          {data.role && (
            <div>
              <dt>Role</dt>
              <dd><span class="cs__meta-text">{data.role}</span></dd>
            </div>
          )}
          {data.period && (
            <div>
              <dt>Period</dt>
              <dd><span class="cs__meta-text">{data.period}</span></dd>
            </div>
          )}
          {data.company && (
            <div>
              <dt>Company</dt>
              <dd><span class="cs__meta-text">{data.company}</span></dd>
            </div>
          )}
          {data.status && (
            <div>
              <dt>Status</dt>
              <dd><span class="cs__meta-text cs__meta-text--status">{data.status}</span></dd>
            </div>
          )}
          <div>
            <dt>Focus</dt>
            <dd>
              <ul>
                {data.keyFocus.map(item => <li>{item}</li>)}
              </ul>
            </dd>
          </div>
          {data.stack && data.stack.length > 0 && (
            <div>
              <dt>Stack</dt>
              <dd>
                <ul class="cs__stack">
                  {data.stack.map(item => <li>{item}</li>)}
                </ul>
              </dd>
            </div>
          )}
        </dl>
      </div>
    </header>

    {data.outcomes && data.outcomes.length > 0 && (
      <div class="container-site cs__outcomes-wrap">
        <section class="cs__outcomes" aria-label="Outcomes">
          <span class="cs__outcomes-eyebrow">Outcomes</span>
          <ul class="cs__outcomes-list">
            {data.outcomes.map(o => (
              <li class="cs__outcome">
                <span class="cs__outcome-value">{o.value}</span>
                <span class="cs__outcome-label">{o.label}</span>
              </li>
            ))}
          </ul>
        </section>
      </div>
    )}

    <div class="container-site cs__cover">
      {data.coverImage ? (
        <img
          src={data.coverImage}
          alt={data.coverAlt ?? data.title}
          class="cs__cover-image"
          width="1440"
          height="900"
          loading="eager"
        />
      ) : (
        <Placeholder
          from={data.placeholder.from}
          to={data.placeholder.to}
          label={data.placeholder.label}
          sublabel={data.placeholder.sublabel}
          angle={data.placeholder.angle}
          labelTone={data.placeholder.labelTone}
        />
      )}
    </div>

    <div class="container-narrow cs__content">
      <div class="prose cs__prose">
        <Content />
      </div>
    </div>

    {project.slug === 'chatobd2' && (
      <>
        <section class="container-narrow cs__pull">
          <p class="cs__pull-text">
            This is the moment the system stops exposing complexity and starts resolving it.
          </p>
          <span class="cs__pull-caption">From data to decision</span>
        </section>
        <section class="container-site cs__visuals cs__visuals--feature">
          <VerdictCardMock />
          <ChatOBDFlow />
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Marketing surface</span>
            <h2 class="cs__post-title">Same premise, different format.</h2>
            <p class="cs__post-sub">
              The marketing site carries the same product premise into a
              public-facing surface. Same "verdict comes first" instinct,
              same constraint thinking. Designed and built end to end.
              Visual exploration where it helped, hand-written code
              everywhere else.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/longitudinal-intelligence.webp"
                alt="ChatOBD2 marketing site: The only OBD app that learns your car over time. Vehicle health score and trend dashboard."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                The trend view treats ownership as a film, not a snapshot.
                A single scan is a photograph; a car's health is a story.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/pricing-tiers.webp"
                alt="ChatOBD2 pricing page: Free, Pro $9.99/mo, Elite $19.99/mo with feature lists."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Three tiers explained as product, not commerce. The
                struck-through lines on Free make the upgrade story
                literal instead of implied.
              </figcaption>
            </figure>
          </div>
        </section>

        <section class="container-site cs__post cs__post--alt">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Technical depth</span>
            <h2 class="cs__post-title">The system underneath the surface.</h2>
            <p class="cs__post-sub">
              Six deterministic reasoning layers run before every model
              call. The system prompt is composed per scan from a
              38,000-token budget, with P0 sections always making the
              cut and lower-priority sections only landing if budget
              remains. BLE adapter integration. Write operations with
              rollback. The dev surface is treated as a designed product,
              not a wiki. Same care as the user-facing app.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/context-budget.webp"
                alt="ChatOBD2 context budget UI: 38,000 tokens assembled by priority across module sections like Vehicle identity, Behavioral rules, Diagnostic report, etc."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Context budget composed dynamically per scan, keyed by
                verdict tier and code context.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/developer-portal.webp"
                alt="ChatOBD2 developer portal: Under the Hood docs covering Quick Start, System Diagrams, Project Structure, Intelligence Engine, OBD Reference, Design System, Auth, Subscriptions, Edge Function, Mobile Design System."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Developer portal: architecture diagrams, annotated
                project structure, a code-standards doc.
              </figcaption>
            </figure>
          </div>
        </section>
      </>
    )}

    {project.slug === 'magtek-platform' && (
      <>
        <section class="container-site cs__post">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Hardware experience</span>
            <h2 class="cs__post-title">Pattern-driven product pages.</h2>
            <p class="cs__post-sub">
              The hardware portfolio spans card readers, OEM
              components, check scanners, and issuance hardware. Each
              category needed its own surface without forcing buyers
              to relearn the layout.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/magtek/hardware-card-readers.webp"
                alt="MagTek hardware page: Card readers for magstripe, EMV chip, and contactless NFC, with product photography."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>Card readers, magstripe, EMV chip, contactless NFC.</figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/magtek/hardware-oem-components.webp"
                alt="MagTek hardware page: OEM card readers and components for embedded payment and access."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>OEM components for embedded payment and access.</figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/magtek/hardware-check-scanners.webp"
                alt="MagTek hardware page: MICR readers and check scanners for retail and banking."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>MICR readers and check scanners for retail and banking.</figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/magtek/hardware-instant-issuance.webp"
                alt="MagTek hardware page: Issuance and personalization hardware for every program."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>Issuance and personalization hardware for every program.</figcaption>
            </figure>
          </div>
          <p class="cs__post-closing">
            The same template carries every category. Eyebrow, title,
            buyer-facing copy on the left. Product photography on the
            right. Twin CTAs: "Contact Us" and "View products". Below
            the hero, a sticky horizontal sub-nav keeps the four
            hardware categories one click apart with the current
            section highlighted. A buyer who lands on Card readers
            from search can scan adjacent categories without
            round-tripping through the main nav. The product page
            stops being a destination and starts behaving like a
            shop floor.
          </p>
        </section>

        <section class="container-site cs__post cs__post--alt">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Magensa, a MagTek company</span>
            <h2 class="cs__post-title">A subsidiary that needed to feel its own.</h2>
            <p class="cs__post-sub">
              Magensa carries its own product identity inside the
              MagTek family: gateway, eCommerce, tokenization, PIN
              services, reader management. The brief was to keep it
              inside the family without making it feel like the same
              site with a recolored stripe.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/magtek/magensa-pin-services.webp"
                alt="Magensa PIN Services page: Secure PIN Verification and Issuance, with Old Way vs Magensa Way comparison."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Distinct logo lockup, distinct nav (Overview, Gateway,
                eCommerce, Tokenization, Dev &amp; Apps, PIN Services,
                Reader Management, MagCare). Same platform underneath.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/magtek/magensa-pin-services-scrolled.webp"
                alt="Magensa PIN Services page scrolled, showing the compacted sticky header with a Get Started CTA appearing on scroll."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                On scroll the header compacts and surfaces a primary
                "Get Started" CTA. The header earns its way into the
                buyer's attention instead of demanding it on load.
              </figcaption>
            </figure>
          </div>
          <p class="cs__post-closing">
            The "Old Way / Magensa Way" comparison runs across the
            product pages. A visual structure that carries the sales
            argument without paragraphs of marketing copy. The
            subsidiary feels like its own product because it is one,
            and the design treats it that way.
          </p>
        </section>

      </>
    )}

    {project.slug === 'sawa' && (
      <>
        <section class="container-site cs__post">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Earning trust through content</span>
            <h2 class="cs__post-title">Two surfaces that do the convincing.</h2>
            <p class="cs__post-sub">
              A group-decision product has to feel low-friction before
              anyone installs it. The marketing site does that with two
              content surfaces. A live matches feed that shows the
              product in motion. A curated guide section sourced from
              Reddit threads.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/sawa/live-matches.webp"
                alt="Sawa marketing site: Matches Happening Now. A live grid of group dining matches with location, headline, swipe count, and time stamps."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                A live matches feed. Real squads, real restaurants, real
                time. Lets the product make its own case without
                saying "trust us."
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/sawa/city-guides.webp"
                alt="Sawa City Food Guides: real recommendations from real locals, powered by Reddit. Filter pills for All Cities, NYC, Los Angeles, Honolulu, Seattle."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                City Food Guides, sourced from Reddit threads with
                attribution kept intact. Curation as proof that the
                app is built around real places, not just a swipe
                mechanic.
              </figcaption>
            </figure>
          </div>
        </section>

        <section class="container-site cs__post cs__post--alt">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Long-form content and conversion</span>
            <h2 class="cs__post-title">Restaurant pieces double as the install path.</h2>
            <p class="cs__post-sub">
              Each city piece is its own page with its own URL. They
              earn organic traffic, hold the SEO surface for the
              brand, and lead the same reader into the same install
              prompt at the bottom.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/sawa/article.webp"
                alt="Sawa article page: The Apple Pan, Los Angeles, CA (Since 1947). Restaurant feature with hero photography, tags, date, and editorial body."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Article pages live inside the same Sawa shell.
                Hero image, tags, read-time, then long-form. SEO
                surface and brand surface in one.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/sawa/download-cta.webp"
                alt="Sawa final CTA section: Ready to End the Food Fight? With an SMS download form."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                One-number install path. SMS in, app link out. No
                account creation, no profile setup before the user
                has seen the value.
              </figcaption>
            </figure>
          </div>
        </section>
      </>
    )}

    {project.slug === 'financial-platforms' && (
      <>
        <section class="container-site cs__visuals">
          <AdvisorVisual />
        </section>
        <section class="container-site cs__post">
          <header class="cs__post-head">
            <span class="cs__post-eyebrow">Client portals</span>
            <h2 class="cs__post-title">Across major wealth and banking institutions.</h2>
            <p class="cs__post-sub">
              A sample of advisor- and customer-facing portals built
              on InvestCloud's framework. Same underlying platform,
              every implementation adapted to the institution's brand,
              structure, and IA.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--3">
            <figure class="cs__shot">
              <img src="/images/financial-platforms/eastwest-bank.webp" alt="East West Bank homepage." width="1440" height="900" loading="lazy" />
              <figcaption>East West Bank</figcaption>
            </figure>
            <figure class="cs__shot">
              <img src="/images/financial-platforms/voya.webp" alt="Voya homepage." width="1440" height="900" loading="lazy" />
              <figcaption>Voya</figcaption>
            </figure>
            <figure class="cs__shot">
              <img src="/images/financial-platforms/silicon-valley-bank.webp" alt="Silicon Valley Bank homepage." width="1440" height="900" loading="lazy" />
              <figcaption>Silicon Valley Bank</figcaption>
            </figure>
            <figure class="cs__shot">
              <img src="/images/financial-platforms/chase.webp" alt="Chase homepage." width="1440" height="900" loading="lazy" />
              <figcaption>Chase</figcaption>
            </figure>
            <figure class="cs__shot">
              <img src="/images/financial-platforms/cetera.webp" alt="Cetera homepage." width="1440" height="900" loading="lazy" />
              <figcaption>Cetera</figcaption>
            </figure>
            <figure class="cs__shot">
              <img src="/images/financial-platforms/northwestern-mutual.webp" alt="Northwestern Mutual homepage." width="1440" height="900" loading="lazy" />
              <figcaption>Northwestern Mutual</figcaption>
            </figure>
          </div>
        </section>
      </>
    )}

    <footer class="cs__footer">
      <div class="container-site">
        <a
          href={`/work/${next.slug}`}
          class="cs__next"
          data-track="cta_click"
          data-track-cta="next-project"
          data-track-project={next.slug}
          data-track-from={project.slug}
        >
          <div class="cs__next-meta">
            <span class="cs__next-label">Next project</span>
            <span class="cs__next-title">{next.data.title}</span>
            <span class="cs__next-short">{next.data.short}</span>
          </div>
          <span class="cs__next-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <div class="cs__footer-actions">
          <a
            href="/work"
            class="cs__btn-secondary"
            data-track="cta_click"
            data-track-cta="all-projects"
            data-track-loc="case-study-footer"
            data-track-from={project.slug}
          >All projects</a>
          <a
            href="/contact"
            class="cs__btn-primary"
            data-track="cta_click"
            data-track-cta="get-in-touch"
            data-track-loc="case-study-footer"
            data-track-from={project.slug}
          >
            Get in touch
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .cs__header {
    padding-top: calc(60px + var(--space-8));
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .cs__header {
      padding-top: calc(64px + var(--space-12));
      padding-bottom: var(--space-10);
    }
  }

  .cs__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-6);
    padding: 6px 0;
    transition: color 150ms;
    -webkit-tap-highlight-color: transparent;
  }

  .cs__back:hover { color: var(--color-accent); }

  .cs__category {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .cs__flagship {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background-color: var(--color-accent-muted);
    padding: 4px 10px;
    border-radius: 9999px;
  }

  .cs__category-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .cs__title {
    font-family: var(--font-display);
    font-size: clamp(38px, 9vw, 88px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 16ch;
  }

  @media (min-width: 768px) {
    .cs__title {
      line-height: 1.02;
      margin-bottom: var(--space-5);
    }
  }

  .cs__short {
    font-size: clamp(16px, 1.8vw, 21px);
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-6);
  }

  @media (min-width: 768px) {
    .cs__short {
      margin-bottom: var(--space-8);
    }
  }

  .cs__meta {
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .cs__meta {
      gap: var(--space-12);
    }
  }

  .cs__meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs__meta dt {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .cs__meta dd {
    margin: 0;
  }

  .cs__meta ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
  }

  .cs__meta li {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .cs__meta li + li::before {
    content: '·';
    margin-right: 14px;
    color: var(--color-border);
  }

  .cs__meta-text {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .cs__meta-text--status {
    color: var(--color-success);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  /* Outcomes rail — sits below the header, above the cover.
     Even partial / status-flavored outcomes ground the case study
     in evidence. The audit's recommendation: every project earns
