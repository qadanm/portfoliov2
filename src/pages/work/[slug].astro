---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Placeholder from '@/components/Placeholder.astro';
import VerdictArtifact from '@/components/artifacts/VerdictArtifact.astro';
import VinlyArtifact from '@/components/artifacts/VinlyArtifact.astro';
import PlatformArtifact from '@/components/artifacts/PlatformArtifact.astro';
import AdvisorArtifact from '@/components/artifacts/AdvisorArtifact.astro';
import CarSpotterArtifact from '@/components/artifacts/CarSpotterArtifact.astro';
import ElmulatorArtifact from '@/components/artifacts/ElmulatorArtifact.astro';
import ChatOBDFlow from '@/components/diagrams/ChatOBDFlow.astro';
import VerdictCardMock from '@/components/diagrams/VerdictCardMock.astro';
import AdvisorVisual from '@/components/diagrams/AdvisorVisual.astro';
import ReelPipeline from '@/components/diagrams/ReelPipeline.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import CaseStudyMobileBar from '@/components/work/CaseStudyMobileBar.astro';
import AppStoreBadge from '@/components/AppStoreBadge.astro';
import SchemaArticle from '@/components/seo/SchemaArticle.astro';
import SchemaBreadcrumb from '@/components/seo/SchemaBreadcrumb.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('build', ({ data }) => !data.draft);
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data } = project;

const allProjects = (await getCollection('build', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const currentIndex = allProjects.findIndex(p => p.slug === project.slug);
const currentNumber = String(currentIndex + 1).padStart(2, '0');
const totalNumber = String(allProjects.length).padStart(2, '0');
const next = allProjects[(currentIndex + 1) % allProjects.length];

const pageUrl = new URL(Astro.url.pathname, Astro.site);
// Per-case-study OG card — bespoke 1200×630 PNG generated from the
// portfolio's design system. Falls back to default site OG if missing.
const ogImagePath = `/og/${project.slug}.jpg`;
const ogImage = new URL(ogImagePath, Astro.site).toString();
const ogAlt = `${data.title}: case study by Moe Qadan.`;

// Map slugs to bespoke artifact components for the hero preview frame.
const artifactMap: Record<string, any> = {
  'chatobd2': VerdictArtifact,
  'vinly': VinlyArtifact,
  'car-spotter': CarSpotterArtifact,
  'magtek-platform': PlatformArtifact,
  'financial-platforms': AdvisorArtifact,
  'elmulator': ElmulatorArtifact,
};
const Artifact = artifactMap[project.slug] ?? null;
const categoryKey = data.category.toLowerCase();
---

<BaseLayout
  title={`${data.title} Case Study`}
  description={data.short}
  article={true}
  image={ogImagePath}
  imageAlt={ogAlt}
  keywords={[data.title, data.category, ...data.keyFocus, 'case study', 'product design', 'UX engineering']}
>
  <Fragment slot="head">
    <SchemaArticle
      title={data.title}
      description={data.short}
      url={pageUrl}
      image={ogImage}
      imageAlt={ogAlt}
      category={data.category}
      keywords={data.keyFocus}
    />
    <SchemaBreadcrumb
      items={[
        { name: 'Home', url: new URL('/', Astro.site) },
        { name: 'Work', url: new URL('/work', Astro.site) },
        { name: data.title, url: pageUrl },
      ]}
    />
  </Fragment>

  <ReadingProgress />

  <article class:list={['cs', `cs--${project.slug}`, `cs--${categoryKey}`, { 'cs--flagship': data.category === 'Flagship' }]}>
    <header class="cs__header">
      <div class="container-site">
        <a href="/work" class="cs__back">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13 8H3M7 12l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          All projects
        </a>

        {/* Numbered editorial head: project index + category. Mirrors the
            section-head pattern from the homepage grid. */}
        <div class="cs__sxn">
          <span class="cs__sxn-num">{currentNumber} / {totalNumber}</span>
          <span class:list={['cs__sxn-tag', `cs__sxn-tag--${categoryKey}`]}>
            {data.category}
          </span>
          {data.engagement === 'work' && data.company && (
            <span class="cs__sxn-company">
              <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <rect x="1.5" y="3.5" width="9" height="6.5" rx="1" stroke="currentColor" stroke-width="1"/>
                <path d="M4.5 3.5V2.5a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v1" stroke="currentColor" stroke-width="1"/>
              </svg>
              {data.company}
            </span>
          )}
          <span class="cs__sxn-rule" aria-hidden="true"></span>
          <span class="cs__sxn-meta">Case study</span>
        </div>

        <h1 class="cs__title">{data.title}</h1>
        <p class="cs__short">{data.short}</p>

        <dl class="cs__meta">
          {data.role && (
            <div>
              <dt>Role</dt>
              <dd><span class="cs__meta-text">{data.role}</span></dd>
            </div>
          )}
          {data.period && (
            <div>
              <dt>Period</dt>
              <dd><span class="cs__meta-text">{data.period}</span></dd>
            </div>
          )}
          {data.scope && (
            <div>
              <dt>Scope</dt>
              <dd><span class="cs__meta-text">{data.scope}</span></dd>
            </div>
          )}
          {data.status && (
            <div>
              <dt>Status</dt>
              <dd><span class:list={['cs__meta-text', 'cs__meta-text--status', { 'cs__meta-text--coming': data.comingSoon }]}><span class:list={['cs__status-dot', { 'cs__status-dot--coming': data.comingSoon }]} aria-hidden="true"></span>{data.status}</span></dd>
            </div>
          )}
          <div>
            <dt>Focus</dt>
            <dd>
              <ul>
                {data.keyFocus.map(item => <li>{item}</li>)}
              </ul>
            </dd>
          </div>
          {data.stack && data.stack.length > 0 && (
            <div>
              <dt>Stack</dt>
              <dd>
                <ul class="cs__stack">
                  {data.stack.map(item => <li>{item}</li>)}
                </ul>
              </dd>
            </div>
          )}
        </dl>

        {(data.appStoreUrl || data.siteUrl) && (
          <div class="cs__get">
            {data.appStoreUrl && (
              <AppStoreBadge href={data.appStoreUrl} height={44} project={project.slug} cta="case-study-appstore" />
            )}
            {data.siteUrl && (
              <a
                class="cs__get-site"
                href={data.siteUrl}
                target="_blank"
                rel="noopener"
                data-track="cta_click"
                data-track-cta="case-study-site"
                data-track-project={project.slug}
              >
                {new URL(data.siteUrl).hostname}
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            )}
          </div>
        )}
      </div>
    </header>

    {data.outcomes && data.outcomes.length > 0 && (
      <div class="container-site cs__outcomes-wrap">
        <section class="cs__outcomes" aria-label="Outcomes">
          <header class="cs__outcomes-head">
            <span class="cs__outcomes-eyebrow">Outcomes</span>
            <span class="cs__outcomes-rule" aria-hidden="true"></span>
            <span class="cs__outcomes-meta">at a glance</span>
          </header>
          <ul class="cs__outcomes-list">
            {data.outcomes.map(o => (
              <li class="cs__outcome">
                <span class="cs__outcome-value">{o.value}</span>
                <span class="cs__outcome-label">{o.label}</span>
              </li>
            ))}
          </ul>
        </section>
      </div>
    )}

    <div class="container-site cs__cover-wrap">
      <div class="cs__cover">
        <span class="cs__cover-corner cs__cover-corner--tl" aria-hidden="true"></span>
        <span class="cs__cover-corner cs__cover-corner--tr" aria-hidden="true"></span>
        <span class="cs__cover-corner cs__cover-corner--bl" aria-hidden="true"></span>
        <span class="cs__cover-corner cs__cover-corner--br" aria-hidden="true"></span>

        {data.coverImage ? (
          <img
            src={data.coverImage}
            alt={data.coverAlt ?? data.title}
            class="cs__cover-image"
            width="1440"
            height="900"
            loading="eager"
          />
        ) : Artifact ? (
          <div class="cs__cover-artifact">
            <Artifact />
          </div>
        ) : (
          <Placeholder
            from={data.placeholder.from}
            to={data.placeholder.to}
            label={data.placeholder.label}
            sublabel={data.placeholder.sublabel}
            angle={data.placeholder.angle}
            labelTone={data.placeholder.labelTone}
          />
        )}
      </div>
    </div>

    <div class="container-narrow cs__content">
      <div class="cs__content-head">
        <span class="cs__content-label">Notes</span>
        <span class="cs__content-rule" aria-hidden="true"></span>
      </div>
      <div class="prose cs__prose">
        <Content />
      </div>

      {data.appStoreUrl && (
        <aside class="cs__download" aria-label={`Get ${data.title}`}>
          <div class="cs__download-copy">
            <h2 class="cs__download-title">{data.title} is on the App Store.</h2>
            <p class="cs__download-sub">The fastest way to judge the work is to use it.</p>
          </div>
          <div class="cs__download-actions">
            <AppStoreBadge href={data.appStoreUrl} height={48} project={project.slug} cta="case-study-download-cta" />
            {data.siteUrl && (
              <a
                class="cs__get-site"
                href={data.siteUrl}
                target="_blank"
                rel="noopener"
                data-track="cta_click"
                data-track-cta="case-study-download-site"
                data-track-project={project.slug}
              >
                {new URL(data.siteUrl).hostname}
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            )}
          </div>
        </aside>
      )}
    </div>

    {project.slug === 'chatobd2' && (
      <>
        <section class="container-narrow cs__pull">
          <p class="cs__pull-text">
            This is the moment the system stops exposing complexity and starts resolving it.
          </p>
          <span class="cs__pull-caption">From data to decision</span>
        </section>
        <section class="container-site cs__visuals cs__visuals--feature">
          <VerdictCardMock />
          <ChatOBDFlow />
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">Marketing surface</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">Same premise, different format.</h2>
            <p class="cs__post-sub">
              The marketing site carries the same product premise into a
              public-facing surface. Same "verdict comes first" instinct,
              same constraint thinking. Designed and built end to end.
              Visual exploration where it helped, hand-written code
              everywhere else.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/longitudinal-intelligence.webp"
                alt="ChatOBD2 marketing site: The only OBD app that learns your car over time. Vehicle health score and trend dashboard."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                The trend view treats ownership as a film, not a snapshot.
                A single scan is a photograph; a car's health is a story.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/pricing-tiers.webp"
                alt="ChatOBD2 pricing page: Free, Pro $9.99/mo, Elite $19.99/mo with feature lists."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Three tiers explained as product, not commerce. The
                struck-through lines on Free make the upgrade story
                literal instead of implied.
              </figcaption>
            </figure>
          </div>
        </section>

        <section class="container-site cs__post cs__post--alt">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">Technical depth</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">The system underneath the surface.</h2>
            <p class="cs__post-sub">
              Six deterministic reasoning layers run before every model
              call. The system prompt is composed per scan from a
              38,000-token budget, with P0 sections always making the
              cut and lower-priority sections only landing if budget
              remains. BLE adapter integration. Write operations with
              rollback. The dev surface is treated as a designed product,
              not a wiki. Same care as the user-facing app.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--2">
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/context-budget.webp"
                alt="ChatOBD2 context budget UI: 38,000 tokens assembled by priority across module sections like Vehicle identity, Behavioral rules, Diagnostic report, etc."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Context budget composed dynamically per scan, keyed by
                verdict tier and code context.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/chatobd2/developer-portal.webp"
                alt="ChatOBD2 developer portal: Under the Hood docs covering Quick Start, System Diagrams, Project Structure, Intelligence Engine, OBD Reference, Design System, Auth, Subscriptions, Edge Function, Mobile Design System."
                width="1440"
                height="900"
                loading="lazy"
              />
              <figcaption>
                Developer portal: architecture diagrams, annotated
                project structure, a code-standards doc.
              </figcaption>
            </figure>
          </div>
        </section>
      </>
    )}

    {project.slug === 'vinly' && (
      <>
        <section class="container-narrow cs__pull">
          <p class="cs__pull-text">
            It would rather tell you it couldn't read the VIN than look up
            the wrong car.
          </p>
          <span class="cs__pull-caption">Where the trust comes from</span>
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">The record</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">Scan the VIN. Read the record.</h2>
            <p class="cs__post-sub">
              Point the camera at a door jamb and the barcode decodes on
              the phone. What comes back is the car's public safety file,
              read in plain language, free.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--phones">
            <figure class="cs__shot">
              <img
                src="/images/vinly/scan.webp"
                alt="VINly App Store poster: the headline 'Scan any VIN.' over the app's home screen, showing a Scan a VIN button for the door jamb, dashboard or paperwork, a field to type the 17 characters instead, and a Recent list holding a 2024 Ford F-150 and a 2017 Lexus GX."
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                The VIN is the front door, not a form field. Scan the
                barcode, photograph the plate, or type it. Every route ends
                at the same check-digit test before anything is looked up.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/vinly/report.webp"
                alt="VINly App Store poster: the headline 'Research before you go.' over a report for a 2024 Ford F-150 Raptor, VIN 1FTFW1RG1RFA97847, with a dark hero card reading FREE PUBLIC RECORD · U.S. GOVERNMENT DATA, a 'Should you worry?' verdict of Look closer, and caution cards reading no open recalls and 10 injuries reported."
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                The answer comes first, in the buyer's words: should you
                worry. Underneath it, the caution cards say what the
                government actually published and what it doesn't prove.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/vinly/owners.webp"
                alt="VINly App Store poster: the headline 'See what owners report.' over the owners chapter for a 2024 Ford F-150, comparing complaint counts by model year (555 in 2022, 385 in 2023, 179 for this car in 2024, 100 in 2025), then 179 reports broken down into crash, fire and injury mentions and the parts named most often."
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                Complaints only mean something next to the years around
                them. Counts are normalized against volume, so a popular
                model isn't smeared for being popular.
              </figcaption>
            </figure>
          </div>
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">The rest of the file</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">Crash tests, fuel cost, and where to find one.</h2>
            <p class="cs__post-sub">
              Everything the federal government knows about the model, plus
              real cars for sale near you once the research is done.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--phones">
            <figure class="cs__shot">
              <img
                src="/images/vinly/safety.webp"
                alt="VINly App Store poster: the headline 'Check crash-test scores.' over the safety chapter for a 2024 Ford F-150, showing five out of five stars for overall, frontal, side and side pole, four out of five for rollover, the standard crash-avoidance features, and the NHTSA crash-test photograph."
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                Official NCAP scores, with the line that matters kept
                visible: these rate the year and model, not the exact car
                in front of you.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/vinly/fuel.webp"
                alt="VINly App Store poster: the headline 'Know what it costs to drive.' over the fuel chapter for a 2024 Ford F-150, comparing MPG across model years, then an estimated $3,100 a year in fuel at 15,000 miles, with city, highway and combined figures from the EPA."
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                EPA economy turned into the number a buyer actually asks
                for: what this costs to drive for a year.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/vinly/listings.webp"
                alt="VINly App Store poster: the headline 'Find real nearby listings.' over live dealer listings for a 2024 Ford F-150, the first a blue XLT at $47,998 and $8,032 below MSRP with 9,667 miles in Inglewood, California from CarMax, with an Open listing link."
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                Listings are a chapter of the research, not a marketplace
                bolted on. Real dealer inventory, and the link goes to the
                dealer.
              </figcaption>
            </figure>
          </div>
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">The promise</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">Free, and narrow about it.</h2>
            <p class="cs__post-sub">
              VINly charges nothing, holds no account, and shows no ads.
              It is also plain about what it isn't.
            </p>
          </header>
          <div class="cs__shot-grid">
            <figure class="cs__shot">
              <img
                src="/images/vinly/free.webp"
                alt="VINly App Store poster: the app icon over the headline '100% free.' and the line 'No subscription. No account.'"
                width="1080"
                height="2341"
                loading="lazy"
              />
              <figcaption>
                Not a vehicle-history report: no accident record, no title
                or lien check, no odometer verification. It reports what
                the government publishes, and says so rather than letting
                the buyer assume otherwise.
              </figcaption>
            </figure>
          </div>
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">The surface</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">And the site that frames it.</h2>
          </header>
          <div class="cs__shot-grid">
            <figure class="cs__shot">
              <img
                src="/images/vinly/site-hero.webp"
                alt="The VINly marketing site: the headline 'Scan any VIN. Know the car.' over a line explaining the VIN sits on the door jamb, dashboard or paperwork, an App Store button and a Browse cars for sale link, next to a free research tool that takes a year, make and model or a 17-character VIN."
                width="1920"
                height="1125"
                loading="lazy"
              />
              <figcaption>
                Landing page, copy, and the free research tool are also one
                person's work. The site and the phone import the same
                engine, so they can't disagree about a car.
              </figcaption>
            </figure>
          </div>
        </section>
      </>
    )}

    {project.slug === 'car-spotter' && (
      <>
        <section class="container-narrow cs__pull">
          <p class="cs__pull-text">
            One detail. Ten seconds. Then the whole car.
          </p>
          <span class="cs__pull-caption">The moment that hooks you</span>
        </section>

        <section class="container-site cs__post">
          <header class="cs__post-head">
            <div class="cs__post-sxn">
              <span class="cs__post-eyebrow">The Daily 5</span>
              <span class="cs__post-rule" aria-hidden="true"></span>
            </div>
            <h2 class="cs__post-title">A clue, a clock, and four ways to be wrong.</h2>
            <p class="cs__post-sub">
              The loop is built to be felt in under a minute. A cropped detail
              locks into a lime viewfinder, the tachometer drains ten seconds,
              and four arcade buttons wait in the thumb zone. Pick, and the crop
              blooms out to the whole car. Same five for everyone, every day.
            </p>
          </header>
          <div class="cs__shot-grid cs__shot-grid--phones">
            <figure class="cs__shot">
              <img
                src="/images/car-spotter/clue.webp"
                alt="CarSpotter clue screen: a tightly cropped grille inside a lime viewfinder, a draining ten-second tachometer, and four answer buttons: Chevrolet Aveo, Lincoln Aviator, Lincoln MKS, Chrysler 300."
                width="1290"
                height="2796"
                loading="lazy"
              />
              <figcaption>
                The clue: one cropped detail, a ten-second clock, four cars to
                choose from. Tap before the tach hits zero.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/car-spotter/reveal.webp"
                alt="CarSpotter reveal screen: the cropped grille has zoomed out to the full car, a silver Lincoln MKS, named simply 'Lincoln MKS', with a one-line fact about its split-wing grille."
                width="1290"
                height="2796"
                loading="lazy"
              />
              <figcaption>
                The reveal. The crop zooms out to the whole car and the fact
                lands. It's the one second the entire app is built around.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/car-spotter/daily.webp"
                alt="CarSpotter home: a faint wall of car photographs behind a one-day streak and today's finished Daily 5 (833 points, graded A, 'Sharp eye'), with a countdown to tomorrow's set."
                width="1290"
                height="2796"
                loading="lazy"
              />
              <figcaption>
                A fresh Daily 5 every morning, the same five for everyone, and a
                streak to keep alive. Play it and the day resolves to a grade and
                a countdown to the next one.
              </figcaption>
            </figure>
            <figure class="cs__shot">
              <img
                src="/images/car-spotter/combo.webp"
