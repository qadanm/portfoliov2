---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Placeholder from '@/components/Placeholder.astro';
import ChatOBDFlow from '@/components/diagrams/ChatOBDFlow.astro';
import VerdictCardMock from '@/components/diagrams/VerdictCardMock.astro';
import AdvisorVisual from '@/components/diagrams/AdvisorVisual.astro';
import ReadingProgress from '@/components/ReadingProgress.astro';
import Thesis from '@/components/Thesis.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const work = await getCollection('work', ({ data }) => !data.draft);
  return work.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data } = project;

const allWork = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const currentIndex = allWork.findIndex(p => p.slug === project.slug);
const next = allWork[(currentIndex + 1) % allWork.length];
---

<BaseLayout
  title={`${data.title} — Work`}
  description={data.short}
  article={true}
>
  <ReadingProgress />

  <article class="cs">
    <header class="cs__header">
      <div class="container-site">
        <a href="/work" class="cs__back">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M13 8H3M7 12l-4-4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          All work
        </a>

        <div class="cs__category">
          {data.category === 'Flagship'
            ? <span class="cs__flagship">Flagship</span>
            : <span class="cs__category-label">{data.category}</span>}
        </div>

        <h1 class="cs__title">{data.title}</h1>
        <p class="cs__short">{data.short}</p>

        <dl class="cs__meta">
          <div>
            <dt>Focus</dt>
            <dd>
              <ul>
                {data.keyFocus.map(item => <li>{item}</li>)}
              </ul>
            </dd>
          </div>
          {data.stack && data.stack.length > 0 && (
            <div>
              <dt>Stack</dt>
              <dd>
                <ul class="cs__stack">
                  {data.stack.map(item => <li>{item}</li>)}
                </ul>
              </dd>
            </div>
          )}
        </dl>
      </div>
    </header>

    <div class="container-site cs__cover">
      <Placeholder
        from={data.placeholder.from}
        to={data.placeholder.to}
        label={data.placeholder.label}
        sublabel={data.placeholder.sublabel}
        angle={data.placeholder.angle}
        labelTone={data.placeholder.labelTone}
      />
    </div>

    <div class="container-narrow cs__content">
      <div class="prose cs__prose">
        <Content />
      </div>
    </div>

    {project.slug === 'chatobd2' && (
      <>
        <section class="container-narrow">
          <Thesis
            text="This is the moment the system stops exposing complexity and starts resolving it."
            caption="From data to decision"
          />
        </section>
        <section class="container-site cs__visuals cs__visuals--feature">
          <VerdictCardMock />
          <ChatOBDFlow />
        </section>
      </>
    )}

    {project.slug === 'financial-platforms' && (
      <section class="container-site cs__visuals">
        <AdvisorVisual />
      </section>
    )}

    <footer class="cs__footer">
      <div class="container-site">
        <a href={`/work/${next.slug}`} class="cs__next">
          <div class="cs__next-meta">
            <span class="cs__next-label">Next project</span>
            <span class="cs__next-title">{next.data.title}</span>
            <span class="cs__next-short">{next.data.short}</span>
          </div>
          <span class="cs__next-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <div class="cs__footer-actions">
          <a href="/work" class="cs__btn-secondary">All work</a>
          <a href="/contact" class="cs__btn-primary">
            Get in touch
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .cs__header {
    padding-top: calc(64px + var(--space-12));
    padding-bottom: var(--space-10);
  }

  .cs__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: color 150ms;
  }

  .cs__back:hover { color: var(--color-accent); }

  .cs__category {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .cs__flagship {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background-color: var(--color-accent-muted);
    padding: 4px 10px;
    border-radius: 9999px;
  }

  .cs__category-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .cs__title {
    font-family: var(--font-display);
    font-size: clamp(40px, 7vw, 88px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: var(--color-text);
    margin-bottom: var(--space-5);
    max-width: 16ch;
  }

  .cs__short {
    font-size: clamp(17px, 2vw, 21px);
    line-height: 1.55;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-8);
  }

  .cs__meta {
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
    display: flex;
    gap: var(--space-12);
    flex-wrap: wrap;
  }

  .cs__meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cs__meta dt {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .cs__meta dd {
    margin: 0;
  }

  .cs__meta ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
  }

  .cs__meta li {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .cs__meta li + li::before {
    content: '·';
    margin-right: 14px;
    color: var(--color-border);
  }

  .cs__meta .cs__stack {
    gap: 6px;
  }

  .cs__meta .cs__stack li {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    padding: 3px 9px;
    border-radius: 9999px;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    line-height: 1.4;
  }

  .cs__meta .cs__stack li + li::before {
    content: none;
  }

  .cs__cover {
    padding-bottom: var(--space-12);
  }

  .cs__cover :global(.placeholder) {
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .cs__content {
    padding-bottom: var(--space-12);
  }

  .cs__visuals {
    padding-bottom: var(--space-16);
  }

  .cs__visuals--feature {
    padding-bottom: var(--space-20);
  }

  .cs__prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .cs__prose :global(h2:first-child) {
    margin-top: 0;
  }

  .cs__prose :global(h3) {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .cs__prose :global(p) {
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .cs__prose :global(ul), .cs__prose :global(ol) {
    padding-left: var(--space-6);
    color: var(--color-text-muted);
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.75;
    margin-bottom: var(--space-5);
  }

  .cs__prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .cs__prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .cs__prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-10) 0;
  }

  .cs__footer {
    border-top: 1px solid var(--color-border-subtle);
    padding-block: var(--space-12);
  }

  .cs__next {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-7);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background-color: var(--color-bg-elevated);
    text-decoration: none;
    color: var(--color-text);
    margin-bottom: var(--space-8);
    transition:
      border-color 200ms,
      transform 200ms var(--ease-out),
      box-shadow 200ms;
  }

  .cs__next:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 0 0 1px var(--color-accent-muted);
  }

  .cs__next-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs__next-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .cs__next-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .cs__next-short {
    font-size: 14px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .cs__next-arrow {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    transition: color 200ms, transform 200ms;
  }

  .cs__next:hover .cs__next-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  .cs__footer-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .cs__btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 22px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: all 200ms;
  }

  .cs__btn-secondary:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
    background-color: var(--color-bg-muted);
  }

  .cs__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--color-text);
    text-decoration: none;
    transition: all 200ms var(--ease-out);
    letter-spacing: -0.01em;
  }

  .cs__btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }
</style>
