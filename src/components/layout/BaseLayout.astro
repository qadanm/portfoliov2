---
import { ViewTransitions } from 'astro:transitions';
import { themeScript } from '@/utils/theme';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  noindex?: boolean;
}

const {
  title = 'Qadan — UX & Frontend Systems',
  description = 'I build systems that make complex things usable. UX, frontend architecture, and AI-native products.',
  image = '/og-default.png',
  article = false,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Qadan') ? title : `${title} — Qadan`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark light" />

  <script set:html={themeScript} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex" />}

  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:site_name" content="Qadan" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <ViewTransitions />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Moe Qadan",
    "url": Astro.site,
    "jobTitle": "UX Engineer & Platform Systems",
    "description": description,
    "knowsAbout": ["UX Engineering", "Platform Systems", "Design Systems", "ASP.NET MVC", "AI-Native Workflows", "Front-End Architecture"],
  })} />
</head>
<body>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <script is:inline>
    (() => {
      // Guard against re-execution on Astro view transitions.
      // is:inline scripts in body are re-attached on every swap.
      if (window.__siteInit) {
        // Theme is the only thing that needs re-applying after each swap;
        // the listener attached on first init handles it via astro:after-swap.
        // We still need to run reveals for the new page's elements.
        if (typeof window.__siteBindReveals === 'function') {
          window.__siteBindReveals();
        }
        return;
      }
      window.__siteInit = true;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let activeIO = null;

      function bindReveals() {
        const els = document.querySelectorAll('[data-reveal]:not(.is-revealed)');
        if (prefersReduced) {
          els.forEach(el => el.classList.add('is-revealed'));
          return;
        }
        if (!('IntersectionObserver' in window) || els.length === 0) {
          els.forEach(el => el.classList.add('is-revealed'));
          return;
        }
        // Disconnect previous observer to avoid orphaned bindings to swapped DOM.
        if (activeIO) activeIO.disconnect();
        activeIO = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              activeIO.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        els.forEach(el => activeIO.observe(el));
      }
      window.__siteBindReveals = bindReveals;

      function smoothThemeToggle() {
        const html = document.documentElement;
        const observer = new MutationObserver((mutations) => {
          mutations.forEach(m => {
            if (m.attributeName === 'data-theme' && !window.__themeSyncing) {
              html.setAttribute('data-theme-transitioning', 'true');
              clearTimeout(window.__themeTransitionTO);
              window.__themeTransitionTO = setTimeout(() => {
                html.removeAttribute('data-theme-transitioning');
              }, 480);
            }
          });
        });
        observer.observe(html, { attributes: true, attributeFilter: ['data-theme'] });
      }

      function applyStoredTheme() {
        const stored = localStorage.getItem('mq-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        if (document.documentElement.getAttribute('data-theme') !== theme) {
          window.__themeSyncing = true;
          document.documentElement.setAttribute('data-theme', theme);
          requestAnimationFrame(() => { window.__themeSyncing = false; });
        }
      }

      bindReveals();
      smoothThemeToggle();
      applyStoredTheme();
      document.addEventListener('astro:page-load', bindReveals);
      document.addEventListener('astro:after-swap', applyStoredTheme);
    })();
  </script>
</body>
</html>
