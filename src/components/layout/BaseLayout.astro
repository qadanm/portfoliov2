---
import { themeScript } from '@/utils/theme';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  noindex?: boolean;
}

const {
  title = 'Moe Qadan — UX Engineer & Platform Systems',
  description = 'UX engineering and platform systems work at MagTek. Designing and evolving multi-site production environments, component systems, and AI-augmented workflows.',
  image = '/og-default.png',
  article = false,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Moe Qadan') ? title : `${title} — Moe Qadan`;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark light" />

  <script set:html={themeScript} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex" />}

  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:site_name" content="Moe Qadan" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Moe Qadan",
    "url": Astro.site,
    "jobTitle": "UX Engineer & Platform Systems",
    "description": description,
    "knowsAbout": ["UX Engineering", "Platform Systems", "Design Systems", "ASP.NET MVC", "AI-Native Workflows", "Front-End Architecture"],
  })} />
</head>
<body>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
