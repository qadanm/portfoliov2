---
import { ViewTransitions } from 'astro:transitions';
import { themeScript } from '@/utils/theme';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Analytics from '@/components/analytics/Analytics.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  article?: boolean;
  noindex?: boolean;
  keywords?: string[];
  publishedTime?: string;
}

const {
  title = 'Moe Qadan, UX Engineer & Frontend Systems',
  description = "Portfolio of Moe Qadan, a senior UX and frontend practitioner in Los Angeles. UX engineering, frontend systems, design systems, content architecture, accessibility, and AI-assisted product work.",
  image = '/og.jpg',
  imageAlt = 'Moe Qadan, UX Engineer & Frontend Systems. Portfolio of selected work.',
  article = false,
  noindex = false,
  keywords,
  publishedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Qadan') || title.includes('Moe ') ? title : `${title} · Qadan`;
const ogImage = new URL(image, Astro.site).toString();
const ogType = article ? 'article' : 'website';
const ogImageType = image.endsWith('.webp') ? 'image/webp'
  : image.endsWith('.jpg') || image.endsWith('.jpeg') ? 'image/jpeg'
  : 'image/png';

// WebSite schema describes the *site*, not the page — keep its description
// stable across navigations so Google's site card stays coherent.
const SITE_DESCRIPTION = "Portfolio of Moe Qadan, a senior UX and frontend practitioner in Los Angeles. UX engineering, frontend systems, design systems, content architecture, accessibility, and AI-assisted product work.";

const defaultKeywords = [
  'Moe Qadan',
  'Muhammed Qadan',
  'UX engineer',
  'frontend engineer',
  'design engineer',
  'design systems',
  'web experience',
  'creative technologist',
  'AI-assisted product design',
  'Los Angeles',
];
const metaKeywords = (keywords && keywords.length > 0 ? keywords : defaultKeywords).join(', ');

// Person schema — describes professional identity. No availability/job
// signal here on purpose; this stays stable whether or not Moe is open
// to projects.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Moe Qadan',
  alternateName: 'Muhammed Qadan',
  url: Astro.site?.toString(),
  jobTitle: 'UX Engineer & Frontend Systems',
  description: 'UX engineering, frontend systems, and design systems for long-running platforms and AI-native products.',
  knowsAbout: [
    'UX Engineering',
    'Frontend Engineering',
    'Design Systems',
    'Web Experience',
    'Content Architecture',
    'Accessibility',
    'AI-Assisted Product Design',
    'Razor Components',
    'ASP.NET MVC',
    'React',
    'Astro',
    'TypeScript',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Los Angeles',
    addressRegion: 'CA',
    addressCountry: 'US',
  },
  sameAs: [
    'https://linkedin.com/in/mqadan',
    'https://github.com/qadanm',
  ],
};

// WebSite schema with SearchAction is the standard pattern for a site root —
// even without a search box it tells crawlers this is a coherent site, not
// a stack of pages. Description must stay stable per-navigation.
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Qadan',
  alternateName: 'Moe Qadan Portfolio',
  url: Astro.site?.toString(),
  description: SITE_DESCRIPTION,
  publisher: {
    '@type': 'Person',
    name: 'Moe Qadan',
    url: Astro.site?.toString(),
  },
  inLanguage: 'en',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#FAFAF9" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#09090B" media="(prefers-color-scheme: dark)" />

  <script set:html={themeScript} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={metaKeywords} />
  <meta name="author" content="Moe Qadan" />
  <link rel="canonical" href={canonicalURL} />
  {noindex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow, max-image-preview:large" />}

  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content={ogImageType} />
  <meta property="og:image:alt" content={imageAlt} />
  <meta property="og:site_name" content="Qadan" />
  <meta property="og:locale" content="en_US" />
  {article && publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {article && <meta property="article:author" content="Moe Qadan" />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={imageAlt} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

  <ViewTransitions />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <slot name="head" />

  <Analytics />
</head>
<body>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <script is:inline>
    (() => {
      // Guard against re-execution on Astro view transitions.
      // is:inline scripts in body are re-attached on every swap.
      if (window.__siteInit) {
        // Theme is the only thing that needs re-applying after each swap;
        // the listener attached on first init handles it via astro:after-swap.
        // We still need to run reveals for the new page's elements.
        if (typeof window.__siteBindReveals === 'function') {
          window.__siteBindReveals();
        }
        return;
      }
      window.__siteInit = true;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let activeIO = null;

      function bindReveals() {
        const els = document.querySelectorAll('[data-reveal]:not(.is-revealed)');
        if (prefersReduced) {
          els.forEach(el => el.classList.add('is-revealed'));
          return;
        }
        if (!('IntersectionObserver' in window) || els.length === 0) {
          els.forEach(el => el.classList.add('is-revealed'));
          return;
        }
        // Disconnect previous observer to avoid orphaned bindings to swapped DOM.
        if (activeIO) activeIO.disconnect();
        activeIO = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              activeIO.unobserve(entry.target);
            }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
        els.forEach(el => activeIO.observe(el));
      }
      window.__siteBindReveals = bindReveals;

      function smoothThemeToggle() {
        const html = document.documentElement;
        const observer = new MutationObserver((mutations) => {
          mutations.forEach(m => {
            if (m.attributeName === 'data-theme' && !window.__themeSyncing) {
              html.setAttribute('data-theme-transitioning', 'true');
              clearTimeout(window.__themeTransitionTO);
              window.__themeTransitionTO = setTimeout(() => {
                html.removeAttribute('data-theme-transitioning');
              }, 480);
            }
          });
        });
        observer.observe(html, { attributes: true, attributeFilter: ['data-theme'] });
      }

      function applyStoredTheme() {
        const stored = localStorage.getItem('mq-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        if (document.documentElement.getAttribute('data-theme') !== theme) {
          window.__themeSyncing = true;
          document.documentElement.setAttribute('data-theme', theme);
          requestAnimationFrame(() => { window.__themeSyncing = false; });
        }
      }

      // Live update when the OS color scheme changes — but only when the
      // visitor hasn't manually overridden the theme.
      function bindSystemSchemeListener() {
        const mq = window.matchMedia('(prefers-color-scheme: dark)');
        const handler = (e) => {
          if (localStorage.getItem('mq-theme')) return;
          const theme = e.matches ? 'dark' : 'light';
          if (document.documentElement.getAttribute('data-theme') !== theme) {
            document.documentElement.setAttribute('data-theme', theme);
          }
        };
        if (typeof mq.addEventListener === 'function') {
          mq.addEventListener('change', handler);
        } else {
          // Safari < 14 fallback
          mq.addListener(handler);
        }
      }

      bindReveals();
      smoothThemeToggle();
      applyStoredTheme();
      bindSystemSchemeListener();
      document.addEventListener('astro:page-load', bindReveals);
      document.addEventListener('astro:after-swap', applyStoredTheme);
    })();
  </script>
</body>
</html>
