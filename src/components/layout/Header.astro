---
const pathname = Astro.url.pathname;

const nav = [
  { href: '/work', label: 'Work', sub: 'Selected projects and case studies.' },
  { href: '/approach', label: 'Approach', sub: 'How I design, build, and use AI.' },
  { href: '/about', label: 'About', sub: 'Background and how I think.' },
  { href: '/contact', label: 'Contact', sub: 'Open to hearing about projects.' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header" id="site-header" transition:persist>
  <div class="container-site header-inner">
    <a href="/" class="logo" aria-label="Qadan, Home">
      <span class="logo-name">Qadan</span>
      <span class="logo-dot" aria-hidden="true">.</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary navigation">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a
        href="/contact"
        class="status-pill"
        aria-label="Open to hearing about projects, go to contact"
        title="Open to hearing about new projects"
      >
        <span class="status-pill__dot" aria-hidden="true"></span>
        <span class="status-pill__text">Open to projects</span>
      </a>

      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle color theme"
        title="Toggle theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M18.66 5.34l-1.41 1.41"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button
        class="nav-mobile-toggle"
        id="mobile-menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span class="hamburger" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="nav-mobile-backdrop" id="mobile-nav-backdrop" aria-hidden="true"></div>
  <div class="nav-mobile" id="mobile-nav" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Site navigation">
    <nav class="nav-mobile__inner" aria-label="Mobile navigation">
      <span class="nav-mobile__eyebrow">
        <span class="nav-mobile__status">
          <span class="status-pill__dot" aria-hidden="true"></span>
          Open to hearing about projects
        </span>
      </span>
      <ul class="nav-mobile__list">
        {nav.map((item, i) => (
          <li>
            <a
              href={item.href}
              class:list={['nav-mobile-link', { 'nav-mobile-link--active': isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
              style={`--i: ${i}`}
            >
              <span class="nav-mobile-link__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="nav-mobile-link__body">
                <span class="nav-mobile-link__label">{item.label}</span>
                <span class="nav-mobile-link__sub">{item.sub}</span>
              </span>
              <span class="nav-mobile-link__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="nav-mobile__foot">
        <a
          href="mailto:moe@qadan.co"
          class="nav-mobile__email"
          data-track="contact_click"
          data-track-channel="email"
          data-track-loc="mobile-nav"
        >moe@qadan.co</a>
        <span class="nav-mobile__sig">© Moe Qadan</span>
      </div>
    </nav>
  </div>
</header>

<script>
  import { THEME_KEY } from '@/utils/theme';

  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function getTheme() {
    const attr = html.getAttribute('data-theme');
    if (attr === 'dark' || attr === 'light') return attr;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function setTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    localStorage.setItem(THEME_KEY, theme);
  }

  toggle?.addEventListener('click', () => {
    const from = getTheme();
    const to = from === 'dark' ? 'light' : 'dark';
    setTheme(to);
    if (typeof window.plausible === 'function') {
      window.plausible('theme_toggle', { props: { from, to } });
    }
  });

  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  const mobileBackdrop = document.getElementById('mobile-nav-backdrop');
  const body = document.body;

  function isMenuOpen() {
    return mobileToggle?.getAttribute('aria-expanded') === 'true';
  }

  function lockScroll() {
    const scrollY = window.scrollY;
    body.dataset.scrollLock = String(scrollY);
    body.style.position = 'fixed';
    body.style.top = `-${scrollY}px`;
    body.style.left = '0';
    body.style.right = '0';
    body.style.width = '100%';
  }

  function unlockScroll() {
    const scrollY = parseInt(body.dataset.scrollLock || '0', 10);
    body.style.position = '';
    body.style.top = '';
    body.style.left = '';
    body.style.right = '';
    body.style.width = '';
    delete body.dataset.scrollLock;
    if (scrollY) window.scrollTo(0, scrollY);
  }

  function openMenu() {
    mobileToggle?.setAttribute('aria-expanded', 'true');
    mobileToggle?.setAttribute('aria-label', 'Close menu');
    mobileNav?.setAttribute('aria-hidden', 'false');
    mobileBackdrop?.setAttribute('aria-hidden', 'false');
    mobileNav?.classList.add('nav-mobile--open');
    mobileBackdrop?.classList.add('nav-mobile-backdrop--open');
    mobileToggle?.classList.add('is-open');
    lockScroll();
    if (typeof window.plausible === 'function') {
      window.plausible('nav_open', { props: { page: location.pathname } });
    }
  }

  function closeMenu() {
    if (!isMenuOpen()) return;
    mobileToggle?.setAttribute('aria-expanded', 'false');
    mobileToggle?.setAttribute('aria-label', 'Open menu');
    mobileNav?.setAttribute('aria-hidden', 'true');
    mobileBackdrop?.setAttribute('aria-hidden', 'true');
    mobileNav?.classList.remove('nav-mobile--open');
    mobileBackdrop?.classList.remove('nav-mobile-backdrop--open');
    mobileToggle?.classList.remove('is-open');
    unlockScroll();
  }

  mobileToggle?.addEventListener('click', () => {
    if (isMenuOpen()) closeMenu(); else openMenu();
  });

  mobileBackdrop?.addEventListener('click', closeMenu);

  mobileNav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen()) {
      closeMenu();
      mobileToggle?.focus();
    }
  });

  const desktopMQ = window.matchMedia('(min-width: 768px)');
  const onMQChange = (e: MediaQueryListEvent | MediaQueryList) => {
    if (e.matches && isMenuOpen()) closeMenu();
  };
  if (typeof desktopMQ.addEventListener === 'function') {
    desktopMQ.addEventListener('change', onMQChange);
  } else {
    desktopMQ.addListener(onMQChange);
  }

  document.addEventListener('astro:before-swap', closeMenu);

  const header = document.getElementById('site-header');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 32) {
      header?.classList.add('header--scrolled');
    } else {
      header?.classList.remove('header--scrolled');
    }
  }, { passive: true });

  function syncActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.nav-link, .nav-mobile-link').forEach(link => {
      const href = link.getAttribute('href') || '';
      const active = href === '/' ? path === '/' : path.startsWith(href);
      link.classList.toggle('nav-link--active', active && link.classList.contains('nav-link'));
      link.classList.toggle('nav-mobile-link--active', active && link.classList.contains('nav-mobile-link'));
      if (active) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  document.addEventListener('astro:page-load', syncActiveNav);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background-color 250ms ease, border-color 250ms ease, backdrop-filter 250ms ease;
  }

  .header--scrolled {
    background-color: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 12px;
  }

  @media (min-width: 768px) {
    .header-inner {
      height: 64px;
      gap: 24px;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.02em;
    transition: color 150ms;
    padding-block: 8px;
  }

  .logo:hover { color: var(--color-accent); }

  .logo-dot {
    color: var(--color-accent);
    margin-left: 1px;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .nav-desktop { display: flex; }
  }

  .nav-link {
    padding: 6px 14px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms, background-color 150ms;
    letter-spacing: -0.01em;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-bg-muted);
  }

  .nav-link--active {
    color: var(--color-text);
    background-color: var(--color-bg-muted);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* "Open to projects" pill — soft availability signal that doesn't read as job-hunting */
  .status-pill {
    display: none;
    align-items: center;
    gap: 6px;
    padding: 5px 10px 5px 9px;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-success);
    background-color: color-mix(in srgb, var(--color-success) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-success) 28%, transparent);
    text-decoration: none;
    transition: background-color 150ms, border-color 150ms, transform 150ms var(--ease-out);
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 600px) {
    .status-pill { display: inline-flex; }
  }

  .status-pill:hover {
    background-color: color-mix(in srgb, var(--color-success) 14%, transparent);
    border-color: color-mix(in srgb, var(--color-success) 50%, transparent);
    transform: translateY(-1px);
  }

  .status-pill__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-success);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-success) 65%, transparent);
    animation: status-pulse 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-pill__dot { animation: none; }
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 150ms;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }

  .icon-moon { display: none; }

  :global([data-theme="dark"]) .icon-sun { display: none; }
  :global([data-theme="dark"]) .icon-moon { display: block; }

  .nav-mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    transition: all 150ms;
    -webkit-tap-highlight-color: transparent;
    position: relative;
    z-index: 102;
  }

  @media (min-width: 768px) {
    .nav-mobile-toggle { display: none; }
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 18px;
    height: 1.5px;
    background-color: var(--color-text);
    border-radius: 9999px;
    transition: all 220ms var(--ease-out);
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
  }

  .hamburger::before { top: -6px; }
  .hamburger::after { top: 6px; }

  .is-open .hamburger { background-color: transparent; }
  .is-open .hamburger::before { transform: rotate(45deg); top: 0; }
  .is-open .hamburger::after { transform: rotate(-45deg); top: 0; }

  .nav-mobile-backdrop {
    position: fixed;
    inset: 0;
    background-color: color-mix(in srgb, var(--color-bg) 70%, transparent);
    backdrop-filter: blur(8px) saturate(120%);
    -webkit-backdrop-filter: blur(8px) saturate(120%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 240ms var(--ease-out);
    z-index: 99;
  }

  .nav-mobile-backdrop--open {
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .nav-mobile-backdrop { display: none !important; }
  }

  .nav-mobile {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 100dvh;
    height: 100vh;
    background-color: var(--color-bg);
    z-index: 101;
    transform: translateY(-100%);
    transition: transform 360ms var(--ease-out);
    overflow-y: auto;
    overscroll-behavior: contain;
    padding-top: 60px;
    -webkit-overflow-scrolling: touch;
  }

  .nav-mobile--open {
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .nav-mobile { display: none !important; }
  }

  .nav-mobile__inner {
    display: flex;
    flex-direction: column;
    min-height: calc(100dvh - 60px);
    padding: 24px 24px 32px;
  }

  .nav-mobile__eyebrow {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border-subtle);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 280ms var(--ease-out) 80ms, transform 280ms var(--ease-out) 80ms;
  }

  .nav-mobile--open .nav-mobile__eyebrow {
    opacity: 1;
    transform: none;
  }

  .nav-mobile__status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-success);
  }

  .nav-mobile__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .nav-mobile__list li {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .nav-mobile__list li:last-child {
    border-bottom: none;
  }

  .nav-mobile-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 18px 4px;
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-out), padding-left var(--duration-base) var(--ease-out);
    opacity: 0;
    transform: translateY(12px);
    -webkit-tap-highlight-color: transparent;
    min-height: 64px;
  }

  .nav-mobile--open .nav-mobile-link {
    animation: navLinkRise 420ms var(--ease-out) forwards;
    animation-delay: calc(120ms + var(--i, 0) * 60ms);
  }

  @keyframes navLinkRise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-mobile-link__num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-text-subtle);
    width: 22px;
    line-height: 1;
  }

  .nav-mobile-link__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .nav-mobile-link__label {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-text);
  }

  .nav-mobile-link__sub {
    font-size: 13px;
    line-height: 1.4;
    color: var(--color-text-subtle);
  }

  .nav-mobile-link__arrow {
    color: var(--color-text-subtle);
    font-size: 20px;
    line-height: 1;
    transition: color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }

  .nav-mobile-link:hover .nav-mobile-link__label,
  .nav-mobile-link:active .nav-mobile-link__label {
    color: var(--color-accent);
  }

  .nav-mobile-link:hover .nav-mobile-link__arrow,
  .nav-mobile-link:active .nav-mobile-link__arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  .nav-mobile-link--active .nav-mobile-link__num,
  .nav-mobile-link--active .nav-mobile-link__arrow {
    color: var(--color-accent);
  }

  .nav-mobile-link--active .nav-mobile-link__label {
    color: var(--color-accent);
  }

  .nav-mobile__foot {
    margin-top: auto;
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 320ms var(--ease-out) 380ms, transform 320ms var(--ease-out) 380ms;
  }

  .nav-mobile--open .nav-mobile__foot {
    opacity: 1;
    transform: none;
  }

  .nav-mobile__email {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 8px;
    transition: color 150ms, border-color 150ms;
    -webkit-tap-highlight-color: transparent;
  }

  .nav-mobile__email:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .nav-mobile__sig {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-subtle);
    letter-spacing: 0.06em;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-mobile {
      transition: none;
    }
    .nav-mobile-backdrop {
      transition: none;
    }
    .nav-mobile--open .nav-mobile-link {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .nav-mobile__eyebrow,
    .nav-mobile__foot {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
