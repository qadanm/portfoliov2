---
const pathname = Astro.url.pathname;

const nav = [
  { href: '/build', label: 'Build' },
  { href: '/design', label: 'Design' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header" id="site-header" transition:persist>
  <div class="container-site header-inner">
    <a href="/" class="logo" aria-label="Qadan — Home">
      <span class="logo-name">Qadan</span>
      <span class="logo-dot" aria-hidden="true">.</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary navigation">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle color theme"
        title="Toggle theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M18.66 5.34l-1.41 1.41"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button class="nav-mobile-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div class="nav-mobile" id="mobile-nav" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={['nav-mobile-link', { 'nav-mobile-link--active': isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  import { THEME_KEY } from '@/utils/theme';

  const toggle = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function getTheme() {
    const attr = html.getAttribute('data-theme');
    if (attr === 'dark' || attr === 'light') return attr;
    // Fallback to system preference when no attribute is set yet.
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function setTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    localStorage.setItem(THEME_KEY, theme);
  }

  toggle?.addEventListener('click', () => {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });

  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  function isMenuOpen() {
    return mobileToggle?.getAttribute('aria-expanded') === 'true';
  }

  function openMenu() {
    mobileToggle?.setAttribute('aria-expanded', 'true');
    mobileNav?.setAttribute('aria-hidden', 'false');
    mobileNav?.classList.add('nav-mobile--open');
    mobileToggle?.classList.add('is-open');
  }

  function closeMenu() {
    mobileToggle?.setAttribute('aria-expanded', 'false');
    mobileNav?.setAttribute('aria-hidden', 'true');
    mobileNav?.classList.remove('nav-mobile--open');
    mobileToggle?.classList.remove('is-open');
  }

  mobileToggle?.addEventListener('click', () => {
    if (isMenuOpen()) closeMenu(); else openMenu();
  });

  mobileNav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isMenuOpen()) {
      closeMenu();
      mobileToggle?.focus();
    }
  });

  // Close when resizing past the desktop breakpoint
  const desktopMQ = window.matchMedia('(min-width: 768px)');
  const onMQChange = (e: MediaQueryListEvent | MediaQueryList) => {
    if (e.matches && isMenuOpen()) closeMenu();
  };
  if (typeof desktopMQ.addEventListener === 'function') {
    desktopMQ.addEventListener('change', onMQChange);
  } else {
    // Safari < 14 fallback
    desktopMQ.addListener(onMQChange);
  }

  // Close before view-transition swap (covers browser back/forward too)
  document.addEventListener('astro:before-swap', closeMenu);

  const header = document.getElementById('site-header');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header?.classList.add('header--scrolled');
    } else {
      header?.classList.remove('header--scrolled');
    }
  }, { passive: true });

  function syncActiveNav() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.nav-link, .nav-mobile-link').forEach(link => {
      const href = link.getAttribute('href') || '';
      const active = href === '/' ? path === '/' : path.startsWith(href);
      link.classList.toggle('nav-link--active', active && link.classList.contains('nav-link'));
      link.classList.toggle('nav-mobile-link--active', active && link.classList.contains('nav-mobile-link'));
      if (active) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  document.addEventListener('astro:page-load', syncActiveNav);
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background-color 250ms ease, border-color 250ms ease, backdrop-filter 250ms ease;
  }

  .header--scrolled {
    background-color: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.02em;
    transition: color 150ms;
  }

  .logo:hover { color: var(--color-accent); }

  .logo-dot {
    color: var(--color-accent);
    margin-left: 1px;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .nav-desktop { display: flex; }
  }

  .nav-link {
    padding: 6px 14px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms, background-color 150ms;
    letter-spacing: -0.01em;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-bg-muted);
  }

  .nav-link--active {
    color: var(--color-text);
    background-color: var(--color-bg-muted);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 150ms;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }

  .icon-moon { display: none; }

  :global([data-theme="dark"]) .icon-sun { display: none; }
  :global([data-theme="dark"]) .icon-moon { display: block; }

  .nav-mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    transition: all 150ms;
  }

  @media (min-width: 768px) {
    .nav-mobile-toggle { display: none; }
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 16px;
    height: 1.5px;
    background-color: var(--color-text-muted);
    border-radius: 9999px;
    transition: all 200ms;
    position: relative;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
  }

  .hamburger::before { top: -5px; }
  .hamburger::after { top: 5px; }

  .is-open .hamburger { background-color: transparent; }
  .is-open .hamburger::before { transform: rotate(45deg); top: 0; }
  .is-open .hamburger::after { transform: rotate(-45deg); top: 0; }

  .nav-mobile {
    display: flex;
    flex-direction: column;
    padding: 12px 24px 20px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      max-height 360ms var(--ease-out),
      opacity 240ms var(--ease-out),
      padding 360ms var(--ease-out);
  }

  .nav-mobile--open {
    max-height: 480px;
    opacity: 1;
    pointer-events: auto;
  }

  @media (min-width: 768px) {
    .nav-mobile { display: none !important; }
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-subtle);
    transition: color var(--duration-base) var(--ease-out), padding-left var(--duration-base) var(--ease-out);
    opacity: 0;
    transform: translateY(8px);
  }

  .nav-mobile--open .nav-mobile-link {
    animation: navLinkRise 360ms var(--ease-out) forwards;
  }

  .nav-mobile--open .nav-mobile-link:nth-child(1) { animation-delay: 60ms; }
  .nav-mobile--open .nav-mobile-link:nth-child(2) { animation-delay: 120ms; }
  .nav-mobile--open .nav-mobile-link:nth-child(3) { animation-delay: 180ms; }
  .nav-mobile--open .nav-mobile-link:nth-child(4) { animation-delay: 240ms; }

  @keyframes navLinkRise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-mobile-link::after {
    content: '→';
    color: var(--color-text-subtle);
    font-size: 16px;
    transition: transform var(--duration-base) var(--ease-out), color var(--duration-base) var(--ease-out);
  }

  .nav-mobile-link:hover {
    color: var(--color-text);
  }

  .nav-mobile-link:hover::after {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  .nav-mobile-link:last-child { border-bottom: none; }

  .nav-mobile-link--active {
    color: var(--color-text);
  }

  .nav-mobile-link--active::after {
    color: var(--color-accent);
  }
</style>
