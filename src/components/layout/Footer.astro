---
const year = new Date().getFullYear();

const links = [
  { href: 'https://linkedin.com/in/muhammedqadan', label: 'LinkedIn', external: true },
  { href: 'https://github.com/muhammedqadan', label: 'GitHub', external: true },
  { href: 'mailto:muhammedqadan@outlook.com', label: 'Email', external: false },
];
---

<footer class="site-footer">
  <div class="container-site footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo">Qadan<span class="footer-logo-dot">.</span></a>
      <p class="footer-tagline">
        Product design, UX engineering, AI-native systems.
      </p>
    </div>

    <div class="footer-right">
      <nav class="footer-nav" aria-label="Footer navigation">
        {links.map(link => (
          <a
            href={link.href}
            class="footer-link"
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
            {link.external && (
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" style="display:inline;margin-left:2px;opacity:0.5">
                <path d="M3 1h6v6M9 1 1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
        ))}
      </nav>
      <p class="footer-copy">© {year} Moe Qadan</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-12);
    margin-top: var(--space-24);
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .footer-logo {
    display: inline-block;
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
    transition: color 150ms;
  }

  .footer-logo:hover { color: var(--color-accent); }
  .footer-logo-dot { color: var(--color-accent); }

  .footer-tagline {
    font-size: 13px;
    color: var(--color-text-subtle);
    line-height: 1.5;
    max-width: 280px;
    margin-top: 4px;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
  }

  .footer-nav {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms;
  }

  .footer-link:hover { color: var(--color-accent); }

  .footer-copy {
    font-size: 12px;
    color: var(--color-text-subtle);
  }

  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; gap: var(--space-6); }
    .footer-right { align-items: flex-start; }
  }
</style>
