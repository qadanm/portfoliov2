---
interface Props {
  text: string;
  caption?: string;
}

const { text, caption } = Astro.props;
---

<aside class="thesis" data-reveal>
  <span class="thesis__rule" aria-hidden="true"></span>
  <p class="thesis__text">{text}</p>
  {caption && <span class="thesis__caption">{caption}</span>}
</aside>

<style>
  .thesis {
    margin: var(--space-16) auto var(--space-12);
    padding: 0;
    max-width: 720px;
    text-align: left;
    display: grid;
    grid-template-columns: 1px 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  .thesis__rule {
    width: 1px;
    height: 100%;
    min-height: 64px;
    background: linear-gradient(to bottom, var(--color-accent), transparent 80%);
  }

  .thesis__text {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--color-text);
    margin: 0;
    max-width: 28ch;
  }

  .thesis__caption {
    grid-column: 2;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  @media (min-width: 768px) {
    .thesis {
      margin: var(--space-20) auto var(--space-16);
    }
  }
</style>
