---
// ChatOBD2 thumbnail. Theme-aware: dark amber atmosphere in dark mode,
// warm off-white atmosphere in light mode. Both keep the amber accent
// signature so the project identity reads at a glance.
---

<div class="vart" aria-hidden="true">
  <div class="vart__bg"></div>
  <div class="vart__grid"></div>
  <div class="vart__halo"></div>

  <div class="vart__plate">
    <div class="vart__head">
      <div class="vart__brand">
        <span class="vart__brand-mark">CO</span>
        <span class="vart__brand-name">ChatOBD-2</span>
      </div>
      <span class="vart__head-mono">Scan #2419</span>
    </div>

    <div class="vart__body">
      <div class="vart__verdict">
        <span class="vart__verdict-tag">
          <span class="vart__verdict-dot"></span>
          Safe to drive
        </span>
      </div>
      <div class="vart__title">Catalyst efficiency is below the threshold</div>

      <div class="vart__row">
        <span class="vart__row-label">Confidence</span>
        <div class="vart__bar">
          <span class="vart__bar-fill"></span>
        </div>
        <span class="vart__row-value">82%</span>
      </div>

      <div class="vart__codes">
        <span class="vart__chip vart__chip--accent">P0420</span>
        <span class="vart__chip">Toyota Prius</span>
        <span class="vart__chip">2010</span>
      </div>
    </div>
  </div>

  <div class="vart__caption">
    <span class="vart__caption-line"></span>
    <span>Verdict surface · ChatOBD-2</span>
  </div>
</div>

<style>
  /* Theme-aware tokens. Default = dark; light overrides via global theme. */
  .vart {
    /* Background atmosphere */
    --vart-atmos:
      radial-gradient(ellipse 80% 80% at 30% 20%, rgba(245, 158, 11, 0.10), transparent 60%),
      radial-gradient(ellipse 60% 60% at 80% 90%, rgba(245, 158, 11, 0.05), transparent 60%),
      linear-gradient(155deg, #0F0E12 0%, #1A1812 60%, #0B0A0E 100%);
    --vart-text: #FAFAFA;
    --vart-text-muted: rgba(255, 255, 255, 0.55);
    --vart-text-subtle: rgba(255, 255, 255, 0.45);
    --vart-grid: rgba(255, 255, 255, 0.025);
    --vart-dot-1: rgba(245, 158, 11, 0.04);
    --vart-dot-2: rgba(255, 255, 255, 0.03);
    --vart-halo: radial-gradient(circle, rgba(245, 158, 11, 0.18), transparent 65%);
    /* Plate */
    --vart-plate-bg: linear-gradient(180deg, rgba(28, 26, 32, 0.92), rgba(18, 16, 22, 0.94));
    --vart-plate-border: rgba(255, 255, 255, 0.08);
    --vart-plate-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 16px 32px rgba(0, 0, 0, 0.4),
      0 4px 12px rgba(0, 0, 0, 0.3);
    --vart-divider: rgba(255, 255, 255, 0.06);
    --vart-chip-bg: rgba(255, 255, 255, 0.04);
    --vart-chip-border: rgba(255, 255, 255, 0.06);
    --vart-chip-text: rgba(255, 255, 255, 0.7);
    --vart-bar-track: rgba(255, 255, 255, 0.08);
    --vart-caption: rgba(255, 255, 255, 0.45);
    --vart-caption-rule: rgba(255, 255, 255, 0.3);
  }

  :global([data-theme="light"]) .vart {
    --vart-atmos:
      radial-gradient(ellipse 80% 80% at 30% 20%, rgba(245, 158, 11, 0.10), transparent 60%),
      radial-gradient(ellipse 60% 60% at 80% 90%, rgba(245, 158, 11, 0.05), transparent 60%),
      linear-gradient(155deg, #FFFBF3 0%, #FFF6E4 60%, #FFFCF5 100%);
    --vart-text: #1F1408;
    --vart-text-muted: rgba(31, 20, 8, 0.62);
    --vart-text-subtle: rgba(31, 20, 8, 0.5);
    --vart-grid: rgba(31, 20, 8, 0.04);
    --vart-dot-1: rgba(217, 119, 6, 0.07);
    --vart-dot-2: rgba(31, 20, 8, 0.04);
    --vart-halo: radial-gradient(circle, rgba(245, 158, 11, 0.22), transparent 65%);
    --vart-plate-bg: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 243, 0.94));
    --vart-plate-border: rgba(31, 20, 8, 0.08);
    --vart-plate-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 1px 2px rgba(31, 20, 8, 0.04),
      0 16px 32px rgba(31, 20, 8, 0.08),
      0 4px 12px rgba(31, 20, 8, 0.04);
    --vart-divider: rgba(31, 20, 8, 0.06);
    --vart-chip-bg: rgba(31, 20, 8, 0.04);
    --vart-chip-border: rgba(31, 20, 8, 0.07);
    --vart-chip-text: rgba(31, 20, 8, 0.65);
    --vart-bar-track: rgba(31, 20, 8, 0.08);
    --vart-caption: rgba(31, 20, 8, 0.5);
    --vart-caption-rule: rgba(31, 20, 8, 0.25);
  }

  .vart {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--vart-atmos);
    color: var(--vart-text);
    container-type: inline-size;
  }

  .vart__bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(var(--vart-dot-1) 1px, transparent 1px),
      radial-gradient(var(--vart-dot-2) 1px, transparent 1px);
    background-size: 14px 14px, 32px 32px;
    background-position: 0 0, 7px 7px;
  }

  .vart__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--vart-grid) 1px, transparent 1px),
      linear-gradient(to bottom, var(--vart-grid) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(180deg, transparent 0%, #000 50%);
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 50%);
  }

  .vart__halo {
    position: absolute;
    top: -10%;
    right: -20%;
    width: 60%;
    height: 60%;
    border-radius: 50%;
    background: var(--vart-halo);
    filter: blur(20px);
    pointer-events: none;
  }

  .vart__plate {
    position: absolute;
    left: 8%;
    right: 8%;
    top: 56%;
    transform: translateY(-50%);
    border: 1px solid var(--vart-plate-border);
    border-radius: 12px;
    background: var(--vart-plate-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: var(--vart-plate-shadow);
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  @container (min-width: 360px) {
    .vart__plate {
      padding: 16px 18px 18px;
      gap: 12px;
    }
  }

  .vart__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--vart-divider);
  }

  .vart__brand {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .vart__brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: linear-gradient(180deg, #F59E0B, #B45309);
    color: #1F1408;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .vart__brand-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--vart-text);
    letter-spacing: 0.02em;
    opacity: 0.85;
  }

  .vart__head-mono {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--vart-text-subtle);
    letter-spacing: 0.04em;
  }

  .vart__body {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .vart__verdict-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 9px;
    border-radius: 9999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #047857;
    background-color: rgba(16, 185, 129, 0.14);
    border: 1px solid rgba(16, 185, 129, 0.4);
    line-height: 1;
  }

  :global([data-theme="dark"]) .vart__verdict-tag {
    color: #34D399;
    background-color: rgba(16, 185, 129, 0.12);
  }

  .vart__verdict-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: #10B981;
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.7);
  }

  .vart__title {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 14px;
    line-height: 1.2;
    color: var(--vart-text);
    letter-spacing: -0.005em;
  }

  @container (min-width: 360px) {
    .vart__title {
      font-size: 18px;
    }
  }

  .vart__row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .vart__row-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--vart-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .vart__bar {
    flex: 1;
    height: 4px;
    border-radius: 9999px;
    background-color: var(--vart-bar-track);
    overflow: hidden;
  }

  .vart__bar-fill {
    display: block;
    width: 82%;
    height: 100%;
    background: linear-gradient(to right, #10B981, #F59E0B);
    border-radius: inherit;
  }

  .vart__row-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--vart-text);
    font-weight: 600;
  }

  .vart__codes {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .vart__chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 3px 7px;
    border-radius: 4px;
    background-color: var(--vart-chip-bg);
    border: 1px solid var(--vart-chip-border);
    color: var(--vart-chip-text);
    letter-spacing: 0.04em;
  }

  .vart__chip--accent {
    background-color: rgba(245, 158, 11, 0.14);
    border-color: rgba(245, 158, 11, 0.4);
    color: #B45309;
    font-weight: 600;
  }

  :global([data-theme="dark"]) .vart__chip--accent {
    color: #FBBF24;
  }

  .vart__caption {
    position: absolute;
    bottom: 12px;
    left: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    color: var(--vart-caption);
    letter-spacing: 0.06em;
  }

  .vart__caption-line {
    width: 14px;
    height: 1px;
    background-color: var(--vart-caption-rule);
  }
</style>
