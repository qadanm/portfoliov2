---
// Six-stage loop. Execution is a branched node with three alternative
// environments — never chained as a pipeline.
const stages = [
  { name: 'Intent', kind: 'input' },
  { name: 'Interrogate', kind: 'process' },
  { name: 'Structure', kind: 'process', sub: 'Prompt System' },
  { name: 'Execute', kind: 'execution' },
  { name: 'Review', kind: 'gate' },
  { name: 'Ship', kind: 'output' },
];

// Claude and Cursor both handle reasoning, generation, and code.
// They are interchangeable execution environments — the differentiator
// is interaction style (agentic vs local-iteration), not function.
// Claude Design is the conditional visual branch.
const executionEnvironments = [
  { name: 'Claude', sub: 'agentic work — reasoning, generation, code' },
  { name: 'Cursor', sub: 'local iteration — code, refactor, integration' },
  { name: 'Claude Design', sub: 'visual exploration, when needed', conditional: true },
];
---

<div class="ai-strip" aria-label="From intent to ship: an AI-native system layer with branched execution">
  <span class="ai-strip__label">From intent to ship · AI-native system</span>
  <div class="ai-strip__flow">
    {stages.map((stage, i) => (
      <>
        <span class:list={['ai-strip__node', `ai-strip__node--${stage.kind}`]}>
          <span class="ai-strip__node-name">{stage.name}</span>
          {stage.sub && (
            <span class="ai-strip__node-sub">({stage.sub})</span>
          )}
          {stage.kind === 'execution' && (
            <span class="ai-strip__branches" aria-label="Execution environments">
              {executionEnvironments.map((env, j) => (
                <>
                  <span class:list={['ai-strip__branch', { 'ai-strip__branch--conditional': env.conditional }]}>
                    <span class="ai-strip__branch-name">{env.name}{env.conditional && <span class="ai-strip__star" aria-hidden="true">*</span>}</span>
                    <span class="ai-strip__branch-sub">{env.sub}</span>
                  </span>
                  {j < executionEnvironments.length - 1 && (
                    <span class="ai-strip__branch-sep" aria-hidden="true">·</span>
                  )}
                </>
              ))}
            </span>
          )}
        </span>
        {i < stages.length - 1 && (
          <span class="ai-strip__sep" aria-hidden="true">→</span>
        )}
      </>
    ))}
  </div>
  <p class="ai-strip__legend">
    Execution environment is selected per task, not by role.
  </p>
</div>

<style>
  .ai-strip {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-elevated);
    width: 100%;
    max-width: 100%;
  }

  .ai-strip__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .ai-strip__flow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 10px;
  }

  .ai-strip__node {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 6px 12px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    line-height: 1.2;
  }

  .ai-strip__node-name {
    font-weight: 600;
  }

  .ai-strip__node-sub {
    font-size: 10px;
    color: var(--color-text-subtle);
    font-weight: 400;
  }

  .ai-strip__node--input {
    color: var(--color-text);
    background-color: var(--color-bg);
    border-color: var(--color-text-subtle);
  }

  .ai-strip__node--gate {
    color: var(--color-text);
    background-color: var(--color-bg);
    border-color: var(--color-border);
  }

  .ai-strip__node--output {
    color: var(--color-success);
    background-color: rgba(16, 185, 129, 0.08);
    border-color: rgba(16, 185, 129, 0.25);
  }

  /* Execution opens into a vertical stack on every viewport so each
     branch reads on its own line. The descriptors are too long for a
     single horizontal row, and the vertical layout makes it visually
     obvious that the branches are alternatives, not a chain. */
  .ai-strip__node--execution {
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 0;
    border-radius: 18px;
    overflow: hidden;
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
    border-color: var(--color-accent-muted);
    min-width: 280px;
  }

  .ai-strip__node--execution .ai-strip__node-name {
    text-align: center;
    padding: 8px 14px 7px;
    border-bottom: 1px solid var(--color-accent-muted);
  }

  .ai-strip__branches {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    margin: 0;
    padding: 4px 10px 8px;
    border-left: none;
  }

  .ai-strip__branch {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 8px;
    padding: 5px 4px;
    color: var(--color-accent-hover);
  }

  .ai-strip__branch + .ai-strip__branch {
    border-top: 1px dashed var(--color-accent-muted);
  }

  .ai-strip__branch--conditional {
    color: var(--color-text-muted);
  }

  .ai-strip__branch-name {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1.2;
    flex-shrink: 0;
    min-width: 90px;
  }

  .ai-strip__branch-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-subtle);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .ai-strip__star {
    color: var(--color-accent);
    font-weight: 700;
    margin-left: 1px;
  }

  .ai-strip__branch-sep {
    display: none;
  }

  .ai-strip__sep {
    color: var(--color-text-subtle);
    font-size: 11px;
    opacity: 0.6;
    line-height: 1;
  }

  .ai-strip__legend {
    margin: 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-subtle);
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .ai-strip {
      padding: 14px 16px 16px;
    }
    .ai-strip__flow {
      flex-direction: column;
      align-items: stretch;
      gap: 6px;
    }
    .ai-strip__node {
      justify-content: center;
      font-size: 12px;
      padding: 8px 14px;
    }
    .ai-strip__node-sub {
      font-size: 11px;
    }
    .ai-strip__node--execution {
      min-width: 0;
    }
    .ai-strip__branch {
      flex-direction: column;
      align-items: center;
      gap: 1px;
      padding: 6px 4px;
    }
    .ai-strip__branch-name {
      min-width: 0;
      font-size: 12px;
      text-align: center;
    }
    .ai-strip__branch-sub {
      font-size: 10px;
      text-align: center;
    }
    .ai-strip__sep {
      transform: rotate(90deg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 14px;
    }
  }
</style>
