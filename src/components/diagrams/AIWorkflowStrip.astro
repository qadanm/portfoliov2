---
const nodes = [
  { name: 'Spec', kind: 'input' },
  { name: 'Claude', kind: 'agent' },
  { name: 'Cursor', kind: 'agent' },
  { name: 'Review', kind: 'gate' },
  { name: 'Ship', kind: 'output' },
];
---

<div class="ai-strip" aria-label="AI-augmented development flow">
  <span class="ai-strip__label">AI-augmented workflow</span>
  <div class="ai-strip__flow">
    {nodes.map((node, i) => (
      <>
        <span class:list={['ai-strip__node', `ai-strip__node--${node.kind}`]}>
          {node.kind === 'agent' && (
            <svg class="ai-strip__icon" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <circle cx="5" cy="5" r="2" fill="currentColor"/>
              <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="0.75" opacity="0.4"/>
            </svg>
          )}
          {node.name}
        </span>
        {i < nodes.length - 1 && (
          <span class="ai-strip__sep" aria-hidden="true">→</span>
        )}
      </>
    ))}
  </div>
</div>

<style>
  .ai-strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background-color: var(--color-bg-elevated);
    width: fit-content;
    max-width: 100%;
  }

  .ai-strip__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    padding-right: var(--space-3);
    border-right: 1px solid var(--color-border-subtle);
  }

  .ai-strip__flow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-strip__node {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 3px 9px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    border: 1px solid var(--color-border);
  }

  .ai-strip__node--agent {
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
    border-color: var(--color-accent-muted);
  }

  .ai-strip__node--output {
    color: var(--color-success);
    background-color: rgba(16, 185, 129, 0.08);
    border-color: rgba(16, 185, 129, 0.2);
  }

  .ai-strip__icon {
    display: inline-block;
    color: currentColor;
  }

  .ai-strip__sep {
    color: var(--color-text-subtle);
    font-size: 11px;
    opacity: 0.6;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .ai-strip {
      flex-direction: column;
      align-items: stretch;
      border-radius: 16px;
      padding: 14px 16px 16px;
      gap: 0;
      width: 100%;
    }
    .ai-strip__label {
      border-right: none;
      border-bottom: 1px solid var(--color-border-subtle);
      padding: 0 0 10px;
      margin-bottom: 12px;
      width: 100%;
    }
    .ai-strip__flow {
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }
    .ai-strip__node {
      font-size: 12px;
      padding: 6px 12px;
    }
    .ai-strip__sep {
      transform: rotate(90deg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 14px;
    }
  }
</style>
