---
// Same loop as AIWorkflowStrip, scoped to the visual-exploration branch.
// Claude Design is shown as the *selected* execution environment when a
// screen is easier to think through visually. The output lands back in
// the codebase — that is not a separate "Claude Code" step in a chain,
// it is the codebase the work always belonged to.
const stages = [
  { name: 'Visual intent', kind: 'input' },
  { name: 'Prompt', kind: 'process' },
  { name: 'Claude Design', kind: 'execution' },
  { name: 'Codebase', kind: 'output' },
];
---

<div class="dw-strip" aria-label="Visual exploration branch: intent, prompt, Claude Design, codebase">
  <span class="dw-strip__label">Visual branch</span>
  <div class="dw-strip__flow">
    {stages.map((stage, i) => (
      <>
        <span class:list={['dw-strip__node', `dw-strip__node--${stage.kind}`]}>
          {stage.kind === 'execution' && (
            <svg class="dw-strip__icon" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <circle cx="5" cy="5" r="2" fill="currentColor"/>
              <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="0.75" opacity="0.4"/>
            </svg>
          )}
          {stage.name}
        </span>
        {i < stages.length - 1 && (
          <span class="dw-strip__sep" aria-hidden="true">→</span>
        )}
      </>
    ))}
  </div>
  <p class="dw-strip__legend">
    One branch of the execution layer. Selected when the work is easier to
    reason about visually than in code.
  </p>
</div>

<style>
  .dw-strip {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-3);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-elevated);
    width: 100%;
    max-width: 100%;
  }

  .dw-strip__label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .dw-strip__flow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .dw-strip__node {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 5px 11px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    border: 1px solid var(--color-border);
  }

  .dw-strip__node--input {
    color: var(--color-text);
    background-color: var(--color-bg);
    border-color: var(--color-text-subtle);
  }

  .dw-strip__node--execution {
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
    border-color: var(--color-accent-muted);
  }

  .dw-strip__node--output {
    color: var(--color-success);
    background-color: rgba(16, 185, 129, 0.08);
    border-color: rgba(16, 185, 129, 0.2);
  }

  .dw-strip__icon {
    display: inline-block;
    color: currentColor;
  }

  .dw-strip__sep {
    color: var(--color-text-subtle);
    font-size: 11px;
    opacity: 0.6;
    line-height: 1;
  }

  .dw-strip__legend {
    margin: 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border-subtle);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-text-subtle);
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .dw-strip {
      padding: 14px 16px 16px;
    }
    .dw-strip__flow {
      flex-direction: column;
      align-items: stretch;
      gap: 6px;
    }
    .dw-strip__node {
      justify-content: center;
      font-size: 12px;
      padding: 7px 12px;
    }
    .dw-strip__sep {
      transform: rotate(90deg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 14px;
    }
  }
</style>
