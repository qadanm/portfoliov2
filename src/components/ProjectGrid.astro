---
import ProjectCard from './ProjectCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  projects: CollectionEntry<'build'>[];
  /**
   * `flat` (default) renders one unified Selected Work list, with badges
   * on each card carrying the differentiation (Flagship · Platform ·
   * Product · etc.). The lead card is sized as a feature row, the rest
   * follow as a 2-up grid. This is the audit-recommended layout — no
   * "Selected vs Experience" tier split.
   */
  variant?: 'flat';
}

const { projects, variant = 'flat' } = Astro.props;
const sorted = [...projects].sort((a, b) => a.data.order - b.data.order);
const [lead, ...rest] = sorted;
---

<div class="pg" data-variant={variant}>
  <section class="pg__section" data-reveal>
    <header class="pg__head">
      <span class="pg__eyebrow">Selected work</span>
      <span class="pg__note">Independent products and platform engagements.</span>
    </header>

    {lead && (
      <div class="pg__lead">
        <ProjectCard project={lead} size="feature" index={0} />
      </div>
    )}

    {rest.length > 0 && (
      <div class:list={['pg__rest', { 'pg__rest--solo': rest.length === 1 }]}>
        {rest.map((project, i) => (
          <ProjectCard project={project} index={i + 1} />
        ))}
      </div>
    )}
  </section>
</div>

<style>
  .pg {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .pg {
      gap: var(--space-20);
    }
  }

  .pg__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  @media (min-width: 600px) {
    .pg__section {
      gap: var(--space-6);
    }
  }

  .pg__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .pg__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .pg__note {
    font-size: 13px;
    color: var(--color-text-subtle);
    line-height: 1.5;
  }

  .pg__lead {
    /* Single lead card, full width */
  }

  .pg__rest {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 600px) {
    .pg__rest {
      gap: var(--space-5);
    }
  }

  @media (min-width: 720px) {
    .pg__rest {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }

    .pg__rest--solo {
      grid-template-columns: repeat(2, 1fr);
    }

    .pg__rest--solo :global(.project-card) {
      grid-column: 2 / 3;
    }
  }
</style>
