---
interface Props {
  posts: Array<{
    slug: string;
    data: {
      title: string;
      description: string;
      date: Date;
      tags: string[];
    };
  }>;
}

const { posts } = Astro.props;

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<section class="section-gap" aria-labelledby="writing-heading">
  <div class="container-site">
    <div class="writing-header">
      <div>
        <span class="badge badge-muted">Writing</span>
        <h2 id="writing-heading" class="section-title">
          Thinking in public
        </h2>
        <p class="section-desc">
          Notes on AI-native product design, agentic workflows,
          and how the designer's role is evolving.
        </p>
      </div>
      <a href="/writing" class="work-all-link">
        All articles
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>
    </div>

    <div class="writing-list">
      {posts.map((post) => (
        <a href={`/writing/${post.slug}`} class="writing-item">
          <div class="writing-item-meta">
            <time datetime={post.data.date.toISOString()} class="writing-date">
              {formatDate(post.data.date)}
            </time>
            {post.data.tags[0] && (
              <span class="writing-tag">{post.data.tags[0]}</span>
            )}
          </div>
          <div class="writing-item-body">
            <h3 class="writing-title">{post.data.title}</h3>
            <p class="writing-desc">{post.data.description}</p>
          </div>
          <div class="writing-item-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .writing-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }

  .work-all-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms;
    white-space: nowrap;
    padding-bottom: 4px;
    align-self: flex-end;
  }

  .work-all-link:hover { color: var(--color-accent); }

  .writing-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background-color: var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .writing-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition: background-color 150ms;
  }

  @media (min-width: 640px) {
    .writing-item {
      grid-template-columns: 180px 1fr auto;
      gap: var(--space-6);
      align-items: center;
    }
  }

  .writing-item:hover {
    background-color: var(--color-bg-muted);
  }

  .writing-item:hover .writing-title {
    color: var(--color-accent);
  }

  .writing-item-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .writing-date {
    font-size: 12px;
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .writing-tag {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 9999px;
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-muted);
    display: inline-block;
  }

  .writing-title {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 4px;
    line-height: 1.3;
    transition: color 150ms;
  }

  .writing-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .writing-item-arrow {
    color: var(--color-text-subtle);
    transition: color 200ms, transform 200ms;
    flex-shrink: 0;
  }

  .writing-item:hover .writing-item-arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }
</style>
