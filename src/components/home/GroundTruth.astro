---
const facts = [
  { value: '11', label: 'Sites on shared system' },
  { value: '~85%', label: 'Of the platform I own' },
  { value: '1', label: 'AI-native flagship', accent: true },
  { value: '10y+', label: 'Inside production code' },
];
---

<aside class="ground-truth" aria-label="Scope and scale">
  <div class="ground-truth__inner">
    {facts.map((fact, i) => (
      <>
        <div class:list={['gt__fact', { 'gt__fact--accent': fact.accent }]}>
          <span class="gt__value">{fact.value}</span>
          <span class="gt__label">{fact.label}</span>
        </div>
        {i < facts.length - 1 && <span class="gt__sep" aria-hidden="true"></span>}
      </>
    ))}
  </div>
</aside>

<style>
  .ground-truth {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-subtle);
  }

  .ground-truth__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    align-items: stretch;
  }

  @media (min-width: 720px) {
    .ground-truth__inner {
      grid-template-columns: repeat(7, 1fr);
      align-items: center;
      gap: 0;
    }
  }

  .gt__fact {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  @media (min-width: 720px) {
    .gt__fact {
      grid-column: span 1.75;
    }
  }

  .gt__value {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-text);
  }

  .gt__fact--accent .gt__value {
    color: var(--color-accent);
  }

  .gt__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
    line-height: 1.4;
  }

  .gt__sep {
    display: none;
  }

  @media (min-width: 720px) {
    .gt__sep {
      display: block;
      width: 1px;
      height: 32px;
      background-color: var(--color-border-subtle);
      justify-self: center;
      align-self: center;
    }
  }
</style>
