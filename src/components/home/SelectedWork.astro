---
interface Props {
  projects: Array<{
    slug: string;
    data: {
      title: string;
      description: string;
      type: string;
      year: string;
      role: string;
      tags: string[];
      outcome?: string;
    };
  }>;
}

const { projects } = Astro.props;

const typeColors: Record<string, string> = {
  'Product System': 'badge-muted',
  'Design System': 'badge-muted',
  'Agentic Workflow': 'badge-accent',
  'UX Engineering': 'badge-muted',
  'AI-Native': 'badge-accent',
  'Platform': 'badge-muted',
  'Research': 'badge-muted',
};
---

<section class="section-gap" aria-labelledby="work-heading">
  <div class="container-site">
    <div class="work-header">
      <div>
        <span class="badge badge-muted">Selected Work</span>
        <h2 id="work-heading" class="section-title">
          Systems, products,<br />and agentic workflows
        </h2>
      </div>
      <a href="/work" class="work-all-link">
        View all work
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>
    </div>

    <div class="work-grid">
      {projects.map((project, i) => (
        <a
          href={`/work/${project.slug}`}
          class:list={['work-card', { 'work-card--featured': i === 0 }]}
          aria-label={`View ${project.data.title}`}
        >
          <div class="work-card-top">
            <div class="work-card-meta">
              <span class={`badge ${typeColors[project.data.type] || 'badge-muted'}`}>
                {project.data.type}
              </span>
              <span class="work-year">{project.data.year}</span>
            </div>
            <div class="work-card-arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <div class="work-card-body">
            <h3 class="work-card-title">{project.data.title}</h3>
            <p class="work-card-desc">{project.data.description}</p>
            {project.data.outcome && (
              <div class="work-outcome">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {project.data.outcome}
              </div>
            )}
          </div>

          <div class="work-card-footer">
            <span class="work-role">{project.data.role}</span>
            <div class="work-tags">
              {project.data.tags.slice(0, 3).map(tag => (
                <span class="work-tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .work-all-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms;
    white-space: nowrap;
    padding-bottom: 4px;
  }

  .work-all-link:hover {
    color: var(--color-accent);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .work-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .work-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms var(--ease-out),
                box-shadow 200ms var(--ease-out),
                transform 200ms var(--ease-out);
  }

  .work-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 1px var(--color-accent-muted), var(--shadow-lg);
    transform: translateY(-3px);
  }

  .work-card--featured {
    border-color: var(--color-accent-muted);
    background-color: var(--color-accent-dim);
  }

  .work-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .work-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .work-year {
    font-size: 12px;
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .work-card-arrow {
    color: var(--color-text-subtle);
    transition: color 200ms, transform 200ms;
    flex-shrink: 0;
  }

  .work-card:hover .work-card-arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }

  .work-card-body {
    flex: 1;
  }

  .work-card-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }

  .work-card-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .work-outcome {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    margin-top: var(--space-3);
    font-size: 13px;
    color: var(--color-success);
    font-weight: 500;
    line-height: 1.4;
  }

  .work-outcome svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .work-card-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .work-card--featured .work-card-footer {
    border-top-color: var(--color-accent-muted);
  }

  .work-role {
    font-size: 12px;
    color: var(--color-text-subtle);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .work-tag {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
  }

  .work-card--featured .work-tag {
    background-color: var(--color-accent-dim);
    border-color: var(--color-accent-muted);
    color: var(--color-accent);
  }
</style>
