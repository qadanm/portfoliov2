---
// Signature visualization: the agentic workflow pipeline
---

<section class="section-gap pipeline-section" aria-labelledby="pipeline-heading">
  <div class="container-site">
    <div class="pipeline-header">
      <span class="badge badge-accent">How I Work</span>
      <h2 id="pipeline-heading" class="section-title">
        The agentic production loop
      </h2>
      <p class="section-desc">
        I've built a personal workflow where Claude and Cursor operate as
        active participants — not autocomplete. Structured prompts, explicit
        task boundaries, and human judgment at every critical checkpoint.
      </p>
    </div>

    <div class="pipeline-viz dot-grid" role="img" aria-label="Diagram showing the agentic production workflow: Intent → Spec → Agent Execution → Review → Iterate → Ship">
      <!-- Horizontal pipeline -->
      <div class="pipeline-track">
        <!-- Node 1: Intent -->
        <div class="pipe-node pipe-node--human">
          <div class="pipe-node-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <div class="pipe-node-label">Intent</div>
          <div class="pipe-node-desc">Design goal,<br/>constraints, context</div>
          <div class="pipe-node-type">Human</div>
        </div>

        <div class="pipe-connector">
          <svg class="pipe-line" viewBox="0 0 80 2" preserveAspectRatio="none">
            <line x1="0" y1="1" x2="80" y2="1" stroke="var(--viz-line)" stroke-width="1.5"/>
          </svg>
          <div class="pipe-flow-dot"></div>
          <div class="pipe-arrow">→</div>
        </div>

        <!-- Node 2: Structured Spec -->
        <div class="pipe-node pipe-node--spec">
          <div class="pipe-node-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </div>
          <div class="pipe-node-label">Structured Spec</div>
          <div class="pipe-node-desc">Prompt engineering,<br/>explicit task scope</div>
          <div class="pipe-node-type">Authored</div>
        </div>

        <div class="pipe-connector">
          <svg class="pipe-line" viewBox="0 0 80 2" preserveAspectRatio="none">
            <line x1="0" y1="1" x2="80" y2="1" stroke="var(--viz-line)" stroke-width="1.5"/>
          </svg>
          <div class="pipe-flow-dot pipe-flow-dot--d1"></div>
          <div class="pipe-arrow">→</div>
        </div>

        <!-- Node 3: Agent Execution -->
        <div class="pipe-node pipe-node--agent">
          <div class="pipe-node-icon pipe-node-icon--accent">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
            </svg>
          </div>
          <div class="pipe-node-label">Agent Execution</div>
          <div class="pipe-node-desc">Claude generates,<br/>Cursor implements</div>
          <div class="pipe-node-type pipe-node-type--accent">AI Agent</div>
          <div class="pipe-node-pulse"></div>
        </div>

        <div class="pipe-connector">
          <svg class="pipe-line" viewBox="0 0 80 2" preserveAspectRatio="none">
            <line x1="0" y1="1" x2="80" y2="1" stroke="var(--viz-line)" stroke-width="1.5"/>
          </svg>
          <div class="pipe-flow-dot pipe-flow-dot--d2"></div>
          <div class="pipe-arrow">→</div>
        </div>

        <!-- Node 4: Review -->
        <div class="pipe-node pipe-node--review">
          <div class="pipe-node-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div class="pipe-node-label">Human Review</div>
          <div class="pipe-node-desc">Quality, judgment,<br/>pattern validation</div>
          <div class="pipe-node-type">Human</div>
        </div>

        <div class="pipe-connector">
          <svg class="pipe-line" viewBox="0 0 80 2" preserveAspectRatio="none">
            <line x1="0" y1="1" x2="80" y2="1" stroke="var(--viz-line)" stroke-width="1.5"/>
          </svg>
          <div class="pipe-flow-dot pipe-flow-dot--d3"></div>
          <div class="pipe-arrow">→</div>
        </div>

        <!-- Node 5: Ship -->
        <div class="pipe-node pipe-node--ship">
          <div class="pipe-node-icon pipe-node-icon--success">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="m22 2-7 20-4-9-9-4 20-7z"/>
            </svg>
          </div>
          <div class="pipe-node-label">Ship</div>
          <div class="pipe-node-desc">Production-ready,<br/>maintainable output</div>
          <div class="pipe-node-type pipe-node-type--success">Delivered</div>
        </div>
      </div>

      <!-- Feedback loop annotation -->
      <div class="pipeline-feedback" aria-hidden="true">
        <div class="feedback-line"></div>
        <span class="feedback-label">Iteration loop — agent re-runs on feedback</span>
      </div>
    </div>

    <!-- Three pillars below -->
    <div class="pipeline-pillars">
      <div class="pillar">
        <div class="pillar-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
          </svg>
        </div>
        <h3 class="pillar-title">Explicit task scoping</h3>
        <p class="pillar-desc">
          Every agent task starts with a structured prompt — role, constraints, output format, and success criteria. Vagueness kills quality.
        </p>
      </div>
      <div class="pillar">
        <div class="pillar-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="pillar-title">Human oversight at checkpoints</h3>
        <p class="pillar-desc">
          Autonomy without accountability is just chaos. Every consequential step has a human review gate. I own the output.
        </p>
      </div>
      <div class="pillar">
        <div class="pillar-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h3 class="pillar-title">Structured evaluation loops</h3>
        <p class="pillar-desc">
          Output gets assessed against explicit criteria before moving forward. Iteration is built in, not bolted on.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .pipeline-section {
    position: relative;
  }

  .pipeline-header {
    margin-bottom: var(--space-10);
    max-width: 560px;
  }

  .pipeline-viz {
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    padding: var(--space-10) var(--space-8);
    margin-bottom: var(--space-10);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    position: relative;
  }

  .pipeline-track {
    display: flex;
    align-items: center;
    min-width: 860px;
    gap: 0;
  }

  .pipe-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6px;
    flex: 1;
    position: relative;
    min-width: 120px;
  }

  .pipe-node-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    margin-bottom: 6px;
    transition: all 200ms;
  }

  .pipe-node:hover .pipe-node-icon {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .pipe-node-icon--accent {
    background-color: var(--color-accent-dim);
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .pipe-node-icon--success {
    background-color: rgba(16, 185, 129, 0.08);
    border-color: rgba(16, 185, 129, 0.3);
    color: var(--color-success);
  }

  .pipe-node-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .pipe-node-desc {
    font-size: 11px;
    color: var(--color-text-subtle);
    line-height: 1.4;
  }

  .pipe-node-type {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
    margin-top: 2px;
  }

  .pipe-node-type--accent {
    background-color: var(--color-accent-muted);
    color: var(--color-accent);
    border-color: var(--color-accent-muted);
  }

  .pipe-node-type--success {
    background-color: rgba(16, 185, 129, 0.1);
    color: var(--color-success);
    border-color: rgba(16, 185, 129, 0.2);
  }

  .pipe-node-pulse {
    position: absolute;
    top: 0;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-accent);
    animation: agentPulse 2.5s ease-in-out 0.5s infinite;
    pointer-events: none;
  }

  .pipe-connector {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 80px;
    flex-shrink: 0;
    padding-bottom: 80px;
  }

  .pipe-line {
    width: 80px;
    height: 2px;
    flex-shrink: 0;
  }

  .pipe-arrow {
    position: absolute;
    font-size: 16px;
    color: var(--color-text-subtle);
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% - 40px));
    margin-top: -1px;
  }

  .pipe-flow-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    top: calc(50% - 4px - 40px);
    animation: pipeFlow 3s ease-in-out infinite;
  }

  .pipe-flow-dot--d1 { animation-delay: 0.6s; }
  .pipe-flow-dot--d2 { animation-delay: 1.2s; }
  .pipe-flow-dot--d3 { animation-delay: 1.8s; }

  @keyframes pipeFlow {
    0% { left: 0; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: calc(100% - 8px); opacity: 0; }
  }

  .pipeline-feedback {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 6px;
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px dashed var(--color-border);
  }

  .feedback-label {
    font-size: 11px;
    color: var(--color-text-subtle);
    letter-spacing: 0.02em;
    font-style: italic;
  }

  .pipeline-pillars {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .pipeline-pillars { grid-template-columns: repeat(3, 1fr); }
  }

  .pillar {
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-elevated);
  }

  .pillar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    background-color: var(--color-accent-dim);
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .pillar-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
  }

  .pillar-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }
</style>
