---
// The Garage — the car-enthusiast showcase for the three mobile apps.
// CarSpotter is the hero (largest, lime arcade, the best-designed card);
// VINly + ChatOBD2 sit below as a brand-accented 2-up. Energetic, warm/dark,
// automotive — deliberately "these are mine," the opposite of the corporate
// Experience wall that follows it.
//
// CarSpotter + VINly cards are <article>s with a stretched case-study link
// (::after covers the card) so the App Store badge and site link can be
// real anchors without nesting <a> inside <a>.
import AppStoreBadge from '@/components/AppStoreBadge.astro';

const apps = {
  carspotter: {
    href: '/work/car-spotter',
    appStore: 'https://apps.apple.com/app/carspotter-daily-car-game/id6777868215',
    site: 'https://carspottergame.com',
    siteLabel: 'carspottergame.com',
    poster: '/images/car-spotter/poster.webp',
    alt: 'CarSpotter portfolio poster — the headline "Guess the car from the detail" in lime and white over a near-black wall of car photographs, beside three tilted iPhones showing a clue, the full-car reveal, and the run result.',
  },
  vinly: {
    href: '/work/vinly',
    appStore: 'https://apps.apple.com/us/app/vinly-buyer-reports/id6774041303',
    site: 'https://vinly.dev',
    siteLabel: 'vinly.dev',
    poster: '/images/vinly/poster.webp',
    alt: 'VINly portfolio poster: a warm cream layout headlined "Scan any VIN. Know the car." over two angled iPhones, one showing the app home with a Scan a VIN button, the other a free public-record report for a 2024 Ford F-150.',
  },
  chatobd2: {
    href: '/work/chatobd2',
    poster: '/images/chatobd2/poster.webp',
    alt: 'ChatOBD2 portfolio poster — the headline "Your car is talking. ChatOBD-2 translates." in white and blue on a near-black engineering grid, beside the real app showing a live diagnosis of a P0420 catalyst fault on a 2010 Toyota Prius.',
  },
  elmulator: {
    href: '/work/elmulator',
    github: 'https://github.com/qadanm/elmulator',
    marketplace: 'https://github.com/marketplace/actions/elmulator',
    pypi: 'https://pypi.org/project/elmulator/',
    poster: '/images/elmulator/poster.svg',
    alt: 'elmulator portfolio poster — a dark blue terminal showing a green iOS OBD2 test run against a scripted ELM327, beside the elmulator wordmark.',
  },
};
---

<section class="garage" id="garage" aria-labelledby="garage-title">
  <div class="container-site garage__inner">
    <header class="garage__head">
      <div class="garage__sxn">
        <span class="garage__sxn-label">The Garage</span>
        <span class="garage__sxn-rule" aria-hidden="true"></span>
        <span class="garage__sxn-meta">Built by a car enthusiast</span>
      </div>
      <h2 class="garage__title" id="garage-title">Built for the love of cars.</h2>
      <p class="garage__lede">
        I'm a car guy who ships car apps — three of them, designed and
        engineered solo. A daily spotting game and a free VIN scanner,
        both on the App Store today, and an AI mechanic in your pocket on
        the way. And under them, an open-source ELM327 emulator I pulled
        out and shipped so anyone's car app can be tested in CI.
      </p>
    </header>

    {/* ── Hero: CarSpotter ─────────────────────────────────────────── */}
    <article
      class="garage__hero"
    >
      <span class="garage__hero-corner garage__hero-corner--tl" aria-hidden="true"></span>
      <span class="garage__hero-corner garage__hero-corner--tr" aria-hidden="true"></span>
      <span class="garage__hero-corner garage__hero-corner--bl" aria-hidden="true"></span>
      <span class="garage__hero-corner garage__hero-corner--br" aria-hidden="true"></span>

      <div class="garage__hero-media">
        <img src={apps.carspotter.poster} alt={apps.carspotter.alt} width="2560" height="1600" loading="lazy" decoding="async" />
        <span class="garage__hero-redline" aria-hidden="true"></span>
      </div>

      <div class="garage__hero-body">
        <div class="garage__hero-tags">
          <a
            class="garage__chip garage__chip--dl"
            href={apps.carspotter.appStore}
            target="_blank"
            rel="noopener"
            data-track="cta_click"
            data-track-cta="garage-chip-download"
            data-track-project="car-spotter"
          >
            Download now
          </a>
          <span class="garage__hero-kind">iOS · daily game</span>
        </div>
        <h3 class="garage__hero-name">CarSpotter</h3>
        <p class="garage__hero-desc">
          The daily car-spotting game. Five cropped details, four answers,
          ten seconds — for the people who know the car before the badge
          shows up.
        </p>
        <ul class="garage__spec">
          <li><span>Daily 5</span></li>
          <li><span>12 detail types</span></li>
          <li><span>Spoiler-free share</span></li>
        </ul>
        <a
          href={apps.carspotter.href}
          class="garage__cta garage__cta--stretch"
          data-track="cta_click"
          data-track-cta="garage-hero"
          data-track-project="car-spotter"
        >
          Open the case study
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="garage__store">
          <AppStoreBadge href={apps.carspotter.appStore} height={40} project="car-spotter" cta="garage-appstore" />
          <a
            class="garage__site"
            href={apps.carspotter.site}
            target="_blank"
            rel="noopener"
            data-track="cta_click"
            data-track-cta="garage-site"
            data-track-project="car-spotter"
          >
            {apps.carspotter.siteLabel}
            <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </article>

    {/* ── 2-up: VINly + ChatOBD2 ───────────────────────────────────── */}
    <div class="garage__pair">
      <article
        class="garage__app garage__app--vinly"
      >
        <div class="garage__app-media">
          <img src={apps.vinly.poster} alt={apps.vinly.alt} width="2560" height="1600" loading="lazy" decoding="async" />
        </div>
        <div class="garage__app-body">
          <div class="garage__app-tags">
            <a
              class="garage__chip garage__chip--dl"
              href={apps.vinly.appStore}
              target="_blank"
              rel="noopener"
              data-track="cta_click"
              data-track-cta="garage-chip-download"
              data-track-project="vinly"
            >
              Download now
            </a>
            <span class="garage__app-kind">iOS · Free VIN research</span>
          </div>
          <h3 class="garage__app-name">VINly</h3>
          <p class="garage__app-desc">
            Scan a VIN and see the car's public safety record free:
            recalls, complaints, crash tests, fuel cost, and real listings
            nearby. Out now on the App Store.
          </p>
          <a
            href={apps.vinly.href}
            class="garage__app-link garage__app-link--stretch"
            data-track="cta_click"
            data-track-cta="garage-app"
            data-track-project="vinly"
          >
            Case study
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="garage__store garage__store--app">
            <AppStoreBadge href={apps.vinly.appStore} height={40} project="vinly" cta="garage-appstore" />
            <a
              class="garage__site"
              href={apps.vinly.site}
              target="_blank"
              rel="noopener"
              data-track="cta_click"
              data-track-cta="garage-site"
              data-track-project="vinly"
            >
              {apps.vinly.siteLabel}
              <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </article>

      <a
        href={apps.chatobd2.href}
        class="garage__app garage__app--chatobd"
        data-track="cta_click"
        data-track-cta="garage-app"
        data-track-project="chatobd2"
      >
        <div class="garage__app-media">
          <img src={apps.chatobd2.poster} alt={apps.chatobd2.alt} width="2560" height="1600" loading="lazy" decoding="async" />
        </div>
        <div class="garage__app-body">
          <div class="garage__app-tags">
            <span class="garage__chip garage__chip--soon">Coming soon</span>
            <span class="garage__app-kind">iOS · AI diagnostics</span>
          </div>
          <h3 class="garage__app-name">ChatOBD2</h3>
          <p class="garage__app-desc">
            Your AI car mechanic. Plug in an OBD-II adapter, ask your car
            anything, and get a real diagnosis in plain English.
          </p>
          <span class="garage__app-link">
            Case study
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    </div>

    {/* ── Open source: elmulator ───────────────────────────────────── */}
    <article
      class="garage__oss"
    >
      <span class="garage__hero-corner garage__hero-corner--tl garage__oss-corner" aria-hidden="true"></span>
      <span class="garage__hero-corner garage__hero-corner--tr garage__oss-corner" aria-hidden="true"></span>
      <span class="garage__hero-corner garage__hero-corner--bl garage__oss-corner" aria-hidden="true"></span>
      <span class="garage__hero-corner garage__hero-corner--br garage__oss-corner" aria-hidden="true"></span>

      <div class="garage__oss-media">
        <img src={apps.elmulator.poster} alt={apps.elmulator.alt} width="2560" height="1600" loading="lazy" decoding="async" />
      </div>

      <div class="garage__oss-body">
        <div class="garage__hero-tags">
          <span class="garage__chip garage__chip--oss">Open source</span>
          <span class="garage__hero-kind">Swift + Python · CLI + Action</span>
        </div>
        <h3 class="garage__oss-name">elmulator</h3>
        <p class="garage__hero-desc">
          The test harness under the car apps, pulled out and shipped. A
          scriptable ELM327 adapter that puts your Bluetooth OBD2 code under
          test in CI — no car, no adapter, no radio.
        </p>
        <ul class="garage__spec garage__spec--oss">
          <li><span>Swift + Python</span></li>
          <li><span>Byte-for-byte parity</span></li>
          <li><span>GitHub Action</span></li>
        </ul>
        <a
          href={apps.elmulator.href}
          class="garage__cta garage__cta--stretch"
          data-track="cta_click"
          data-track-cta="garage-oss"
          data-track-project="elmulator"
        >
          Open the case study
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="garage__store garage__store--oss">
          <a
            class="garage__site garage__site--strong"
            href={apps.elmulator.github}
            target="_blank"
            rel="noopener"
            data-track="cta_click"
            data-track-cta="garage-github"
            data-track-project="elmulator"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            GitHub
          </a>
          <a
            class="garage__site"
            href={apps.elmulator.marketplace}
            target="_blank"
            rel="noopener"
            data-track="cta_click"
            data-track-cta="garage-marketplace"
            data-track-project="elmulator"
          >
            Marketplace
            <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            class="garage__site"
            href={apps.elmulator.pypi}
            target="_blank"
            rel="noopener"
            data-track="cta_click"
            data-track-cta="garage-pypi"
            data-track-project="elmulator"
          >
            PyPI
            <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  /* ─── Section frame: warm/dark automotive band ──────────────────── */
  .garage {
    position: relative;
    overflow: hidden;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    border-top: 1px solid var(--color-border-subtle);
    --lime: #C8FF00;
    --lime-rgb: 200, 255, 0;
  }

  @media (min-width: 768px) {
    .garage {
      padding-top: var(--space-24);
      padding-bottom: var(--space-24);
    }
  }

  .garage__inner { position: relative; z-index: 1; }

  /* ─── Section head ──────────────────────────────────────────────── */
  .garage__sxn {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: var(--space-5);
  }
  .garage__sxn-label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
  }
  .garage__sxn-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(var(--lime-rgb), 0.5), transparent);
    min-width: 24px;
    max-width: 520px;
  }
  .garage__sxn-meta {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-subtle);
    white-space: nowrap;
  }

  .garage__head {
    max-width: 760px;
    margin-bottom: var(--space-10);
  }
  @media (min-width: 768px) {
    .garage__head { margin-bottom: var(--space-12); }
  }
  .garage__title {
    font-family: var(--font-display);
    font-size: clamp(34px, 5.4vw, 60px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.04;
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }
  .garage__lede {
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.65;
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  /* ─── Shared chips ──────────────────────────────────────────────── */
  .garage__chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    padding: 4px 9px;
    border-radius: 9999px;
    line-height: 1;
  }
  .garage__chip--flag {
    color: #0B0C0E;
    background: var(--lime);
    box-shadow: 0 0 14px rgba(var(--lime-rgb), 0.35);
  }
  /* "Download now" — a real anchor, so it must clear the stretched case-study
     link (::after, z-index 1) the same way the store row does, or the card
     would swallow the click and send you to the case study instead. */
  .garage__chip--dl {
    position: relative;
    z-index: 2;
    color: #0B0C0E;
    background: var(--lime);
    box-shadow: 0 0 14px rgba(var(--lime-rgb), 0.35);
    text-decoration: none;
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .garage__chip--dl:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 18px rgba(var(--lime-rgb), 0.55);
  }
  .garage__chip--dl:focus-visible {
    outline: 2px solid var(--lime);
    outline-offset: 2px;
  }
  .garage__chip--soon {
    color: var(--color-text);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border-strong);
  }

  /* ─── Hero card: CarSpotter ─────────────────────────────────────── */
  .garage__hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: linear-gradient(180deg, var(--color-bg-elevated), var(--color-bg-muted));
    box-shadow: var(--shadow-card);
    overflow: hidden;
    margin-bottom: var(--space-5);
    transition: border-color 360ms var(--ease-out), box-shadow 360ms var(--ease-out), transform 360ms var(--ease-out);
    will-change: transform;
  }
  @media (min-width: 880px) {
    .garage__hero { grid-template-columns: 1.32fr 1fr; }
  }

  .garage__hero:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--lime-rgb), 0.5);
    box-shadow: var(--shadow-card-hover), 0 0 0 1px rgba(var(--lime-rgb), 0.25), 0 24px 60px rgba(var(--lime-rgb), 0.10);
  }

  .garage__hero-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: #0B0C0E;
    border-bottom: 1px solid var(--color-border);
  }
  @media (min-width: 880px) {
    .garage__hero-media { border-bottom: none; border-right: 1px solid var(--color-border); aspect-ratio: auto; }
  }
  .garage__hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 700ms var(--ease-out);
    will-change: transform;
  }
  .garage__hero:hover .garage__hero-media img { transform: scale(1.035); }

  /* redline sweep that flares on hover */
  .garage__hero-redline {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 3px;
    background: linear-gradient(to right, transparent, var(--lime), transparent);
    opacity: 0;
    transform: scaleX(0.4);
    transition: opacity 360ms var(--ease-out), transform 520ms var(--ease-out);
  }
  .garage__hero:hover .garage__hero-redline { opacity: 0.9; transform: scaleX(1); }

  .garage__hero-corner {
    position: absolute;
    width: 12px; height: 12px;
    border: 1.5px solid rgba(var(--lime-rgb), 0.0);
    z-index: 3;
    transition: border-color 280ms var(--ease-out);
  }
  .garage__hero:hover .garage__hero-corner { border-color: var(--lime); }
  .garage__hero-corner--tl { top: 12px; left: 12px; border-right: none; border-bottom: none; }
  .garage__hero-corner--tr { top: 12px; right: 12px; border-left: none; border-bottom: none; }
  .garage__hero-corner--bl { bottom: 12px; left: 12px; border-right: none; border-top: none; }
  .garage__hero-corner--br { bottom: 12px; right: 12px; border-left: none; border-top: none; }

  .garage__hero-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-7) var(--space-6);
  }
  @media (min-width: 880px) {
    .garage__hero-body { padding: var(--space-10) var(--space-8); justify-content: center; }
  }

  .garage__hero-tags { display: flex; align-items: center; gap: 10px; }
  .garage__hero-kind {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-text-subtle);
  }
  .garage__hero-name {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 0.98;
    color: var(--color-text);
  }
  .garage__hero-desc {
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 46ch;
  }
  .garage__spec {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    list-style: none;
    padding: var(--space-4) 0 0;
    margin: 0;
    border-top: 1px solid var(--color-border-subtle);
  }
  .garage__spec li {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-text-subtle);
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .garage__spec li::before {
    content: '';
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 6px rgba(var(--lime-rgb), 0.6);
  }
  .garage__cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: var(--space-2);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }
  .garage__cta svg { transition: transform 240ms var(--ease-out); }
  .garage__hero:hover .garage__cta { color: var(--lime); }
  :global([data-theme="light"]) .garage__hero:hover .garage__cta { color: #5b7300; }
  .garage__hero:hover .garage__cta svg { transform: translate(3px, -3px); }

  /* Stretched case-study link: covers the whole card so the card stays
     one big click target, while the store row below renders real anchors
     ABOVE it (z-index) — no <a> nested in <a>. */
  .garage__cta--stretch { text-decoration: none; }
  .garage__cta--stretch::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* ── App Store badge + marketing-site row ───────────────────────── */
  .garage__store {
    position: relative;
    z-index: 2;
    display: flex;
