---
---

<section class="hero dot-grid" aria-label="Introduction">
  <div class="container-site hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow animate-fade-up">
        <span class="eyebrow-line">UX Engineering</span>
        <span class="eyebrow-sep" aria-hidden="true">·</span>
        <span class="eyebrow-line">Platform Systems</span>
        <span class="eyebrow-sep" aria-hidden="true">·</span>
        <span class="eyebrow-line">AI-Native</span>
      </div>

      <h1 class="hero-name animate-fade-up animate-delay-100">
        Moe<span class="name-period">.</span>
      </h1>

      <p class="hero-statement animate-fade-up animate-delay-200">
        I work at the intersection of design, front-end engineering,
        and system architecture — maintaining large production codebases,
        evolving multi-site platforms, and building with AI as a structural
        part of the process.
      </p>

      <div class="hero-cta animate-fade-up animate-delay-300">
        <a href="/work" class="btn-primary">
          View work
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/about" class="btn-secondary">How I think</a>
      </div>

      <div class="hero-stack animate-fade-up animate-delay-400">
        <span class="stack-label">Stack</span>
        <div class="stack-chips">
          <span class="stack-chip">ASP.NET MVC</span>
          <span class="stack-chip">TypeScript</span>
          <span class="stack-chip">React</span>
          <span class="stack-chip">Astro</span>
          <span class="stack-chip">Figma</span>
          <span class="stack-chip">Claude</span>
          <span class="stack-chip">Cursor</span>
        </div>
      </div>
    </div>

    <div class="hero-visual animate-fade-in animate-delay-300" aria-hidden="true">
      <!-- Platform system map diagram -->
      <div class="system-map">
        <div class="smap-title">Platform Architecture</div>

        <!-- Core platform -->
        <div class="smap-core">
          <div class="smap-core-label">MagTek.com</div>
          <div class="smap-core-sub">Primary platform · ~85% ownership</div>
          <div class="smap-core-layers">
            <span class="smap-layer">UX Systems</span>
            <span class="smap-layer smap-layer--accent">Components</span>
            <span class="smap-layer">Routing</span>
          </div>
        </div>

        <div class="smap-connector-row">
          <div class="smap-branch-line"></div>
        </div>

        <!-- Satellite sites -->
        <div class="smap-satellites">
          <div class="smap-sat">
            <div class="smap-sat-dot"></div>
            <div class="smap-sat-label">+11 Sites</div>
            <div class="smap-sat-sub">Shared architecture</div>
          </div>
          <div class="smap-sat smap-sat--accent">
            <div class="smap-sat-dot smap-sat-dot--accent"></div>
            <div class="smap-sat-label">QwickPAY</div>
            <div class="smap-sat-sub">Onboarding system</div>
          </div>
          <div class="smap-sat">
            <div class="smap-sat-dot"></div>
            <div class="smap-sat-label">Integrations</div>
            <div class="smap-sat-sub">Web API · SMTP</div>
          </div>
        </div>

        <div class="smap-divider"></div>

        <!-- AI layer -->
        <div class="smap-ai-layer">
          <div class="smap-ai-label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4"/>
            </svg>
            AI-augmented workflow layer
          </div>
          <div class="smap-ai-nodes">
            <span class="smap-ai-node">Claude</span>
            <span class="smap-ai-sep">→</span>
            <span class="smap-ai-node">Cursor</span>
            <span class="smap-ai-sep">→</span>
            <span class="smap-ai-node">Review</span>
            <span class="smap-ai-sep">→</span>
            <span class="smap-ai-node smap-ai-node--ship">Ship</span>
          </div>
        </div>

        <div class="smap-pulse" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <div class="hero-scroll-indicator" aria-hidden="true">
    <span class="scroll-text">Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 64px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 65% 40%, var(--color-accent-dim), transparent 65%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    padding-block: var(--space-20);
    position: relative;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr 380px;
      align-items: center;
    }
  }

  .hero-content {
    max-width: 620px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: var(--space-6);
  }

  .eyebrow-line {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-subtle);
    letter-spacing: 0.01em;
  }

  .eyebrow-sep {
    color: var(--color-accent);
    opacity: 0.5;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(72px, 12vw, 140px);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .name-period {
    color: var(--color-accent);
  }

  .hero-statement {
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.65;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    max-width: 520px;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--color-accent);
    text-decoration: none;
    transition: all 200ms var(--ease-out);
    letter-spacing: -0.01em;
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px var(--color-accent-muted);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: all 200ms;
  }

  .btn-secondary:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }

  .hero-stack {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .stack-label {
    font-size: 11px;
    color: var(--color-text-subtle);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stack-chip {
    font-size: 12px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 9999px;
    background-color: var(--color-bg-muted);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
  }

  /* ─── System Map ─── */
  .hero-visual {
    display: none;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-visual { display: flex; }
  }

  .system-map {
    position: relative;
    width: 100%;
    max-width: 340px;
    padding: var(--space-5);
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .smap-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .smap-core {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background-color: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .smap-core::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-accent-dim), transparent);
    pointer-events: none;
  }

  .smap-core-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin-bottom: 3px;
    position: relative;
  }

  .smap-core-sub {
    font-size: 11px;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-3);
    position: relative;
  }

  .smap-core-layers {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    position: relative;
  }

  .smap-layer {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 9999px;
    background-color: var(--color-bg-elevated);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .smap-layer--accent {
    background-color: var(--color-accent-muted);
    color: var(--color-accent);
    border-color: var(--color-accent-muted);
  }

  .smap-connector-row {
    display: flex;
    justify-content: center;
    height: 16px;
    position: relative;
  }

  .smap-branch-line {
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, var(--color-accent), var(--viz-line));
  }

  .smap-satellites {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .smap-sat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
    padding: var(--space-3) var(--space-2);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-muted);
    transition: border-color 200ms;
  }

  .smap-sat:hover {
    border-color: var(--color-accent);
  }

  .smap-sat--accent {
    border-color: var(--color-accent-muted);
    background-color: var(--color-accent-dim);
  }

  .smap-sat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--viz-line);
  }

  .smap-sat-dot--accent {
    background-color: var(--color-accent);
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  .smap-sat-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .smap-sat-sub {
    font-size: 10px;
    color: var(--color-text-subtle);
    line-height: 1.3;
  }

  .smap-divider {
    height: 1px;
    background-color: var(--color-border);
  }

  .smap-ai-layer {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .smap-ai-label {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .smap-ai-nodes {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .smap-ai-node {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 4px;
    background-color: var(--color-bg-muted);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
  }

  .smap-ai-node--ship {
    background-color: rgba(16, 185, 129, 0.08);
    color: var(--color-success);
    border-color: rgba(16, 185, 129, 0.2);
  }

  .smap-ai-sep {
    font-size: 10px;
    color: var(--color-accent);
    opacity: 0.6;
  }

  .smap-pulse {
    position: absolute;
    inset: -1px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-accent);
    opacity: 0;
    pointer-events: none;
    animation: agentPulse 4s ease-in-out 2s infinite;
  }

  /* Scroll indicator */
  .hero-scroll-indicator {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    animation: fadeIn 1s ease 2s both;
  }

  .scroll-text {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    font-weight: 500;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-text-subtle), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  @media (max-width: 1023px) {
    .hero-scroll-indicator { display: none; }
  }
</style>
