---
// Identity-first hero. Name and role read before the headline so a
// 5-second visitor knows who's talking.
---

<section class="hero" aria-label="Introduction">
  <div class="container-site hero__inner">
    <div class="hero__id animate-fade-up">
      <span class="hero__id-name">Moe Qadan</span>
      <span class="hero__id-sep" aria-hidden="true">·</span>
      <span class="hero__id-role">Product Designer &amp; UX Engineer</span>
      <a href="/contact" class="hero__id-status" aria-label="Open to hearing about projects — go to contact">
        <span class="hero__id-status-dot" aria-hidden="true"></span>
        Open to projects
      </a>
    </div>

    <h1 class="hero__headline animate-fade-up animate-delay-100">
      I build systems that<br />make complex things <em>usable</em>.
    </h1>

    <p class="hero__paragraph animate-fade-up animate-delay-200">
      I design and ship products end to end — interface, frontend, and the
      system the model lives inside. Work spans long-running enterprise
      platforms (MagTek), advisor tools at major wealth institutions
      (Chase, Cetera, Northwestern Mutual via InvestCloud), and most
      recently <a href="/work/chatobd2" class="hero__inline-link">ChatOBD2</a>,
      an AI-native diagnostics product I designed and engineered solo.
    </p>

    <div class="hero__ctas animate-fade-up animate-delay-300">
      <a
        href="/work"
        class="hero__cta hero__cta--primary"
        data-track="cta_click"
        data-track-cta="see-the-work"
        data-track-loc="home-hero"
      >
        See the work
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="/contact"
        class="hero__cta hero__cta--ghost"
        data-track="cta_click"
        data-track-cta="get-in-touch"
        data-track-loc="home-hero"
      >Get in touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: calc(60px + var(--space-10));
    padding-bottom: var(--space-16);
  }

  @media (min-width: 600px) {
    .hero {
      padding-top: calc(64px + var(--space-12));
      padding-bottom: var(--space-20);
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: calc(64px + var(--space-16));
      padding-bottom: var(--space-24);
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding-top: calc(64px + 96px);
      padding-bottom: 128px;
    }
  }

  .hero__inner {
    max-width: 760px;
  }

  /* Identity strip — name, role, availability — sits above the headline */
  .hero__id {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 10px;
    margin-bottom: var(--space-6);
    font-size: 13px;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .hero__id {
      margin-bottom: var(--space-8);
      font-size: 14px;
    }
  }

  .hero__id-name {
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.005em;
  }

  .hero__id-sep {
    color: var(--color-border);
  }

  .hero__id-role {
    color: var(--color-text-muted);
    letter-spacing: -0.005em;
  }

  .hero__id-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px 3px 9px;
    margin-left: 4px;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-success);
    background-color: color-mix(in srgb, var(--color-success) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-success) 28%, transparent);
    text-decoration: none;
    transition: background-color 150ms, border-color 150ms;
    -webkit-tap-highlight-color: transparent;
  }

  .hero__id-status:hover {
    background-color: color-mix(in srgb, var(--color-success) 14%, transparent);
    border-color: color-mix(in srgb, var(--color-success) 50%, transparent);
  }

  .hero__id-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-success);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-success) 65%, transparent);
    animation: hero-status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes hero-status-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(0.85); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__id-status-dot { animation: none; }
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(38px, 9.5vw, 92px);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.04;
    color: var(--color-text);
    margin-bottom: var(--space-6);
    max-width: 15ch;
    text-wrap: balance;
  }

  @media (min-width: 768px) {
    .hero__headline {
      line-height: 1.02;
      letter-spacing: -0.02em;
      margin-bottom: var(--space-10);
    }
  }

  .hero__headline em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__paragraph {
    font-size: clamp(15px, 1.5vw, 18px);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: 0;
  }

  .hero__inline-link {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color 150ms, text-decoration-color 150ms;
  }

  .hero__inline-link:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 12px;
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .hero__ctas {
      margin-top: var(--space-10);
      gap: 12px 16px;
    }
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    transition: transform 200ms var(--ease-out), background-color 200ms, border-color 200ms, color 200ms, box-shadow 200ms;
    -webkit-tap-highlight-color: transparent;
  }

  .hero__cta--primary {
    background-color: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
  }

  .hero__cta--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
  }

  .hero__cta--ghost {
    background-color: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .hero__cta--ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background-color: var(--color-accent-dim);
  }

  @media (max-width: 380px) {
    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }
    .hero__cta {
      width: 100%;
    }
  }
</style>
